<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.GroupBorderPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border>
        <ScrollViewer Margin="0,0,5,0">
            <StackPanel Margin="15,15,10,15" Spacing="15">
                <yik:GroupBorder Header="Header">
                    <Border
                        Background="CornflowerBlue"
                        CornerRadius="{DynamicResource YikCornerRadius}"
                        Height="120"
                        Margin="15"
                        Width="230">
                        <TextBlock
                            Foreground="White"
                            HorizontalAlignment="Center"
                            Text="Content"
                            VerticalAlignment="Center" />
                    </Border>
                </yik:GroupBorder>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>