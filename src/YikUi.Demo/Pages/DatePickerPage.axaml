<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.DatePickerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Calendar"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <DatePicker />
                <DatePicker Classes="ClearButton" />
                <DatePicker DayFormat="d (ddd)" YearVisible="False" />
                <DatePicker IsEnabled="False" />
                <StackPanel Orientation="Horizontal">
                    <DatePicker IsEnabled="False" />
                    <DatePicker Classes="Bordered" />
                    <DatePicker Classes="Bordered" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>