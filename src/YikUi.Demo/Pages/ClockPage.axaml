<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.ClockPage"
    x:DataType="pages:ClockDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Clock"
        Margin="15"
        Padding="15">
        <Grid RowDefinitions="Auto, *">
            <ToggleSwitch Content="Smooth" Name="smooth" />
            <yik:Clock
                Grid.Row="1"
                HorizontalAlignment="Left"
                IsSmooth="{Binding #smooth.IsChecked}"
                Time="{Binding Time}" />
        </Grid>
    </yik:GroupBorder>
</UserControl>