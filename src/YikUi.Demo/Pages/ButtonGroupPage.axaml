<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.ButtonGroupPage"
    x:DataType="pages:ButtonGroupPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="ButtonGroup"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <yik:ButtonGroup CommandBinding="{Binding InvokeCommand}" ItemsSource="{Binding Items}">
                    <yik:ButtonGroup.ItemTemplate>
                        <DataTemplate x:DataType="pages:ButtonItem">
                            <TextBlock>
                                <Run Text="🐥" />
                                <Run Text="{Binding Name}" />
                            </TextBlock>
                        </DataTemplate>
                    </yik:ButtonGroup.ItemTemplate>
                </yik:ButtonGroup>

                <yik:ButtonGroup
                    CommandBinding="{Binding InvokeCommand}"
                    ContentBinding="{Binding Name}"
                    ItemsSource="{Binding Items}" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>