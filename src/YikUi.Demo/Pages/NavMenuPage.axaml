<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.NavMenuPage"
    x:DataType="pages:NavMenuPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Calendar"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel>
                <ToggleSwitch Content="IsHorizontalCollapsed" Name="collapse" />
                <yik:NavMenu
                    HorizontalAlignment="Left"
                    IsHorizontalCollapsed="{Binding #collapse.IsChecked}"
                    Name="menu2">
                    <yik:NavMenuItem Header="Menu 1">
                        <yik:NavMenuItem.Icon>
                            <Rectangle
                                Fill="Red"
                                Height="10"
                                Width="10" />
                        </yik:NavMenuItem.Icon>
                        <yik:NavMenuItem Header="Sub Menu 1" />
                        <yik:NavMenuItem Header="Sub Menu 2" />
                        <yik:NavMenuItem Header="Sub Menu 3" />
                    </yik:NavMenuItem>
                    <yik:NavMenuItem Header="Menu 2">
                        <yik:NavMenuItem.Icon>
                            <Rectangle
                                Fill="Red"
                                Height="10"
                                Width="10" />
                        </yik:NavMenuItem.Icon>
                    </yik:NavMenuItem>
                    <yik:NavMenuItem Header="Menu 3">
                        <yik:NavMenuItem.Icon>
                            <Rectangle
                                Fill="Red"
                                Height="10"
                                Width="10" />
                        </yik:NavMenuItem.Icon>
                    </yik:NavMenuItem>
                </yik:NavMenu>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>