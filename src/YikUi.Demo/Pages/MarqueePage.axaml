<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.MarqueePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Marquee"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <yik:Form>
                    <TextBox
                        Name="content"
                        Text="Hello Avalonia"
                        Width="300"
                        yik:FormItem.Label="Content" />
                    <yik:EnumSelector
                        EnumType="{x:Type yik:Direction}"
                        Name="direction"
                        Value="{x:Static yik:Direction.Left}"
                        yik:FormItem.Label="Direction" />
                    <yik:EnumSelector
                        EnumType="{x:Type HorizontalAlignment}"
                        Name="horizontal"
                        Value="{x:Static HorizontalAlignment.Center}"
                        yik:FormItem.Label="HorizontalContentAlignment" />
                    <yik:EnumSelector
                        EnumType="{x:Type VerticalAlignment}"
                        Name="vertical"
                        Value="{x:Static VerticalAlignment.Center}"
                        yik:FormItem.Label="VerticalContentAlignment" />
                    <yik:NumericDoubleUpDown
                        AllowDrag="True"
                        Maximum="300"
                        Minimum="-100"
                        Name="speed"
                        Value="60"
                        yik:FormItem.Label="Speed" />
                    <ToggleSwitch
                        IsChecked="True"
                        Name="running"
                        yik:FormItem.Label="IsRunning" />
                </yik:Form>

                <yik:Marquee
                    Background="#cbe7fe"
                    Content="{Binding #content.Text}"
                    Direction="{Binding #direction.Value}"
                    Height="100"
                    HorizontalContentAlignment="{Binding #horizontal.Value}"
                    IsRunning="{Binding #running.IsChecked}"
                    Speed="{Binding #speed.Value}"
                    VerticalContentAlignment="{Binding #vertical.Value}" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>