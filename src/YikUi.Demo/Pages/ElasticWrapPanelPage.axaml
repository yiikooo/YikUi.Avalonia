<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.ElasticWrapPanelPage"
    x:DataType="pages:ElasticWrapPanelDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <UserControl.Styles>
        <Style Selector="yik|FormItem">
            <Setter Property="Width" Value="320" />
        </Style>
        <Style Selector="TabItem#FixToRBTabItem WrapPanel &gt; Border, yik|ElasticWrapPanel &gt; Border">
            <Setter Property="Width" Value="{Binding ItemSelfWidth}" />
            <Setter Property="Height" Value="{Binding ItemSelfHeight}" />
        </Style>
        <Style Selector="yik|EnumSelector">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Styles>
    <UserControl.Resources>
        <Color x:Key="SemiRed5Color">#F93920</Color>
        <Color x:Key="SemiPink5Color">#E91E63</Color>
        <Color x:Key="SemiPurple5Color">#9E28B3</Color>
        <Color x:Key="SemiViolet5Color">#6A3AC7</Color>
        <Color x:Key="SemiIndigo5Color">#3F51B5</Color>
        <Color x:Key="SemiBlue5Color">#0064FA</Color>
        <Color x:Key="SemiLightBlue5Color">#0095EE</Color>
        <Color x:Key="SemiCyan5Color">#05A4B6</Color>
        <Color x:Key="SemiTeal5Color">#00B3A1</Color>
        <Color x:Key="SemiGreen5Color">#3BB346</Color>
        <Color x:Key="SemiLightGreen5Color">#7BB63C</Color>
        <Color x:Key="SemiLime5Color">#9BD100</Color>
        <Color x:Key="SemiYellow5Color">#FAC800</Color>
        <Color x:Key="SemiAmber5Color">#F0B114</Color>
        <Color x:Key="SemiOrange5Color">#FC8800</Color>
        <Color x:Key="SemiGrey5Color">#6B7075</Color>
    </UserControl.Resources>
    <yik:GroupBorder
        Header="ElasticWrapPanel"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <DockPanel>
                <yik:Form
                    DockPanel.Dock="Left"
                    LabelAlignment="Left"
                    LabelPosition="Left"
                    LabelWidth="*"
                    Margin="4,0">
                    <yik:FormGroup>
                        <yik:FormItem Label="Orientation">
                            <yik:EnumSelector EnumType="Orientation" Value="{Binding SelectedOrientation}" />
                        </yik:FormItem>
                        <yik:FormItem Label="HorizontalScrollBar">
                            <yik:EnumSelector EnumType="ScrollBarVisibility" Value="{Binding HorizontalVisibility}" />
                        </yik:FormItem>
                        <yik:FormItem Label="VerticalScrollBar">
                            <yik:EnumSelector EnumType="ScrollBarVisibility" Value="{Binding VerticalVisibility}" />
                        </yik:FormItem>
                        <yik:FormItem>
                            <yik:FormItem.Label>
                                <CheckBox Content="IsFillHorizontal" IsChecked="{Binding IsFillHorizontal}" />
                            </yik:FormItem.Label>
                        </yik:FormItem>
                        <yik:FormItem Label="ItemWidth">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                Maximum="1000"
                                Minimum="0"
                                Step="1"
                                Value="{Binding ItemWidth}" />
                        </yik:FormItem>
                        <yik:FormItem>
                            <yik:FormItem.Label>
                                <CheckBox Content="IsFillVertical" IsChecked="{Binding IsFillVertical}" />
                            </yik:FormItem.Label>
                        </yik:FormItem>
                        <yik:FormItem Label="ItemHeight">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                Maximum="1000"
                                Minimum="0"
                                Step="1"
                                Value="{Binding ItemHeight}" />
                        </yik:FormItem>
                        <yik:FormItem Label="ItemSpacing">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                Maximum="100"
                                Minimum="-10"
                                Step="1"
                                Value="{Binding ItemSpacing}" />
                        </yik:FormItem>
                        <yik:FormItem Label="LineSpacing">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                Maximum="100"
                                Minimum="-10"
                                Step="1"
                                Value="{Binding LineSpacing}" />
                        </yik:FormItem>
                    </yik:FormGroup>
                    <yik:FormGroup Header="FixToRB Extension" IsEnabled="{Binding #FixToRBTabItem.IsSelected}">
                        <yik:FormItem>
                            <yik:FormItem.Label>
                                <CheckBox Content="AutoWidth" IsChecked="{Binding AutoWidth}" />
                            </yik:FormItem.Label>
                        </yik:FormItem>
                        <yik:FormItem Label="ItemSelfWidth">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                IsEnabled="{Binding !AutoWidth}"
                                Maximum="1000"
                                Minimum="0"
                                Value="{Binding ItemSelfWidth}" />
                        </yik:FormItem>
                        <yik:FormItem>
                            <yik:FormItem.Label>
                                <CheckBox Content="AutoHeight" IsChecked="{Binding AutoHeight}" />
                            </yik:FormItem.Label>
                        </yik:FormItem>
                        <yik:FormItem Label="ItemSelfHeight">
                            <yik:NumericDoubleUpDown
                                AllowDrag="True"
                                IsEnabled="{Binding !AutoHeight}"
                                Maximum="1000"
                                Minimum="0"
                                Value="{Binding ItemSelfHeight}" />
                        </yik:FormItem>
                        <yik:FormItem Label="HorizontalAlignment">
                            <yik:EnumSelector EnumType="HorizontalAlignment" Value="{Binding CmbHAlign}" />
                        </yik:FormItem>
                        <yik:FormItem Label="VerticalAlignment">
                            <yik:EnumSelector EnumType="VerticalAlignment" Value="{Binding CmbVAlign}" />
                        </yik:FormItem>
                    </yik:FormGroup>
                </yik:Form>
                <TabControl>
                    <TabItem Header="Flat">
                        <TabControl>
                            <TabItem Header="Common">
                                <yik:ElasticWrapPanel
                                    IsFillHorizontal="{Binding IsFillHorizontal}"
                                    IsFillVertical="{Binding IsFillVertical}"
                                    ItemHeight="{Binding ItemHeight}"
                                    ItemSpacing="{Binding ItemSpacing}"
                                    ItemWidth="{Binding ItemWidth}"
                                    LineSpacing="{Binding LineSpacing}"
                                    Orientation="{Binding SelectedOrientation}">
                                    <Border Background="{DynamicResource SemiRed5Color}" />
                                    <Border Background="{DynamicResource SemiPink5Color}" />
                                    <Border Background="{DynamicResource SemiPurple5Color}" />
                                    <Border Background="{DynamicResource SemiViolet5Color}" />
                                    <Border Background="{DynamicResource SemiIndigo5Color}" />
                                    <Border Background="{DynamicResource SemiBlue5Color}" />
                                    <Border Background="{DynamicResource SemiLightBlue5Color}" />
                                    <Border Background="{DynamicResource SemiCyan5Color}" />
                                    <Border Background="{DynamicResource SemiTeal5Color}" />
                                    <Border Background="{DynamicResource SemiGreen5Color}" />
                                    <Border Background="{DynamicResource SemiLightGreen5Color}" />
                                    <Border Background="{DynamicResource SemiLime5Color}" />
                                    <Border Background="{DynamicResource SemiYellow5Color}" />
                                    <Border Background="{DynamicResource SemiAmber5Color}" />
                                    <Border Background="{DynamicResource SemiOrange5Color}" />
                                    <Border Background="{DynamicResource SemiGrey5Color}" />
                                </yik:ElasticWrapPanel>
                            </TabItem>
                            <TabItem Header="Grid Auto">
                                <Grid RowDefinitions="auto,*">
                                    <yik:ElasticWrapPanel
                                        Grid.Row="0"
                                        IsFillHorizontal="{Binding IsFillHorizontal}"
                                        IsFillVertical="{Binding IsFillVertical}"
                                        ItemHeight="{Binding ItemHeight}"
                                        ItemSpacing="{Binding ItemSpacing}"
                                        ItemWidth="{Binding ItemWidth}"
                                        LineSpacing="{Binding LineSpacing}"
                                        Orientation="{Binding SelectedOrientation}">
                                        <Border Background="{DynamicResource SemiRed5Color}" />
                                        <Border Background="{DynamicResource SemiPink5Color}" />
                                        <Border Background="{DynamicResource SemiPurple5Color}" />
                                        <Border Background="{DynamicResource SemiViolet5Color}" />
                                        <Border Background="{DynamicResource SemiIndigo5Color}" />
                                        <Border Background="{DynamicResource SemiBlue5Color}" />
                                        <Border Background="{DynamicResource SemiLightBlue5Color}" />
                                        <Border Background="{DynamicResource SemiCyan5Color}" />
                                        <Border Background="{DynamicResource SemiTeal5Color}" />
                                        <Border Background="{DynamicResource SemiGreen5Color}" />
                                        <Border Background="{DynamicResource SemiLightGreen5Color}" />
                                        <Border Background="{DynamicResource SemiLime5Color}" />
                                        <Border Background="{DynamicResource SemiYellow5Color}" />
                                        <Border Background="{DynamicResource SemiAmber5Color}" />
                                        <Border Background="{DynamicResource SemiOrange5Color}" />
                                        <Border Background="{DynamicResource SemiGrey5Color}" />
                                    </yik:ElasticWrapPanel>
                                    <Border
                                        Grid.Row="1"
                                        Margin="0,4"
                                        Theme="{StaticResource CardBorder}">
                                        <TextBlock Text="This is blank" />
                                    </Border>
                                </Grid>
                            </TabItem>
                            <TabItem Header="ScrollViewer">
                                <Border Margin="0,4">
                                    <ScrollViewer HorizontalScrollBarVisibility="{Binding HorizontalVisibility}"
                                                  VerticalScrollBarVisibility="{Binding VerticalVisibility}">
                                        <yik:ElasticWrapPanel
                                            IsFillHorizontal="{Binding IsFillHorizontal}"
                                            IsFillVertical="{Binding IsFillVertical}"
                                            ItemHeight="{Binding ItemHeight}"
                                            ItemSpacing="{Binding ItemSpacing}"
                                            ItemWidth="{Binding ItemWidth}"
                                            LineSpacing="{Binding LineSpacing}"
                                            Orientation="{Binding SelectedOrientation}">
                                            <Border Background="{DynamicResource SemiRed5Color}" />
                                            <Border Background="{DynamicResource SemiPink5Color}" />
                                            <Border Background="{DynamicResource SemiPurple5Color}" />
                                            <Border Background="{DynamicResource SemiViolet5Color}" />
                                            <Border Background="{DynamicResource SemiIndigo5Color}" />
                                            <Border Background="{DynamicResource SemiBlue5Color}" />
                                            <Border Background="{DynamicResource SemiLightBlue5Color}" />
                                            <Border Background="{DynamicResource SemiCyan5Color}" />
                                            <Border Background="{DynamicResource SemiTeal5Color}" />
                                            <Border Background="{DynamicResource SemiGreen5Color}" />
                                            <Border Background="{DynamicResource SemiLightGreen5Color}" />
                                            <Border Background="{DynamicResource SemiLime5Color}" />
                                            <Border Background="{DynamicResource SemiYellow5Color}" />
                                            <Border Background="{DynamicResource SemiAmber5Color}" />
                                            <Border Background="{DynamicResource SemiOrange5Color}" />
                                            <Border Background="{DynamicResource SemiGrey5Color}" />
                                        </yik:ElasticWrapPanel>
                                    </ScrollViewer>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </TabItem>

                    <TabItem Header="FixToRB" Name="FixToRBTabItem">
                        <DockPanel>
                            <TabControl>
                                <TabItem Header="Single">
                                    <StackPanel>
                                        <ScrollViewer HorizontalScrollBarVisibility="{Binding HorizontalVisibility}"
                                                      VerticalScrollBarVisibility="{Binding VerticalVisibility}">
                                            <StackPanel>
                                                <yik:Divider Content="WrapPanel" HorizontalContentAlignment="Left" />
                                                <WrapPanel
                                                    ItemHeight="{Binding ItemHeight}"
                                                    ItemSpacing="{Binding ItemSpacing}"
                                                    ItemWidth="{Binding ItemWidth}"
                                                    LineSpacing="{Binding LineSpacing}"
                                                    Orientation="{Binding SelectedOrientation}">
                                                    <Border Background="{DynamicResource SemiRed5Color}" />
                                                    <Border Background="{DynamicResource SemiPink5Color}" />
                                                    <Border Background="{DynamicResource SemiPurple5Color}" />
                                                    <Border Background="{DynamicResource SemiViolet5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                </WrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                        <ScrollViewer HorizontalScrollBarVisibility="{Binding HorizontalVisibility}"
                                                      VerticalScrollBarVisibility="{Binding VerticalVisibility}">
                                            <StackPanel>
                                                <yik:Divider Content="ElasticWrapPanel"
                                                             HorizontalContentAlignment="Left" />
                                                <yik:ElasticWrapPanel
                                                    IsFillHorizontal="{Binding IsFillHorizontal}"
                                                    IsFillVertical="{Binding IsFillVertical}"
                                                    ItemHeight="{Binding ItemHeight}"
                                                    ItemSpacing="{Binding ItemSpacing}"
                                                    ItemWidth="{Binding ItemWidth}"
                                                    LineSpacing="{Binding LineSpacing}"
                                                    Orientation="{Binding SelectedOrientation}">
                                                    <Border Background="{DynamicResource SemiRed5Color}" />
                                                    <Border Background="{DynamicResource SemiPink5Color}" />
                                                    <Border Background="{DynamicResource SemiPurple5Color}" />
                                                    <Border Background="{DynamicResource SemiViolet5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}"
                                                        yik:ElasticWrapPanel.FixToRB="True">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                </yik:ElasticWrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Multiply">
                                    <StackPanel>
                                        <ScrollViewer HorizontalScrollBarVisibility="{Binding HorizontalVisibility}"
                                                      VerticalScrollBarVisibility="{Binding VerticalVisibility}">
                                            <StackPanel>
                                                <yik:Divider Content="WrapPanel" HorizontalContentAlignment="Left" />
                                                <WrapPanel
                                                    ItemHeight="{Binding ItemHeight}"
                                                    ItemSpacing="{Binding ItemSpacing}"
                                                    ItemWidth="{Binding ItemWidth}"
                                                    LineSpacing="{Binding LineSpacing}"
                                                    Orientation="{Binding SelectedOrientation}">
                                                    <Border Background="{DynamicResource SemiRed5Color}" />
                                                    <Border Background="{DynamicResource SemiPink5Color}" />
                                                    <Border Background="{DynamicResource SemiPurple5Color}" />
                                                    <Border Background="{DynamicResource SemiViolet5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}"
                                                        yik:ElasticWrapPanel.FixToRB="True">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                    <Border Background="{DynamicResource SemiIndigo5Color}" />
                                                    <Border Background="{DynamicResource SemiBlue5Color}" />
                                                    <Border Background="{DynamicResource SemiLightBlue5Color}" />
                                                    <Border Background="{DynamicResource SemiCyan5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}"
                                                        yik:ElasticWrapPanel.FixToRB="True">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                </WrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                        <ScrollViewer HorizontalScrollBarVisibility="{Binding HorizontalVisibility}"
                                                      VerticalScrollBarVisibility="{Binding VerticalVisibility}">
                                            <StackPanel>
                                                <yik:Divider Content="ElasticWrapPanel"
                                                             HorizontalContentAlignment="Left" />
                                                <yik:ElasticWrapPanel
                                                    IsFillHorizontal="{Binding IsFillHorizontal}"
                                                    IsFillVertical="{Binding IsFillVertical}"
                                                    ItemHeight="{Binding ItemHeight}"
                                                    ItemSpacing="{Binding ItemSpacing}"
                                                    ItemWidth="{Binding ItemWidth}"
                                                    LineSpacing="{Binding LineSpacing}"
                                                    Orientation="{Binding SelectedOrientation}">
                                                    <Border Background="{DynamicResource SemiRed5Color}" />
                                                    <Border Background="{DynamicResource SemiPink5Color}" />
                                                    <Border Background="{DynamicResource SemiPurple5Color}" />
                                                    <Border Background="{DynamicResource SemiViolet5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}"
                                                        yik:ElasticWrapPanel.FixToRB="True">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                    <Border Background="{DynamicResource SemiIndigo5Color}" />
                                                    <Border Background="{DynamicResource SemiBlue5Color}" />
                                                    <Border Background="{DynamicResource SemiLightBlue5Color}" />
                                                    <Border Background="{DynamicResource SemiCyan5Color}" />
                                                    <UniformGrid
                                                        HorizontalAlignment="{Binding CmbHAlign}"
                                                        MinWidth="200"
                                                        Rows="1"
                                                        VerticalAlignment="{Binding CmbVAlign}"
                                                        yik:ElasticWrapPanel.FixToRB="True">
                                                        <Button Content="Search" />
                                                        <Button Content="Export" />
                                                    </UniformGrid>
                                                </yik:ElasticWrapPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>