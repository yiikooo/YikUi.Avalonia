<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.DropDownButtonPage"
    x:DataType="pages:DropDownButtonPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="DropDownButton"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <WrapPanel ItemSpacing="15" LineSpacing="15">
                <DropDownButton Content="DropDownButton">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Command="{Binding Tip}" Header="Item 1" />
                            <MenuItem Command="{Binding Tip}" Header="Item 2" />
                            <MenuItem Command="{Binding Tip}" Header="Item 3" />
                            <Separator />
                            <MenuItem Command="{Binding Tip}" Header="More Options" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton Content="Disabled" IsEnabled="False">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="Item 1" />
                            <MenuItem Header="Item 2" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton Classes="Danger" Content="Danger DropDownButton">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Command="{Binding Tip}" Header="Delete" />
                            <MenuItem Command="{Binding Tip}" Header="Remove" />
                            <Separator />
                            <MenuItem Command="{Binding Tip}" Header="Cancel" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton
                    Classes="Danger"
                    Content="Danger Disabled"
                    IsEnabled="False">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Command="{Binding Tip}" Header="Delete" />
                            <MenuItem Command="{Binding Tip}" Header="Remove" />
                            <Separator />
                            <MenuItem Command="{Binding Tip}" Header="Cancel" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </WrapPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>