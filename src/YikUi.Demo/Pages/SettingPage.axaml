<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.SettingPage"
    x:DataType="pages:SettingPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Setting"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel>
                <TextBlock Text="ThemeVariant" />
                <ComboBox ItemsSource="{Binding ThemeVariants}" SelectedItem="{Binding SelectedThemeVariant}" />
                <TextBlock Text="ThemeColor" />
                <TextBox
                    KeyDown="InputElement_OnKeyDown"
                    Name="ThemeColor"
                    PlaceholderText="Enter hex color" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>