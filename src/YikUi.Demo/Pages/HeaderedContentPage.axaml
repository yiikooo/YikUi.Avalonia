<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.HeaderedContentPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder Header="HeaderedContentControl" Margin="15">
        <HeaderedContentControl
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="10"
            Header="This is the text header!"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Border
                Background="CornflowerBlue"
                CornerRadius="{DynamicResource YikCornerRadius}"
                Height="120"
                Margin="15"
                Width="230">
                <TextBlock
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Text="Content"
                    VerticalAlignment="Center" />
            </Border>
        </HeaderedContentControl>
    </yik:GroupBorder>
</UserControl>