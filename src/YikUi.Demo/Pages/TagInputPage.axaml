<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.TagInputPage"
    x:DataType="pages:TagInputDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="TagInput"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <yik:TagInput
                    AllowDuplicates="True"
                    Name="labels"
                    Separator="-"
                    Tags="{Binding Tags}"
                    Watermark="Hello world" />
                <yik:TagInput
                    AllowDuplicates="False"
                    LostFocusBehavior="Clear"
                    Separator="-"
                    Tags="{Binding DistinctTags}" />
                <ListBox ItemsSource="{Binding DistinctTags}" />
                <yik:TagInput
                    AcceptsReturn="True"
                    AllowDuplicates="False"
                    LostFocusBehavior="Clear"
                    Separator="-"
                    Tags="{Binding DistinctTags}" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>