<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.LoadingPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Loading"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <Grid RowDefinitions="Auto, Auto, *">
                <ToggleSwitch Content="Loading" Name="s" />
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <yik:LoadingIcon Classes="Small" />
                    <yik:LoadingIcon />
                    <yik:LoadingIcon Classes="Large" />
                </StackPanel>
                <yik:LoadingContainer
                    Grid.Row="2"
                    IsLoading="{Binding #s.IsChecked}"
                    LoadingMessage="Loading...">
                    <Calendar />
                </yik:LoadingContainer>
            </Grid>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>