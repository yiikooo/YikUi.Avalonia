<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.AvatarPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Avatar"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel
                Orientation="Horizontal"
                Spacing="20"
                VerticalAlignment="Top">
                <yik:Avatar Content="HI" />
                <yik:Avatar Classes="Red">
                    <yik:Avatar.HoverMask>
                        <Border Opacity="0.6">
                            <Panel>
                                <Border
                                    Background="#16161A"
                                    Height="{Binding $parent[yik:Avatar].Height}"
                                    Width="{Binding $parent[yik:Avatar].Width}" />
                                <PathIcon
                                    Data="F1 M512,512z M0,0z M149.1,64.8L138.7,96 64,96C28.7,96,0,124.7,0,160L0,416C0,451.3,28.7,480,64,480L448,480C483.3,480,512,451.3,512,416L512,160C512,124.7,483.3,96,448,96L373.3,96 362.9,64.8C356.4,45.2,338.1,32,317.4,32L194.6,32C173.9,32,155.6,45.2,149.1,64.8z M256,192A96,96,0,1,1,256,384A96,96,0,1,1,256,192z"
                                    Foreground="White"
                                    Height="{Binding $parent[yik:Avatar].FontSize}"
                                    Width="{Binding $parent[yik:Avatar].FontSize}" />
                            </Panel>
                        </Border>
                    </yik:Avatar.HoverMask>
                </yik:Avatar>
                <yik:Avatar Source="/icon.png" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>