<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.DateTimePickerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="DateTimePicker"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <yik:Form>
                    <TextBox
                        Name="formatBox"
                        Text="yyyy年MM月dd日 HH时mm分ss秒"
                        Width="300"
                        yik:FormItem.Label="DisplayFormat" />
                    <TextBox
                        Name="panelBox"
                        Text="hh mm ss"
                        Width="300"
                        yik:FormItem.Label="Panel" />
                    <yik:DateTimePicker
                        Classes="ClearButton"
                        DisplayFormat="{Binding #formatBox.Text}"
                        PanelFormat="{Binding #panelBox.Text}"
                        Width="300"
                        yik:FormItem.NoLabel="True" />
                </yik:Form>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>