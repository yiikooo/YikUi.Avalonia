<UserControl
    d:DesignHeight="800"
    d:DesignWidth="900"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.ContentDialogPage"
    x:DataType="pages:ContentDialogDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">

    <yik:GroupBorder
        Header="ContentDialog"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="24">

                <!--  基础用法  -->
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="基础用法" />

                    <Grid ColumnDefinitions="280, *" ColumnSpacing="24">

                        <!--  左侧：选项配置面板  -->
                        <yik:Form Grid.Column="0" LabelPosition="Top">
                            <TextBox
                                HorizontalAlignment="Stretch"
                                PlaceholderText="对话框标题"
                                Text="{Binding Title}"
                                yik:FormItem.Label="Title" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                PlaceholderText="对话框内容文字"
                                Text="{Binding Content}"
                                TextWrapping="Wrap"
                                yik:FormItem.Label="Content" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                PlaceholderText="留空则不显示"
                                Text="{Binding PrimaryText}"
                                yik:FormItem.Label="Primary Button Text" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                PlaceholderText="留空则不显示"
                                Text="{Binding SecondaryText}"
                                yik:FormItem.Label="Secondary Button Text" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                PlaceholderText="留空则不显示"
                                Text="{Binding CloseText}"
                                yik:FormItem.Label="Close Button Text" />
                            <yik:EnumSelector
                                EnumType="yik:ContentDialogButton"
                                HorizontalAlignment="Stretch"
                                Value="{Binding DefaultButton}"
                                yik:FormItem.Label="Default Button" />
                            <CheckBox IsChecked="{Binding FullSizeDesired}" yik:FormItem.Label="Full Size Desired" />

                            <yik:FormItem NoLabel="True">
                                <Button
                                    Classes="accent"
                                    Command="{Binding ShowBasicCommand}"
                                    Content="Show ContentDialog"
                                    HorizontalAlignment="Stretch" />
                            </yik:FormItem>
                        </yik:Form>

                        <!--  右侧：结果展示  -->
                        <Border
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="8"
                            Grid.Column="1"
                            Padding="20">
                            <StackPanel Spacing="12" VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{DynamicResource TextSecondaryColor}"
                                    Text="点击按钮后对话框关闭，此处显示结果" />
                                <Separator />
                                <Grid
                                    ColumnDefinitions="Auto, *"
                                    RowDefinitions="Auto, Auto"
                                    RowSpacing="8">
                                    <TextBlock
                                        FontWeight="Medium"
                                        Grid.Column="0"
                                        Grid.Row="0"
                                        Margin="0,0,12,0"
                                        Text="Last Result:" />
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource ThemeAccentColor}"
                                        Grid.Column="1"
                                        Grid.Row="0"
                                        Text="{Binding LastResult}" />

                                    <TextBlock
                                        FontWeight="Medium"
                                        Grid.Column="0"
                                        Grid.Row="1"
                                        Margin="0,0,12,0"
                                        Text="Show Count:" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Grid.Row="1"
                                        Text="{Binding ShowCount}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Separator />

                <!--  预设示例  -->
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="预设示例" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryColor}" Text="点击按钮快速体验不同的常见场景" />
                    <WrapPanel ItemSpacing="10" LineSpacing="10">
                        <Button Command="{Binding ShowDeleteConfirmCommand}" Content="Delete Confirm" />
                        <Button Command="{Binding ShowSaveCommand}" Content="Save Changes" />
                        <Button Command="{Binding ShowAlertCommand}" Content="Alert (No Input)" />
                        <Button Command="{Binding ShowInputDialogCommand}" Content="Input Dialog" />
                    </WrapPanel>
                    <TextBlock>
                        <Run Text="预设示例结果: " />
                        <Run
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource ThemeAccentColor}"
                            Text="{Binding PresetResult}" />
                    </TextBlock>
                </StackPanel>

                <Separator />

                <!--  Deferral（异步验证）  -->
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="Deferral — 异步关闭验证" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryColor}" TextWrapping="Wrap">
                        点击 Primary 按钮后，通过 Deferral 延迟关闭并模拟 1 秒的异步校验。
                        若取消则对话框不会关闭。
                    </TextBlock>
                    <Button Command="{Binding ShowDeferralCommand}" Content="Show Deferral Demo" />
                    <TextBlock>
                        <Run Text="Deferral 结果: " />
                        <Run
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource ThemeAccentColor}"
                            Text="{Binding DeferralResult}" />
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>