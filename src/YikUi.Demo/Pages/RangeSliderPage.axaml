<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.RangeSliderPage"
    x:DataType="pages:RangeSliderDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <UserControl.Styles>
        <Style Selector="yik|NumericDoubleUpDown">
            <Setter Property="Width" Value="300" />
        </Style>
    </UserControl.Styles>
    <yik:GroupBorder
        Header="RangeSlider"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <yik:RangeSlider
                    IsSnapToTick="True"
                    LowerValue="{Binding #range.LowerValue, Mode=TwoWay}"
                    Maximum="{Binding #range.Maximum, Mode=TwoWay}"
                    Minimum="{Binding #range.Minimum, Mode=TwoWay}"
                    TickFrequency="5"
                    TickPlacement="TopLeft"
                    UpperValue="{Binding #range.UpperValue, Mode=TwoWay}" />
                <yik:NumericDoubleUpDown InnerLeftContent="Minimum" Value="{Binding #range.Minimum, Mode=TwoWay}" />
                <yik:NumericDoubleUpDown InnerLeftContent="Maximum" Value="{Binding #range.Maximum, Mode=TwoWay}" />
                <yik:NumericDoubleUpDown InnerLeftContent="LowerValue" Value="{Binding #range.LowerValue, Mode=TwoWay}" />
                <yik:NumericDoubleUpDown InnerLeftContent="UpperValue" Value="{Binding #range.UpperValue, Mode=TwoWay}" />
                <ComboBox ItemsSource="{Binding Orientations}" SelectedItem="{Binding Orientation}" />
                <yik:RangeSlider
                    HorizontalAlignment="Left"
                    Margin="8"
                    Name="range"
                    Orientation="{Binding Orientation}"
                    TickFrequency="5"
                    VerticalAlignment="Top">
                    <yik:RangeSlider.Styles>
                        <Style Selector="yik|RangeSlider:horizontal">
                            <Setter Property="Width" Value="400" />
                            <Setter Property="Height" Value="40" />
                        </Style>
                        <Style Selector="yik|RangeSlider:vertical">
                            <Setter Property="Width" Value="40" />
                            <Setter Property="Height" Value="400" />
                        </Style>
                    </yik:RangeSlider.Styles>
                </yik:RangeSlider>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>