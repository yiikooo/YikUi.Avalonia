<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.AspectRatioLayoutPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="AspectRatioLayout"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0">
                    <yik:NumericDoubleUpDown InnerLeftContent="AspectRatioTolerance" Value="{Binding #AspectRatioLayout.AspectRatioTolerance}" />
                    <TextBlock Text="{Binding #AspectRatioLayout.AspectRatioValue, StringFormat='AspectRatioValue: {0}'}" />
                </StackPanel>

                <yik:AspectRatioLayout
                    BorderBrush="Red"
                    BorderThickness="1"
                    CornerRadius="10"
                    Grid.Row="1"
                    Margin="2"
                    Name="AspectRatioLayout">
                    <yik:AspectRatioLayoutItem AcceptAspectRatioMode="HorizontalRectangle">
                        <Button>HorizontalRectangle ControlLayout</Button>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem AcceptAspectRatioMode="VerticalRectangle">
                        <Button>VerticalRectangle ControlLayout</Button>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem AcceptAspectRatioMode="Square">
                        <Button>Square ControlLayout</Button>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem EndAspectRatioValue="2.2" StartAspectRatioValue="2">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].StartAspectRatioValue, StringFormat='StartAspectRatioValue {0}'}" />
                            <LineBreak />
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].EndAspectRatioValue, StringFormat='EndAspectRatioValue {0}'}" />
                        </TextBlock>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem EndAspectRatioValue="2.4" StartAspectRatioValue="2">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].StartAspectRatioValue, StringFormat='StartAspectRatioValue {0}'}" />
                            <LineBreak />
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].EndAspectRatioValue, StringFormat='EndAspectRatioValue {0}'}" />
                        </TextBlock>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem EndAspectRatioValue="2.6" StartAspectRatioValue="2">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].StartAspectRatioValue, StringFormat='StartAspectRatioValue {0}'}" />
                            <LineBreak />
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].EndAspectRatioValue, StringFormat='EndAspectRatioValue {0}'}" />
                        </TextBlock>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem EndAspectRatioValue="2.8" StartAspectRatioValue="2">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].StartAspectRatioValue, StringFormat='StartAspectRatioValue {0}'}" />
                            <LineBreak />
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].EndAspectRatioValue, StringFormat='EndAspectRatioValue {0}'}" />
                        </TextBlock>
                    </yik:AspectRatioLayoutItem>
                    <yik:AspectRatioLayoutItem EndAspectRatioValue="1.5" StartAspectRatioValue="1.3">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].StartAspectRatioValue, StringFormat='StartAspectRatioValue {0}'}" />
                            <LineBreak />
                            <Run Text="{Binding $parent[yik:AspectRatioLayoutItem].EndAspectRatioValue, StringFormat='EndAspectRatioValue {0}'}" />
                        </TextBlock>
                    </yik:AspectRatioLayoutItem>
                </yik:AspectRatioLayout>
            </Grid>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>