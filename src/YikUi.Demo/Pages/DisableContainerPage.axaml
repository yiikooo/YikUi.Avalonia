<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.DisableContainerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="DisableContainer"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <ToggleSwitch IsChecked="True" Name="s" />
                <yik:DisableContainer DisabledTip="This is disabled. ">
                    <Button IsEnabled="{Binding #s.IsChecked}">Hello World!</Button>
                </yik:DisableContainer>
                <yik:DisableContainer DisabledTip="This is disabled. ">
                    <Calendar IsEnabled="{Binding #s.IsChecked}" />
                </yik:DisableContainer>
                <yik:DisableContainer>
                    <Button IsEnabled="{Binding #s.IsChecked}">Hello Avalonia</Button>
                </yik:DisableContainer>
                <Button
                    IsEnabled="{Binding #s.IsChecked}"
                    yik:DisabledAdorner.DisabledTip="Fine"
                    yik:DisabledAdorner.IsEnabled="True">
                    Hello Avalonia
                </Button>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>