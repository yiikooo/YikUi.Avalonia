<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.ToastPage"
    x:DataType="pages:ToastPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border>
        <ScrollViewer Margin="0,0,5,0">
            <StackPanel Margin="15,15,10,15" Spacing="10">

                <!--  基础 Toast  -->
                <yik:GroupBorder Header="基础 Toast">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowInformationToast}" Content="Information Toast" />
                        <Button Command="{Binding ShowSuccessToast}" Content="Success Toast" />
                        <Button Command="{Binding ShowWarningToast}" Content="Warning Toast" />
                        <Button Command="{Binding ShowErrorToast}" Content="Error Toast" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  不同持续时间  -->
                <yik:GroupBorder Header="持续时间">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowShortToast}" Content="短时间 (1秒)" />
                        <Button Command="{Binding ShowNormalToast}" Content="正常 (3秒)" />
                        <Button Command="{Binding ShowLongToast}" Content="长时间 (5秒)" />
                        <Button Command="{Binding ShowPersistentToast}" Content="持久显示" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  图标显示  -->
                <yik:GroupBorder Header="图标显示">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowToastWithIcon}" Content="显示图标" />
                        <Button Command="{Binding ShowToastWithoutIcon}" Content="隐藏图标" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  关闭按钮  -->
                <yik:GroupBorder Header="关闭按钮">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowToastWithCloseButton}" Content="显示关闭按钮" />
                        <Button Command="{Binding ShowToastWithoutCloseButton}" Content="隐藏关闭按钮" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  操作按钮  -->
                <yik:GroupBorder Header="操作按钮">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowToastWithSingleButton}" Content="单个操作按钮" />
                        <Button Command="{Binding ShowToastWithMultipleButtons}" Content="多个操作按钮" />
                        <Button Command="{Binding ShowToastWithInlineButtons}" Content="内联按钮" />
                        <Button Command="{Binding ShowToastWithStackedButtons}" Content="堆叠按钮" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  样式  -->
                <yik:GroupBorder Header="样式">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowLightToast}" Content="Light 样式" />
                        <Button Command="{Binding ShowColorfulToast}" Content="Colorful 样式" />
                        <Button Command="{Binding ShowDefaultToast}" Content="默认样式" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  交互事件  -->
                <yik:GroupBorder Header="交互事件">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowToastWithClick}" Content="点击事件" />
                        <Button Command="{Binding ShowToastWithClose}" Content="关闭事件" />
                        <Button Command="{Binding ShowToastWithTouchClose}" Content="点击关闭" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  长文本内容  -->
                <yik:GroupBorder Header="长文本内容">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowLongContentToast}" Content="长文本 Toast" />
                        <Button Command="{Binding ShowMultiLineToast}" Content="多行文本 Toast" />
                    </WrapPanel>
                </yik:GroupBorder>

                <!--  综合示例  -->
                <yik:GroupBorder Header="综合示例">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowComplexToast}" Content="复杂 Toast" />
                        <Button Command="{Binding ShowCustomToast}" Content="自定义 Toast" />
                    </WrapPanel>
                </yik:GroupBorder>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>