<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.RefreshContainerPage"
    x:DataType="pages:RefreshContainerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Calendar"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <DockPanel HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <Label DockPanel.Dock="Top">A control that supports pull to refresh</Label>
                <RefreshContainer
                    DockPanel.Dock="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="5"
                    Name="Refresh"
                    PullDirection="TopToBottom"
                    RefreshRequested="RefreshContainerPage_RefreshRequested"
                    VerticalAlignment="Stretch">
                    <ListBox
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Items}"
                        VerticalAlignment="Top" />
                </RefreshContainer>
            </DockPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>