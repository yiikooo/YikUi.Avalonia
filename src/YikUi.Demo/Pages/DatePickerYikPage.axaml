<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.DatePickerYikPage"
    x:DataType="pages:DatePickerDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:YikUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="DatePicker(yik)"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <TextBox
                    InnerLeftContent="Display Format"
                    Name="format"
                    Text="yyyy-MM-dd" />
                <TextBlock Text="Default" />
                <yik:DatePicker DisplayFormat="{Binding #format.Text}" Width="200" />
                <TextBlock Text="Binding" />
                <yik:DatePicker
                    DisplayFormat="{Binding #format.Text}"
                    SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                    Width="200" />
                <TextBlock Text="Clear Button" />
                <yik:DatePicker
                    Classes="ClearButton"
                    Name="singlePicker"
                    Width="200" />
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>