<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Demo.Pages.BadgePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:GroupBorder
        Header="Badge"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <yik:EnumSelector EnumType="{x:Type yik:CornerPosition}" Name="position" />
                <yik:Badge
                    CornerPosition="{Binding #position.Value}"
                    Header="Badge Content"
                    Margin="90,0,0,0">
                    <Button Content="Test" />
                </yik:Badge>
            </StackPanel>
        </ScrollViewer>
    </yik:GroupBorder>
</UserControl>