<yik:YikWindow
    CanResize="True"
    Icon="icon.in.ico"
    MinHeight="400"
    MinWidth="600"
    Title="YikUi.Demo"
    WindowStartupLocation="CenterScreen"
    x:Class="YikUi.Demo.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:YikWindow.TitleBarLeftContent>
        <TextBlock Text="TitleBarLeftContent" />
    </yik:YikWindow.TitleBarLeftContent>

    <yik:YikWindow.TitleBarRightContent>
        <TextBlock Text="TitleBarRightContent" />
    </yik:YikWindow.TitleBarRightContent>

    <Border Margin="10">
        <TextBlock Margin="5,0,0,0" Text="Hi Avalonia!" />
    </Border>
</yik:YikWindow>