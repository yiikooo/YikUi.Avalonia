<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.NumberDisplayerPage"
    x:DataType="pages:NumberDisplayerDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:TioUi.Demo.Pages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="NumberDisplayer"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <Button Command="{Binding IncreaseCommand}" HorizontalAlignment="Left">Change</Button>
                <tio:Int32Displayer Value="{Binding Value}" />
                <tio:Int64Displayer Value="{Binding LongValue}" />
                <tio:DoubleDisplayer StringFormat="N2" Value="{Binding DoubleValue}" />
                <tio:DateDisplay
                    FontSize="30"
                    StringFormat="yyyy-MM-dd"
                    Value="{Binding DateValue}" />
                <TextBlock Text="Selectable: " />
                <tio:Int32Displayer IsSelectable="True" Value="{Binding Value}" />
                <tio:Int64Displayer IsSelectable="True" Value="{Binding LongValue}" />
                <tio:DoubleDisplayer
                    IsSelectable="True"
                    StringFormat="N2"
                    Value="{Binding DoubleValue}" />
                <tio:DateDisplay
                    FontSize="30"
                    IsSelectable="True"
                    StringFormat="yyyy-MM-dd"
                    Value="{Binding DateValue}" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>