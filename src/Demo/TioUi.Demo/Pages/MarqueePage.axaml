<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.MarqueePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="Marquee"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <tio:Form>
                    <TextBox
                        Name="content"
                        Text="Hello Avalonia"
                        Width="300"
                        tio:FormItem.Label="Content" />
                    <tio:EnumSelector
                        EnumType="{x:Type tio:Direction}"
                        Name="direction"
                        Value="{x:Static tio:Direction.Left}"
                        tio:FormItem.Label="Direction" />
                    <tio:EnumSelector
                        EnumType="{x:Type HorizontalAlignment}"
                        Name="horizontal"
                        Value="{x:Static HorizontalAlignment.Center}"
                        tio:FormItem.Label="HorizontalContentAlignment" />
                    <tio:EnumSelector
                        EnumType="{x:Type VerticalAlignment}"
                        Name="vertical"
                        Value="{x:Static VerticalAlignment.Center}"
                        tio:FormItem.Label="VerticalContentAlignment" />
                    <tio:NumericDoubleUpDown
                        AllowDrag="True"
                        Maximum="300"
                        Minimum="-100"
                        Name="speed"
                        Value="60"
                        tio:FormItem.Label="Speed" />
                    <ToggleSwitch
                        IsChecked="True"
                        Name="running"
                        tio:FormItem.Label="IsRunning" />
                </tio:Form>

                <tio:Marquee
                    Background="#cbe7fe"
                    Content="{Binding #content.Text}"
                    Direction="{Binding #direction.Value}"
                    Height="100"
                    HorizontalContentAlignment="{Binding #horizontal.Value}"
                    IsRunning="{Binding #running.IsChecked}"
                    Speed="{Binding #speed.Value}"
                    VerticalContentAlignment="{Binding #vertical.Value}" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>