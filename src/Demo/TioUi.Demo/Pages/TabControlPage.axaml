<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.TabControlPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border>
        <ScrollViewer Margin="0,0,5,0">
            <StackPanel Margin="15,15,10,15" Spacing="10">
                <tio:GroupBorder Header="TabControlStyles" Padding="15">
                    <StackPanel Spacing="15">
                        <Border HorizontalAlignment="Left" Theme="{StaticResource RadioButtonGroupBorder}">
                            <ListBox
                                Name="place"
                                SelectedIndex="3"
                                Theme="{StaticResource ButtonRadioGroupListBox}">
                                <Dock>Left</Dock>
                                <Dock>Bottom</Dock>
                                <Dock>Right</Dock>
                                <Dock>Top</Dock>
                            </ListBox>
                        </Border>
                        <ToggleSwitch Content="ReverseSeparator (only left-right place of the default theme)" Name="reverse" />
                    </StackPanel>
                </tio:GroupBorder>
                <tio:GroupBorder Header="TabControl" Padding="15">
                    <TabControl Classes.ReverseSeparator="{Binding #reverse.IsChecked}" TabStripPlacement="{Binding #place.SelectedValue}">
                        <TabItem Content="Hello 1" Header="Tab 1" />
                        <TabItem Content="Hello 2" Header="Tab 2" />
                        <TabItem Content="Hello 3" Header="Tab 3" />
                        <TabItem Content="中文内容" Header="中文中文" />
                        <TabItem
                            Content="Hello 4"
                            Header="Tab 4"
                            IsEnabled="False" />
                    </TabControl>
                </tio:GroupBorder>
                <tio:GroupBorder Header="LineTabControl" Padding="15">
                    <TabControl TabStripPlacement="{Binding #place.SelectedValue}" Theme="{StaticResource LineTabControl}">
                        <TabItem Content="Hello 1" Header="Tab 1" />
                        <TabItem Content="Hello 2" Header="Tab 2" />
                        <TabItem Content="Hello 3" Header="Tab 3" />
                        <TabItem Content="中文内容" Header="中文中文" />
                        <TabItem
                            Content="Hello 4"
                            Header="Tab 4"
                            IsEnabled="False" />
                    </TabControl>
                </tio:GroupBorder>
                <tio:GroupBorder Header="CardTabControl" Padding="15">
                    <TabControl TabStripPlacement="{Binding #place.SelectedValue}" Theme="{StaticResource CardTabControl}">
                        <TabItem Content="Hello 1" Header="Tab 1" />
                        <TabItem Content="Hello 2" Header="Tab 2" />
                        <TabItem Content="Hello 3" Header="Tab 3" />
                        <TabItem Content="中文内容" Header="中文中文" />
                        <TabItem
                            Content="Hello 4"
                            Header="Tab 4"
                            IsEnabled="False" />
                    </TabControl>
                </tio:GroupBorder>
                <tio:GroupBorder Header="ButtonTabControl" Padding="15">
                    <TabControl TabStripPlacement="{Binding #place.SelectedValue}" Theme="{StaticResource ButtonTabControl}">
                        <TabItem Content="Hello 1" Header="Tab 1" />
                        <TabItem Content="Hello 2" Header="Tab 2" />
                        <TabItem Content="Hello 3" Header="Tab 3" />
                        <TabItem Content="中文内容" Header="中文中文" />
                        <TabItem
                            Content="Hello 4"
                            Header="Tab 4"
                            IsEnabled="False" />
                    </TabControl>
                </tio:GroupBorder>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>