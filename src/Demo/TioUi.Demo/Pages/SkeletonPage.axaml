<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.SkeletonPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="Skeleton"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel>
                <ToggleSwitch Content="Loading" Name="loading" />
                <ToggleSwitch Content="Active" Name="active" />
                <Grid
                    ColumnDefinitions="auto,*"
                    HorizontalAlignment="Left"
                    MinWidth="400">
                    <tio:Skeleton
                        CornerRadius="2"
                        Height="100"
                        IsActive="{Binding #active.IsChecked}"
                        IsLoading="{Binding #loading.IsChecked}"
                        VerticalAlignment="Center"
                        Width="100">
                        <Image RenderOptions.BitmapInterpolationMode="HighQuality" Source="/icon.png" />
                    </tio:Skeleton>
                    <UniformGrid
                        Columns="1"
                        Grid.Column="1"
                        Margin="5,0"
                        Rows="3">
                        <tio:Skeleton
                            CornerRadius="2"
                            IsActive="{Binding #active.IsChecked}"
                            IsLoading="{Binding #loading.IsChecked}"
                            Margin="0,0,200,0"
                            VerticalAlignment="Top">
                            <SelectableTextBlock Margin="0,2" Text="是先有鸡还是先有蛋" />
                        </tio:Skeleton>
                        <tio:Skeleton
                            CornerRadius="2"
                            IsActive="{Binding #active.IsChecked}"
                            IsLoading="{Binding #loading.IsChecked}"
                            Margin="0,0,100,0"
                            VerticalAlignment="Center">
                            <SelectableTextBlock Margin="0,2" Text="什么是工匠精神" />
                        </tio:Skeleton>
                        <tio:Skeleton
                            CornerRadius="2"
                            IsActive="{Binding #active.IsChecked}"
                            IsLoading="{Binding #loading.IsChecked}"
                            VerticalAlignment="Bottom">
                            <SelectableTextBlock Margin="0,2" Text="看山不是山，看水不是水，看山还是山，看水还是水" />
                        </tio:Skeleton>
                    </UniformGrid>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>