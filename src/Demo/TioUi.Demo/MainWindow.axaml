<tio:TioWindow
    CanResize="True"
    ExtendClientAreaToDecorationsHint="True"
    Icon="icon.i.ico"
    IsHitTestVisible="True"
    MinHeight="400"
    MinWidth="600"
    Title="TioUi.Demo"
    WindowDecorations="Full"
    WindowStartupLocation="CenterScreen"
    x:Class="TioUi.Demo.MainWindow"
    x:DataType="demo:MainWindowModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:demo="clr-namespace:TioUi.Demo"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:TioWindow.TitleBarLeftContent>
        <StackPanel Name="Left" Orientation="Horizontal">
            <Image
                Margin="-3,0,-12,0"
                Source="{DynamicResource Logo}"
                Width="48" />
            <TextBlock
                FontSize="16"
                Margin="5,0,0,0"
                Text="TioUi.Demo"
                VerticalAlignment="Center" />
        </StackPanel>
    </tio:TioWindow.TitleBarLeftContent>
    <tio:TioWindow.TitleBarRightContent>
        <StackPanel Name="TitleBarContainer" Orientation="Horizontal">
            <Button
                Classes="title-bar-button big-title-bar-icon"
                Content="M495.9 166.6c3.2 8.7 .5 18.4-6.4 24.6l-43.3 39.4c1.1 8.3 1.7 16.8 1.7 25.4s-.6 17.1-1.7 25.4l43.3 39.4c6.9 6.2 9.6 15.9 6.4 24.6c-4.4 11.9-9.7 23.3-15.8 34.3l-4.7 8.1c-6.6 11-14 21.4-22.1 31.2c-5.9 7.2-15.7 9.6-24.5 6.8l-55.7-17.7c-13.4 10.3-28.2 18.9-44 25.4l-12.5 57.1c-2 9.1-9 16.3-18.2 17.8c-13.8 2.3-28 3.5-42.5 3.5s-28.7-1.2-42.5-3.5c-9.2-1.5-16.2-8.7-18.2-17.8l-12.5-57.1c-15.8-6.5-30.6-15.1-44-25.4L83.1 425.9c-8.8 2.8-18.6 .3-24.5-6.8c-8.1-9.8-15.5-20.2-22.1-31.2l-4.7-8.1c-6.1-11-11.4-22.4-15.8-34.3c-3.2-8.7-.5-18.4 6.4-24.6l43.3-39.4C64.6 273.1 64 264.6 64 256s.6-17.1 1.7-25.4L22.4 191.2c-6.9-6.2-9.6-15.9-6.4-24.6c4.4-11.9 9.7-23.3 15.8-34.3l4.7-8.1c6.6-11 14-21.4 22.1-31.2c5.9-7.2 15.7-9.6 24.5-6.8l55.7 17.7c13.4-10.3 28.2-18.9 44-25.4l12.5-57.1c2-9.1 9-16.3 18.2-17.8C227.3 1.2 241.5 0 256 0s28.7 1.2 42.5 3.5c9.2 1.5 16.2 8.7 18.2 17.8l12.5 57.1c15.8 6.5 30.6 15.1 44 25.4l55.7-17.7c8.8-2.8 18.6-.3 24.5 6.8c8.1 9.8 15.5 20.2 22.1 31.2l4.7 8.1c6.1 11 11.4 22.4 15.8 34.3zM256 336a80 80 0 1 0 0-160 80 80 0 1 0 0 160z"
                VerticalAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button.big-title-bar-icon">
                        <Style Selector="^ Path">
                            <Setter Property="Width" Value="13" />
                            <Setter Property="Height" Value="14" />
                        </Style>
                    </Style>
                </Button.Styles>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuItem Header="Themes" InputGesture="Ctrl+Q">
                            <MenuItem
                                Command="{Binding ToggleTheme}"
                                CommandParameter="a"
                                Header="Default" />
                            <MenuItem
                                Command="{Binding ToggleTheme}"
                                CommandParameter="l"
                                Header="Light" />
                            <MenuItem
                                Command="{Binding ToggleTheme}"
                                CommandParameter="d"
                                Header="Dark" />
                        </MenuItem>
                        <MenuItem Header="Language">
                            <MenuItem
                                Command="{Binding ToggleLang}"
                                CommandParameter="c"
                                Header="简体中文" />
                            <MenuItem
                                Command="{Binding ToggleLang}"
                                CommandParameter="e"
                                Header="English" />
                        </MenuItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <Separator
                Background="{DynamicResource ForegroundColor}"
                Foreground="{DynamicResource ForegroundColor}"
                Height="16"
                Margin="5,0,5,0"
                Name="Separator"
                VerticalAlignment="Center"
                Width="1" />
        </StackPanel>
    </tio:TioWindow.TitleBarRightContent>
    <DockPanel>
        <Border
            Background="{DynamicResource PanelBackgroundColor}"
            BorderBrush="{DynamicResource LineColor}"
            BorderThickness="1"
            CornerRadius="{DynamicResource TioCornerRadius}"
            Margin="15,15,-5,15">
            <tio:NavMenu
                Classes="FlatScrollBar"
                DockPanel.Dock="Left"
                EnableSearch="True"
                HeaderBinding="{Binding Title}"
                IconBinding="{Binding Icon}"
                ItemsSource="{Binding Pages}"
                Margin="10,10,4,10"
                SearchPlaceholderText="Search..."
                SearchPlacement="Top"
                SelectedItem="{Binding SelectedPage}"
                SubMenuBinding="{Binding Children}"
                Width="235"
                x:Name="NavMenu">
                <tio:NavMenu.Styles>
                    <Style Selector="tio|NavMenu /template/ ItemsPresenter#PART_ItemsPresenter">
                        <Setter Property="Margin" Value="0,0,6,0" />
                    </Style>
                    <Style Selector="tio|NavMenuItem:first-level">
                        <Setter Property="IsVerticalCollapsed" Value="True" />
                    </Style>
                </tio:NavMenu.Styles>
                <tio:NavMenu.IconTemplate>
                    <DataTemplate DataType="x:String">
                        <PathIcon
                            Data="{Binding}"
                            Height="19"
                            Margin="2,0,-1,0"
                            Width="19" />
                    </DataTemplate>
                </tio:NavMenu.IconTemplate>
                <tio:NavMenu.ItemTemplate>
                    <DataTemplate DataType="demo:Page">
                        <tio:NavMenuItem IsVerticalCollapsed="True" />
                    </DataTemplate>
                </tio:NavMenu.ItemTemplate>
            </tio:NavMenu>
        </Border>
        <ContentControl Content="{Binding SelectedPage.Content}" DockPanel.Dock="Right" />
    </DockPanel>
</tio:TioWindow>