<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.TwoTonePathIconPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="TwoTonePathIcon"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Size" />
                <Slider
                    Maximum="100"
                    Minimum="0"
                    Name="width"
                    Value="20"
                    Width="300" />
                <ToggleSwitch Content="Active" Name="active" />
                <tio:TwoTonePathIcon
                    Data="F1 M448,512z M0,0z M256,32C256,14.3 241.7,0 224,0 206.3,0 192,14.3 192,32L192,242.7 150.6,201.3C138.1,188.8 117.8,188.8 105.3,201.3 92.8,213.8 92.8,234.1 105.3,246.6L201.3,342.6C213.8,355.1,234.1,355.1,246.6,342.6L342.6,246.6C355.1,234.1 355.1,213.8 342.6,201.3 330.1,188.8 309.8,188.8 297.3,201.3L256,242.7 256,32z M64,320C28.7,320,0,348.7,0,384L0,416C0,451.3,28.7,480,64,480L384,480C419.3,480,448,451.3,448,416L448,384C448,348.7,419.3,320,384,320L337.1,320 280.5,376.6C249.3,407.8,198.6,407.8,167.4,376.6L110.9,320 64,320z M368,376A24,24,0,1,1,368,424A24,24,0,1,1,368,376z"
                    Height="{Binding #width.Value}"
                    IsActive="{Binding ElementName=active, Path=IsChecked}"
                    Width="{Binding #width.Value}" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>