<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.TagInputPage"
    x:DataType="pages:TagInputDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:TioUi.Demo.Pages"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="TagInput"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <tio:TagInput
                    AllowDuplicates="True"
                    Name="labels"
                    PlaceholderText="Hello world"
                    Separator="-"
                    Tags="{Binding Tags}" />
                <tio:TagInput
                    AllowDuplicates="False"
                    LostFocusBehavior="Clear"
                    Separator="-"
                    Tags="{Binding DistinctTags}" />
                <ListBox ItemsSource="{Binding DistinctTags}" />
                <tio:TagInput
                    AcceptsReturn="True"
                    AllowDuplicates="False"
                    LostFocusBehavior="Clear"
                    Separator="-"
                    Tags="{Binding DistinctTags}" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>