<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.DatePickerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="DatePicker"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <DatePicker />
                <DatePicker Classes="ClearButton" />
                <DatePicker DayFormat="d (ddd)" YearVisible="False" />
                <DatePicker DayVisible="False" />
                <DatePicker MonthVisible="False" />
                <DatePicker DayVisible="False" MonthVisible="False" />
                <DatePicker DayVisible="False" YearVisible="False" />
                <DatePicker MonthVisible="False" YearVisible="False" />
                <DatePicker IsEnabled="False" />
                <DatePicker Classes="Bordered" />
                <DatePicker Classes="BorderedOnFocus" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>