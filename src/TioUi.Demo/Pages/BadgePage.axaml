<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.BadgePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="Badge"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <tio:EnumSelector EnumType="{x:Type tio:CornerPosition}" Name="position" />
                <tio:Badge
                    CornerPosition="{Binding #position.Value}"
                    Header="Badge Content"
                    Margin="90,0,0,0">
                    <Button Content="Test" />
                </tio:Badge>
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>