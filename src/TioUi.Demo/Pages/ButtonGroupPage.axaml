<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.ButtonGroupPage"
    x:DataType="pages:ButtonGroupPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:TioUi.Demo.Pages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="ButtonGroup"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <tio:ButtonGroup CommandBinding="{Binding InvokeCommand}" ItemsSource="{Binding Items}">
                    <tio:ButtonGroup.ItemTemplate>
                        <DataTemplate x:DataType="pages:ButtonItem">
                            <TextBlock>
                                <Run Text="🐥" />
                                <Run Text="{Binding Name}" />
                            </TextBlock>
                        </DataTemplate>
                    </tio:ButtonGroup.ItemTemplate>
                </tio:ButtonGroup>

                <tio:ButtonGroup
                    CommandBinding="{Binding InvokeCommand}"
                    ContentBinding="{Binding Name}"
                    ItemsSource="{Binding Items}" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>