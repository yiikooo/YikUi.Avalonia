                        <tio:IconButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
                            IsEnabled="False"
                            IsLoading="True" />
                        <tio:IconButton
                            Classes="Float"
                            Content="Float"
                            Icon="{StaticResource Icon}" />
                        <tio:IconButton
                            Classes="Float"
                            Content="FloatLoading"
                            Icon="{StaticResource Icon}"
                            IsLoading="True" />
                    </WrapPanel>
                </StackPanel>
            </tio:GroupBorder>
            <tio:GroupBorder Header="IconDropDownButton">
                <StackPanel>
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
