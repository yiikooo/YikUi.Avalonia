                    </WrapPanel>
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15"
                        Name="DangerIconDropDownButton">
                        <tio:IconDropDownButton Icon="{StaticResource Icon}" />
                        <tio:IconDropDownButton Content="IconDropDownButton" />
                        <tio:IconDropDownButton Content="IconDropDownButton" Icon="{StaticResource Icon}" />
                        <tio:IconDropDownButton
                            Content="Loading"
                            Icon="{StaticResource Icon}"
                            IsLoading="True" />
                        <tio:IconDropDownButton
                            Content="Disabled"
