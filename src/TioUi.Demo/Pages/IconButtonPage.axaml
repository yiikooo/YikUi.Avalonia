                        <tio:IconSplitButton Icon="{StaticResource Icon}" />
                        <tio:IconSplitButton Content="IconSplitButton" />
                        <tio:IconSplitButton Content="IconSplitButton" Icon="{StaticResource Icon}" />
                        <tio:IconSplitButton
                            Content="Loading"
                            Icon="{StaticResource Icon}"
                            IsLoading="True" />
                        <tio:IconSplitButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
                            IsEnabled="False" />
                        <tio:IconSplitButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
                            IsEnabled="False"
                            IsLoading="True" />
                        <tio:IconSplitButton
                            Classes="Float"
                            Content="Float"
                            Icon="{StaticResource Icon}" />
                        <tio:IconSplitButton
                            Classes="Float"
