                        <tio:IconToggleButton Content="IconToggleButton" Icon="{StaticResource Icon}" />
                        <tio:IconToggleButton
                            Content="Loading"
                            Icon="{StaticResource Icon}"
                            IsLoading="True" />
                        <tio:IconToggleButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
                            IsEnabled="False" />
                        <tio:IconToggleButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
                            IsEnabled="False"
                            IsLoading="True" />
                        <tio:IconToggleButton
                            Classes="Float"
                            Content="Float"
