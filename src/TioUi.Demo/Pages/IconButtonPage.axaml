            <tio:GroupBorder Header="IconSplitButton">
                <StackPanel>
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <tio:IconSplitButton Icon="{StaticResource Icon}" />
                        <tio:IconSplitButton Content="IconSplitButton" />
                        <tio:IconSplitButton Content="IconSplitButton" Icon="{StaticResource Icon}" />
                        <tio:IconSplitButton
                            Content="Loading"
                            Icon="{StaticResource Icon}"
                            IsLoading="True" />
                        <tio:IconSplitButton
                            Content="Disabled"
                            Icon="{StaticResource Icon}"
