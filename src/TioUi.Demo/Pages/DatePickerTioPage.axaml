<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.DatePickerTioPage"
    x:DataType="pages:DatePickerDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:TioUi.Demo.Pages"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="DatePicker(tio)"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Spacing="20">
                <TextBox
                    InnerLeftContent="Display Format"
                    Name="format"
                    Text="yyyy-MM-dd" />
                <TextBlock Text="Default" />
                <tio:DatePicker DisplayFormat="{Binding #format.Text}" Width="300" />
                <TextBlock Text="Binding" />
                <tio:DatePicker
                    DisplayFormat="{Binding #format.Text}"
                    SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                    Width="300" />
                <TextBlock Text="Clear Button" />
                <tio:DatePicker
                    Classes="ClearButton"
                    Name="singlePicker"
                    Width="300" />
            </StackPanel>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>