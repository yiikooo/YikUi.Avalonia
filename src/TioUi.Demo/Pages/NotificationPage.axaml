<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.NotificationPage"
    x:DataType="pages:NotificationPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:TioUi.Demo.Pages"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border>
        <ScrollViewer Margin="0,0,5,0">
            <StackPanel Margin="15,15,10,15" Spacing="10">

                <!--  位置调整  -->
                <tio:GroupBorder Header="通知位置">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding SetPositionTopLeft}" Content="左上角 (TopLeft)" />
                        <Button Command="{Binding SetPositionTopCenter}" Content="顶部居中 (TopCenter)" />
                        <Button Command="{Binding SetPositionTopRight}" Content="右上角 (TopRight)" />
                        <Button Command="{Binding SetPositionBottomLeft}" Content="左下角 (BottomLeft)" />
                        <Button Command="{Binding SetPositionBottomCenter}" Content="底部居中 (BottomCenter)" />
                        <Button Command="{Binding SetPositionBottomRight}" Content="右下角 (BottomRight)" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  基础 Notification  -->
                <tio:GroupBorder Header="基础 Notification">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowInformationNotification}" Content="Information" />
                        <Button Command="{Binding ShowSuccessNotification}" Content="Success" />
                        <Button Command="{Binding ShowWarningNotification}" Content="Warning" />
                        <Button Command="{Binding ShowErrorNotification}" Content="Error" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  带标题的 Notification  -->
                <tio:GroupBorder Header="带标题的 Notification">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithTitle}" Content="带标题" />
                        <Button Command="{Binding ShowNotificationWithLongTitle}" Content="长标题" />
                        <Button Command="{Binding ShowNotificationOnlyTitle}" Content="仅标题" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  不同持续时间  -->
                <tio:GroupBorder Header="持续时间">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowShortNotification}" Content="短时间 (1秒)" />
                        <Button Command="{Binding ShowNormalNotification}" Content="正常 (3秒)" />
                        <Button Command="{Binding ShowLongNotification}" Content="长时间 (5秒)" />
                        <Button Command="{Binding ShowPersistentNotification}" Content="持久显示" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  图标显示  -->
                <tio:GroupBorder Header="图标显示">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithIcon}" Content="显示图标" />
                        <Button Command="{Binding ShowNotificationWithoutIcon}" Content="隐藏图标" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  关闭按钮  -->
                <tio:GroupBorder Header="关闭按钮">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithCloseButton}" Content="显示关闭按钮" />
                        <Button Command="{Binding ShowNotificationWithoutCloseButton}" Content="隐藏关闭按钮" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  操作按钮  -->
                <tio:GroupBorder Header="操作按钮">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithSingleButton}" Content="单个操作按钮" />
                        <Button Command="{Binding ShowNotificationWithMultipleButtons}" Content="多个操作按钮" />
                        <Button Command="{Binding ShowNotificationWithInlineButtons}" Content="内联按钮" />
                        <Button Command="{Binding ShowNotificationWithStackedButtons}" Content="堆叠按钮" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  样式  -->
                <tio:GroupBorder Header="样式">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowLightNotification}" Content="Light 样式" />
                        <Button Command="{Binding ShowColorfulNotification}" Content="Colorful 样式" />
                        <Button Command="{Binding ShowDefaultNotification}" Content="默认样式" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  交互事件  -->
                <tio:GroupBorder Header="交互事件">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithClick}" Content="点击事件" />
                        <Button Command="{Binding ShowNotificationWithClose}" Content="关闭事件" />
                        <Button Command="{Binding ShowNotificationWithTouchClose}" Content="点击关闭" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  长文本内容  -->
                <tio:GroupBorder Header="长文本内容">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowLongContentNotification}" Content="长文本" />
                        <Button Command="{Binding ShowMultiLineNotification}" Content="多行文本" />
                        <Button Command="{Binding ShowLongTitleAndContent}" Content="长标题和内容" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  折叠按钮  -->
                <tio:GroupBorder Header="折叠按钮">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowNotificationWithCollapseButton}" Content="显示折叠按钮" />
                        <Button Command="{Binding ShowNotificationWithBothButtons}" Content="折叠和关闭按钮" />
                    </WrapPanel>
                </tio:GroupBorder>

                <!--  综合示例  -->
                <tio:GroupBorder Header="综合示例">
                    <WrapPanel
                        ItemSpacing="15"
                        LineSpacing="15"
                        Margin="15">
                        <Button Command="{Binding ShowComplexNotification}" Content="复杂 Notification" />
                        <Button Command="{Binding ShowCustomNotification}" Content="自定义 Notification" />
                        <Button Command="{Binding ShowMultipleNotifications}" Content="连续显示多个" />
                    </WrapPanel>
                </tio:GroupBorder>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>