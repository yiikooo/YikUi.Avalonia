<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Demo.Pages.PathPickerPage"
    x:DataType="vm:PathPickerDemoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:vm="clr-namespace:TioUi.Demo.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:GroupBorder
        Header="PathPicker"
        Margin="15"
        Padding="15">
        <ScrollViewer>
            <Grid ColumnDefinitions="*,*" RowDefinitions="7*,3*">
                <ScrollViewer Grid.Column="0" Grid.Row="0">
                    <StackPanel>
                        <HeaderedContentControl Content="PathPicker aggregates a file selector and provides a Command property. The Command is triggered solely after opening the file selector and selecting a file, whereupon the Command receives an IReadOnlyList&lt;string&gt; parameter." Header="Functionality and Usage" />
                        <tio:Form
                            HorizontalAlignment="Stretch"
                            LabelAlignment="Left"
                            LabelPosition="Left"
                            LabelWidth="*">
                            <TextBox
                                Name="Title"
                                Text="选择文件"
                                tio:FormItem.Label="Title" />
                            <TextBox
                                Name="SuggestedFileName"
                                PlaceholderText="filename(not have file extension)"
                                tio:FormItem.Label="SuggestedFileName" />
                            <TextBox
                                Name="SuggestedStartPath"
                                PlaceholderText="D:\Win7 Help\win-x64"
                                tio:FormItem.Label="SuggestedStartPath" />
                            <TextBox
                                Name="FileFilter"
                                PlaceholderText="[Name,Pattern] like this [123,*.exe,*.pdb] or [All][ImageAll][11,*.txt]"
                                tio:FormItem.Label="FileFilter" />
                            <TextBox
                                Name="DefaultFileExtension"
                                PlaceholderText="json"
                                tio:FormItem.Label="DefaultFileExtension" />
                            <CheckBox
                                Content="AllowMultiple"
                                Name="AllowMultiple"
                                tio:FormItem.NoLabel="True" />
                            <CheckBox
                                Content="Do not trigger the command after unselecting."
                                Name="IsOmitCommandOnCancel"
                                tio:FormItem.NoLabel="True" />
                            <CheckBox
                                Content="Clear the selection when unselecting."
                                Name="IsClearSelectionOnCancel"
                                tio:FormItem.NoLabel="True" />
                            <tio:EnumSelector
                                EnumType="tio:UsePickerTypes"
                                Name="UsePickerType"
                                tio:FormItem.Label="UsePickerType" />
                            <tio:ControlClassesInput
                                HorizontalAlignment="Left"
                                Name="ClassInput"
                                tio:FormItem.Label="Style Class">
                                <tio:ControlClassesInput.Styles>
                                    <Style Selector="tio|ControlClassesInput /template/ tio|TagInput">
                                        <Setter Property="PlaceholderText" Value="Available: Top" />
                                    </Style>
                                </tio:ControlClassesInput.Styles>
                            </tio:ControlClassesInput>

                        </tio:Form>
                    </StackPanel>
                </ScrollViewer>
                <ScrollViewer Grid.Column="0" Grid.Row="1">
                    <StackPanel Spacing="2">
                        <HeaderedContentControl Header="Default">
                            <tio:PathPicker
                                AllowMultiple="{Binding #AllowMultiple.IsChecked, Mode=TwoWay}"
                                Command="{Binding SelectedCommand}"
                                DefaultFileExtension="{Binding #DefaultFileExtension.Text}"
                                FileFilter="{Binding #FileFilter.Text}"
                                IsClearSelectionOnCancel="{Binding #IsClearSelectionOnCancel.IsChecked}"
                                IsOmitCommandOnCancel="{Binding #IsOmitCommandOnCancel.IsChecked}"
                                SelectedPaths="{Binding Paths, Mode=OneWayToSource}"
                                SelectedPathsText="{Binding Path, Mode=OneWayToSource}"
                                SuggestedFileName="{Binding #SuggestedFileName.Text}"
                                SuggestedStartPath="{Binding #SuggestedStartPath.Text}"
                                Title="{Binding #Title.Text}"
                                UsePickerType="{Binding #UsePickerType.Value}"
                                tio:ControlClassesInput.Source="{Binding #ClassInput}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="ButtonPathPicker">
                            <tio:PathPicker
                                AllowMultiple="{Binding #AllowMultiple.IsChecked}"
                                Command="{Binding SelectedCommand}"
                                DefaultFileExtension="{Binding #DefaultFileExtension.Text}"
                                FileFilter="{Binding #FileFilter.Text}"
                                IsClearSelectionOnCancel="{Binding #IsClearSelectionOnCancel.IsChecked}"
                                IsOmitCommandOnCancel="{Binding #IsOmitCommandOnCancel.IsChecked}"
                                SelectedPaths="{Binding Paths, Mode=OneWayToSource}"
                                SelectedPathsText="{Binding Path, Mode=OneWayToSource}"
                                SuggestedFileName="{Binding #SuggestedFileName.Text}"
                                SuggestedStartPath="{Binding #SuggestedStartPath.Text}"
                                Theme="{DynamicResource ButtonPathPicker}"
                                Title="{Binding #Title.Text}"
                                UsePickerType="{Binding #UsePickerType.Value}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="ListPathPicker">
                            <tio:PathPicker
                                AllowMultiple="{Binding #AllowMultiple.IsChecked}"
                                Command="{Binding SelectedCommand}"
                                DefaultFileExtension="{Binding #DefaultFileExtension.Text}"
                                FileFilter="{Binding #FileFilter.Text}"
                                IsClearSelectionOnCancel="{Binding #IsClearSelectionOnCancel.IsChecked}"
                                IsOmitCommandOnCancel="{Binding #IsOmitCommandOnCancel.IsChecked}"
                                SelectedPaths="{Binding Paths, Mode=OneWayToSource}"
                                SelectedPathsText="{Binding Path, Mode=OneWayToSource}"
                                SuggestedFileName="{Binding #SuggestedFileName.Text}"
                                SuggestedStartPath="{Binding #SuggestedStartPath.Text}"
                                Theme="{DynamicResource ListPathPicker}"
                                Title="{Binding #Title.Text}"
                                UsePickerType="{Binding #UsePickerType.Value}" />
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
                <ScrollViewer
                    Grid.Column="1"
                    Grid.Row="0"
                    Grid.RowSpan="2">
                    <StackPanel Spacing="1">
                        <TextBlock Text="{Binding CommandTriggerCount, StringFormat='Command Trigger Count:{0}'}" />
                        <HeaderedContentControl Header="SelectedPathsText">
                            <TextBox
                                IsReadOnly="True"
                                Name="SelectedPath"
                                Text="{Binding Path}"
                                tio:FormItem.Label="SelectedPath" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="SelectedPaths">
                            <ListBox ItemsSource="{Binding Paths}" Name="SelectedPaths" />
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </ScrollViewer>
    </tio:GroupBorder>
</UserControl>