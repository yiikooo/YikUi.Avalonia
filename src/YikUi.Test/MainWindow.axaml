<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border Margin="30">
        <yik:Breadcrumb>
            <TextBlock Text="Hello" />
            <yik:BreadcrumbItem Content="World" IsReadOnly="True" />
            <yik:BreadcrumbItem Icon="?" Separator="♥" />
            <yik:BreadcrumbItem Content="Avalonia" />
            <yik:BreadcrumbItem Content="Avalonia" />
            <yik:BreadcrumbItem Content="Avalonia" />
        </yik:Breadcrumb>
    </Border>
</yik:YikWindow>