<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:YikWindow.Resources>
        <StreamGeometry x:Key="SemiIconDownload">
            M17.84 8.06A6.5 6.5 0 1 0 5.18 11 4.5 4.5 0 0 0 5.5 20H17a6 6 0 0 0 .84-11.94Zm-6.16 9.67a.5.5 0 0 0 .64 0l5.15-4.29a.25.25 0 0 0-.16-.44H14V9.5a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5V13H6.7c-.24 0-.35.3-.17.44l5.15 4.3Z
        </StreamGeometry>
        <SolidColorBrush
            Color="Red"
            Opacity="0.2"
            x:Key="MaskBackground" />
        <SolidColorBrush Color="Red" x:Key="MaskBorder" />
    </yik:YikWindow.Resources>
    <Border Margin="30">
        <StackPanel HorizontalAlignment="Left">
            <Button Command="{Binding IncreaseCommand}">Change</Button>
            <yik:Int32Displayer Value="{Binding Value}" />
            <yik:Int64Displayer Value="{Binding LongValue}" />
            <yik:DoubleDisplayer StringFormat="N2" Value="{Binding DoubleValue}" />
            <yik:DateDisplay
                FontSize="30"
                StringFormat="yyyy-MM-dd"
                Value="{Binding DateValue}" />
            <TextBlock Text="Selectable: " />
            <yik:Int32Displayer IsSelectable="True" Value="{Binding Value}" />
            <yik:Int64Displayer IsSelectable="True" Value="{Binding LongValue}" />
            <yik:DoubleDisplayer
                IsSelectable="True"
                StringFormat="N2"
                Value="{Binding DoubleValue}" />
            <yik:DateDisplay
                FontSize="30"
                IsSelectable="True"
                StringFormat="yyyy-MM-dd"
                Value="{Binding DateValue}" />
        </StackPanel>
    </Border>
</yik:YikWindow>