<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border Margin="30">
        <StackPanel HorizontalAlignment="Left" Spacing="15">
            <StackPanel Spacing="20">
                <Grid ColumnDefinitions="*, 300">
                    <Grid Grid.Column="0">
                        <StackPanel HorizontalAlignment="Center">
                            <yik:Rating
                                AllowClear="{Binding AllowClear}"
                                AllowHalf="{Binding AllowHalf}"
                                Count="{Binding Count}"
                                DefaultValue="{Binding DefaultValue}"
                                IsEnabled="{Binding IsEnabled}"
                                Value="{Binding Value}" />
                            <yik:Rating
                                AllowClear="{Binding AllowClear}"
                                AllowHalf="{Binding AllowHalf}"
                                Classes="Small"
                                Count="{Binding Count}"
                                DefaultValue="{Binding DefaultValue}"
                                IsEnabled="{Binding IsEnabled}"
                                Value="{Binding Value}" />
                            <yik:Rating
                                AllowClear="{Binding AllowClear}"
                                AllowHalf="{Binding AllowHalf}"
                                Character="{StaticResource SemiIconLikeHeart}"
                                Count="{Binding Count}"
                                DefaultValue="{Binding DefaultValue}"
                                Foreground="Red"
                                IsEnabled="{Binding IsEnabled}"
                                Size="48"
                                Value="{Binding Value}" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Column="1" VerticalAlignment="Top">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="*,*,*,*,*,*,*,*">
                            <Label
                                Content="AllowClear"
                                Grid.Column="0"
                                Grid.Row="0"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Grid.Row="0"
                                IsChecked="{Binding AllowClear}"
                                MinWidth="200" />
                            <Label
                                Content="AllowHalf"
                                Grid.Column="0"
                                Grid.Row="1"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Grid.Row="1"
                                IsChecked="{Binding AllowHalf}"
                                VerticalAlignment="Center" />
                            <Label
                                Content="IsEnabled"
                                Grid.Column="0"
                                Grid.Row="3"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Grid.Row="3"
                                IsChecked="{Binding IsEnabled}"
                                VerticalAlignment="Center" />
                            <Label
                                Content="DefaultValue"
                                Grid.Column="0"
                                Grid.Row="4"
                                VerticalAlignment="Center" />
                            <Label
                                Classes="Large"
                                Content="{Binding DefaultValue}"
                                Grid.Column="1"
                                Grid.Row="4"
                                Theme="{StaticResource TagLabel}"
                                VerticalAlignment="Center" />
                            <Label
                                Content="Value"
                                Grid.Column="0"
                                Grid.Row="5"
                                VerticalAlignment="Center" />
                            <NumericUpDown
                                Grid.Column="1"
                                Grid.Row="5"
                                Increment="0.1"
                                Maximum="100"
                                Minimum="-10"
                                Value="{Binding Value}"
                                VerticalAlignment="Center" />
                            <Label
                                Content="Count"
                                Grid.Column="0"
                                Grid.Row="6"
                                VerticalAlignment="Center" />
                            <NumericUpDown
                                Grid.Column="1"
                                Grid.Row="6"
                                Increment="1"
                                Maximum="100"
                                Minimum="-10"
                                Value="{Binding Count}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</yik:YikWindow>