<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border Margin="30">
        <StackPanel HorizontalAlignment="Left" Spacing="15">
            <yik:Form>
                <yik:PinCode
                    Count="4"
                    Name="v4"
                    yik:FormItem.Label="Regular" />
                <yik:PinCode
                    Count="4"
                    Mode="Digit"
                    yik:FormItem.Label="Digit Only" />
                <yik:PinCode
                    Count="4"
                    Mode="Letter"
                    yik:FormItem.Label="Letter Only" />
                <yik:FormGroup>
                    <yik:PinCode
                        Classes="Small"
                        Count="6"
                        yik:FormItem.Label="Size Small" />
                    <yik:PinCode Count="6" yik:FormItem.Label="Size Default" />
                    <yik:PinCode
                        Classes="Large"
                        Count="6"
                        yik:FormItem.Label="Size Large" />
                </yik:FormGroup>
            </yik:Form>
        </StackPanel>
    </Border>
</yik:YikWindow>