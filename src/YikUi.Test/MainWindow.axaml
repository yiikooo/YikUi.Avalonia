<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <yik:YikWindow.Resources>
        <StreamGeometry x:Key="SemiIconHome">
            M2 11.45a1 1 0 0 1 .33-.75l9-8.1a1 1 0 0 1 1.34 0l9 8.1a1 1 0 0 1 .33.75V20a2 2 0 0 1-2 2h-4a1 1 0 0 1-1-1v-4a3 3 0 0 0-6 0v4a1 1 0 0 1-1 1H4a2 2 0 0 1-2-2v-8.55Z
        </StreamGeometry>
    </yik:YikWindow.Resources>
    <StackPanel>
        <TextBlock Text="Size" />
        <Slider
            Maximum="100"
            Minimum="0"
            Name="width"
            Value="20"
            Width="300" />
        <ToggleSwitch Content="Active" Name="active" />
        <yik:TwoTonePathIcon
            Data="{StaticResource SemiIconHome}"
            Height="{Binding #width.Value}"
            IsActive="{Binding ElementName=active, Path=IsChecked}"
            Width="{Binding #width.Value}" />
    </StackPanel>
</yik:YikWindow>