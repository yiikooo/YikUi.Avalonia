<yik:YikWindow
    Title="YikUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="YikUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:YikUi.Test"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Border Margin="30">
        <StackPanel HorizontalAlignment="Left" Spacing="15">
            <yik:RangeSlider
                HorizontalAlignment="Left"
                Margin="8"
                Name="range"
                TickFrequency="5"
                VerticalAlignment="Top">
                <yik:RangeSlider.Styles>
                    <Style Selector="yik|RangeSlider:horizontal">
                        <Setter Property="Width" Value="400" />
                        <Setter Property="Height" Value="40" />
                    </Style>
                    <Style Selector="yik|RangeSlider:vertical">
                        <Setter Property="Width" Value="40" />
                        <Setter Property="Height" Value="400" />
                    </Style>
                </yik:RangeSlider.Styles>
            </yik:RangeSlider>
        </StackPanel>
    </Border>
</yik:YikWindow>