<tio:TioWindow
    Title="TioUi.Test"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TioUi.Test.MainWindow"
    x:DataType="test:Model"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:test="clr-namespace:TioUi.Test"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <tio:TioWindow.Resources>
        <StreamGeometry x:Key="SemiIconHome">
            M2 11.45a1 1 0 0 1 .33-.75l9-8.1a1 1 0 0 1 1.34 0l9 8.1a1 1 0 0 1 .33.75V20a2 2 0 0 1-2 2h-4a1 1 0 0 1-1-1v-4a3 3 0 0 0-6 0v4a1 1 0 0 1-1 1H4a2 2 0 0 1-2-2v-8.55Z
        </StreamGeometry>
    </tio:TioWindow.Resources>
    <StackPanel Margin="20">
        <ToggleSwitch Content="Smooth" Name="smooth" />
        <tio:Clock
            Grid.Row="1"
            HorizontalAlignment="Left"
            IsSmooth="{Binding #smooth.IsChecked}"
            Time="{Binding Time}" />
    </StackPanel>
</tio:TioWindow>