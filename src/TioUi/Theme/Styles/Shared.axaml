<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="PopupRoot /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="tio|NumericUpDown#PART_QuickJumpInput /template/ TextBox#PART_TextBox /template/ TextPresenter#PART_TextPresenter">
        <Setter Property="Margin" Value="0,0,3,0" />
    </Style>
    <Style Selector="tio|Skeleton[IsActive=True][IsLoading=True] /template/ tio|PureRectangle#PART_ActiveBorder">
        <Style.Animations>
            <Animation
                Duration="0:0:1.4"
                Easing="CubicEaseInOut"
                FillMode="None"
                IterationCount="Infinite"
                PlaybackDirection="Alternate">
                <KeyFrame Cue="0%">
                    <Setter Property="Background" Value="{DynamicResource SkeletonStartAnimationBackground}" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Background" Value="{DynamicResource SkeletonEndAnimationBackground}" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Button.Accent">
        <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
    </Style>
</Styles>