<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="tio|GroupBorder[IsHeaderSelectable=True]">
        <Style Selector="^ TextBlock#Text">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^ SelectableTextBlock#SelectableText">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </Style>
    <Style Selector="tio|GroupBorder[IsHeaderSelectable=False]">
        <Style Selector="^ TextBlock#Text">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^ SelectableTextBlock#SelectableText">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Style>
</Styles>