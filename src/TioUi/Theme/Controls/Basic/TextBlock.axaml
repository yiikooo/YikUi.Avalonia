<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <StackPanel Spacing="20">
            <TextBlock Text="Test" Theme="{StaticResource TitleTextBlock}" />
        </StackPanel>
    </Design.PreviewWith>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush
                Color="#000000"
                Opacity="0.35"
                x:Key="DisabledForegroundColor" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush
                Color="White"
                Opacity="0.35"
                x:Key="DisabledForegroundColor" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="TextBlock" x:Key="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource TioFontFamily}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition
                    Duration="0:0:0.3"
                    Easing="CircularEaseOut"
                    Property="Foreground" />
            </Transitions>
        </Setter>
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        <Style Selector="^.Underline">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="^.Delete">
            <Setter Property="TextDecorations" Value="StrikeThrough" />
        </Style>
        <Style Selector="^.Underline.Delete">
            <Setter Property="TextDecorations">
                <TextDecorationCollection>
                    <TextDecoration Location="Underline" />
                    <TextDecoration Location="Strikethrough" />
                </TextDecorationCollection>
            </Setter>
        </Style>
        <Style Selector="^.H1">
            <Setter Property="FontSize" Value="32" />
        </Style>
        <Style Selector="^.H2">
            <Setter Property="FontSize" Value="28" />
        </Style>
        <Style Selector="^.H3">
            <Setter Property="FontSize" Value="24" />
        </Style>
        <Style Selector="^.H4">
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style Selector="^.H5">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style Selector="^.H6">
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="^.Success">
            <Setter Property="Foreground" Value="#3bb346" />
        </Style>
        <Style Selector="^.Warning">
            <Setter Property="Foreground" Value="#fc8800" />
        </Style>
        <Style Selector="^.Danger">
            <Setter Property="Foreground" Value="#f93920" />
        </Style>
        <Style Selector="^.Accent">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        </Style>
        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>