<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme TargetType="tio:DisableContainer" x:Key="{x:Type tio:DisableContainer}">
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:DisableContainer">
                <Panel>
                    <ContentPresenter Content="{TemplateBinding Content}" />
                    <tio:PureRectangle
                        Background="Transparent"
                        Cursor="No"
                        IsVisible="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content.IsEnabled, Converter={x:Static BoolConverters.Not}}"
                        ToolTip.Tip="{TemplateBinding DisabledTip}" />
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>