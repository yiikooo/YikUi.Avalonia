<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <StackPanel Margin="20">
            <tio:PaginationButton Page="3" />
        </StackPanel>
    </Design.PreviewWith>
    <!--  Shared Resources  -->
    <StreamGeometry x:Key="SemiIconChevronLeft">M16.28 4.24a1.5 1.5 0 0 1 0 2.12l-5.66 5.66 5.66 5.65a1.5 1.5 0 1 1-2.12 2.13l-6.72-6.72a1.5 1.5 0 0 1 0-2.12l6.72-6.72a1.5 1.5 0 0 1 2.12 0Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconChevronRight">M7.44 19.8a1.5 1.5 0 0 1 0-2.13l5.66-5.65-5.66-5.66a1.5 1.5 0 1 1 2.12-2.12l6.72 6.72a1.5 1.5 0 0 1 0 2.12L9.56 19.8a1.5 1.5 0 0 1-2.12 0Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconDoubleChevronLeft">
        M12.62 4.4c.5.53.5 1.38 0 1.91L7.14 12l5.48 5.69c.5.53.5 1.38 0 1.91-.51.53-1.33.53-1.84 0l-6.4-6.64a1.4 1.4 0 0 1 0-1.92l6.4-6.64c.5-.53 1.33-.53 1.84 0Z
        M19.62 4.4c.5.53.5 1.38 0 1.91L14.14 12l5.48 5.69c.5.53.5 1.38 0 1.91-.51.53-1.34.53-1.84 0l-6.4-6.64a1.4 1.4 0 0 1 0-1.92l6.4-6.64c.5-.53 1.33-.53 1.84 0Z
    </StreamGeometry>
    <StreamGeometry x:Key="SemiIconDoubleChevronRight">
        M4.38 4.4c.51-.53 1.34-.53 1.84 0l6.4 6.64c.5.53.5 1.39 0 1.92l-6.4 6.64c-.5.53-1.33.53-1.84 0a1.4 1.4 0 0 1 0-1.91L9.86 12 4.38 6.31a1.4 1.4 0 0 1 0-1.91Z
        M11.38 4.4c.51-.53 1.33-.53 1.84 0l6.4 6.64c.5.53.5 1.39 0 1.92l-6.4 6.64c-.5.53-1.33.53-1.84 0a1.4 1.4 0 0 1 0-1.91L16.86 12l-5.48-5.69a1.4 1.4 0 0 1 0-1.91Z
    </StreamGeometry>
    <StreamGeometry x:Key="SemiIconMore">M6.5 12a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm6 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm6 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z</StreamGeometry>

    <StaticResource ResourceKey="SemiIconChevronLeft" x:Key="PaginationBackwardGlyph" />
    <StaticResource ResourceKey="SemiIconChevronRight" x:Key="PaginationForwardGlyph" />
    <StaticResource ResourceKey="SemiIconDoubleChevronLeft" x:Key="PaginationFastBackwardGlyph" />
    <StaticResource ResourceKey="SemiIconDoubleChevronRight" x:Key="PaginationFastForwardGlyph" />
    <StaticResource ResourceKey="SemiIconMore" x:Key="PaginationMoreGlyph" />

    <x:String x:Key="STRING_PAGINATION_JUMP_TO">跳至</x:String>
    <x:String x:Key="STRING_PAGINATION_PAGE">页</x:String>

    <FontWeight x:Key="TextBlockTitleFontWeight">600</FontWeight>

    <ControlTheme TargetType="PathIcon" x:Key="InnerPathIcon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="PathIcon">
                <Border Background="{TemplateBinding Background}">
                    <Viewbox Height="{TemplateBinding Height}" Width="{TemplateBinding Width}">
                        <Path
                            Data="{TemplateBinding Data}"
                            Fill="{TemplateBinding Foreground}"
                            Height="24"
                            Name="PART_Path"
                            Width="24" />
                    </Viewbox>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
    <ResourceDictionary.ThemeDictionaries>

        <!--  Light Theme Resources  -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="Transparent" x:Key="PaginationButtonDefaultBackground" />
            <SolidColorBrush Color="#333333" x:Key="PaginationButtonDefaultForeground" />
            <SolidColorBrush Color="#999999" x:Key="PaginationButtonIconForeground" />
            <SolidColorBrush Color="#F5F5F5" x:Key="PaginationButtonPointeroverBackground" />
            <SolidColorBrush Color="#E8E8E8" x:Key="PaginationButtonPressedBackground" />
            <SolidColorBrush
                Color="{DynamicResource SystemAccentColor}"
                Opacity="0.7"
                x:Key="PaginationButtonSelectedBackground" />
            <SolidColorBrush Color="#FFFFFF" x:Key="PaginationButtonSelectedForeground" />
        </ResourceDictionary>

        <!--  Dark Theme Resources  -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="Transparent" x:Key="PaginationButtonDefaultBackground" />
            <SolidColorBrush Color="#FFFFFF" x:Key="PaginationButtonDefaultForeground" />
            <SolidColorBrush Color="#999999" x:Key="PaginationButtonIconForeground" />
            <SolidColorBrush Color="#262626" x:Key="PaginationButtonPointeroverBackground" />
            <SolidColorBrush Color="#1F1F1F" x:Key="PaginationButtonPressedBackground" />
            <SolidColorBrush
                Color="{DynamicResource SystemAccentColor}"
                Opacity="0.7"
                x:Key="PaginationButtonSelectedBackground" />
            <SolidColorBrush Color="#FFFFFF" x:Key="PaginationButtonSelectedForeground" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="tio:Pagination" x:Key="{x:Type tio:Pagination}">
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:Pagination">
                <StackPanel Orientation="Horizontal">
                    <tio:PaginationButton Name="{x:Static tio:Pagination.PART_PreviousButton}" tio:DisabledAdorner.IsEnabled="True">
                        <PathIcon
                            Data="{DynamicResource PaginationBackwardGlyph}"
                            Foreground="{DynamicResource PaginationButtonIconForeground}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </tio:PaginationButton>
                    <StackPanel Name="{x:Static tio:Pagination.PART_ButtonPanel}" Orientation="Horizontal" />
                    <tio:PaginationButton Name="{x:Static tio:Pagination.PART_NextButton}" tio:DisabledAdorner.IsEnabled="True">
                        <PathIcon
                            Data="{DynamicResource PaginationForwardGlyph}"
                            Foreground="{DynamicResource PaginationButtonIconForeground}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </tio:PaginationButton>
                    <StackPanel IsVisible="{TemplateBinding ShowQuickJump}" Orientation="Horizontal">
                        <TextBlock
                            Margin="4,0"
                            Text="{DynamicResource Lang.JumpTo}"
                            VerticalAlignment="Center" />
                        <tio:NumericIntUpDown
                            ShowButtonSpinner="False"
                            Width="50"
                            x:Name="{x:Static tio:Pagination.PART_QuickJumpInput}" />
                        <TextBlock
                            Margin="4,0"
                            Text="{DynamicResource Lang.Page}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox
                        IsVisible="{TemplateBinding ShowPageSizeSelector}"
                        ItemsSource="{TemplateBinding PageSizeOptions}"
                        SelectedItem="{TemplateBinding PageSize,
                                                       Mode=TwoWay}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="{x:Type tio:Pagination}" x:Key="TinyPagination">
        <Setter Property="DisplayCurrentPageInQuickJumper" Value="True" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:Pagination">
                <StackPanel Orientation="Horizontal">
                    <tio:PaginationButton Name="{x:Static tio:Pagination.PART_PreviousButton}" tio:DisabledAdorner.IsEnabled="True">
                        <PathIcon
                            Data="{DynamicResource PaginationBackwardGlyph}"
                            Foreground="{DynamicResource PaginationButtonIconForeground}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </tio:PaginationButton>
                    <Grid ColumnDefinitions="*, Auto, *" Margin="5,0">
                        <tio:NumericIntUpDown
                            Grid.Column="0"
                            HorizontalContentAlignment="Center"
                            IsVisible="True"
                            MinWidth="{Binding $self.Bounds.Height}"
                            Name="{x:Static tio:Pagination.PART_QuickJumpInput}"
                            ShowButtonSpinner="False"
                            Value="{TemplateBinding CurrentPage,
                                                    Mode=TwoWay}"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="0"
                            IsVisible="False"
                            Name="PART_PageTextBlock"
                            Text="{TemplateBinding CurrentPage}"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0"
                            Text="/"
                            VerticalAlignment="Center" />
                        <SelectableTextBlock
                            Grid.Column="2"
                            Text="{TemplateBinding PageCount}"
                            VerticalAlignment="Center" />
                    </Grid>
                    <tio:PaginationButton Name="{x:Static tio:Pagination.PART_NextButton}" tio:DisabledAdorner.IsEnabled="True">
                        <PathIcon
                            Data="{DynamicResource PaginationForwardGlyph}"
                            Foreground="{DynamicResource PaginationButtonIconForeground}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </tio:PaginationButton>
                </StackPanel>
            </ControlTemplate>
        </Setter>
        <Style Selector="^.ReadOnly /template/ TextBlock#PART_PageTextBlock">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^.ReadOnly /template/ tio|NumericUpDown#PART_QuickJumpInput">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="tio:PaginationButton" x:Key="{x:Type tio:PaginationButton}">
        <Setter Property="Content" Value="{Binding $self.Page}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{DynamicResource PaginationButtonDefaultBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource PaginationButtonDefaultForeground}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:PaginationButton">
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="4">
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        FontWeight="{TemplateBinding FontWeight}"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="Center"
                        RecognizesAccessKey="True"
                        VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultPointeroverBackground}" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultPressedBackground}" />
        </Style>
        <Style Selector="^:left">
            <Setter Property="Content">
                <Template>
                    <PathIcon
                        Data="{DynamicResource PaginationMoreGlyph}"
                        Foreground="{DynamicResource InnerForegroundColor}"
                        Theme="{StaticResource InnerPathIcon}" />
                </Template>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Content">
                    <Template>
                        <PathIcon
                            Data="{DynamicResource PaginationFastBackwardGlyph}"
                            Foreground="{DynamicResource InnerForegroundColor}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </Template>
                </Setter>
            </Style>
        </Style>
        <Style Selector="^:right">
            <Setter Property="Content">
                <Template>
                    <PathIcon
                        Data="{DynamicResource PaginationMoreGlyph}"
                        Foreground="{DynamicResource InnerForegroundColor}"
                        Theme="{StaticResource InnerPathIcon}" />
                </Template>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Content">
                    <Template>
                        <PathIcon
                            Data="{DynamicResource PaginationFastForwardGlyph}"
                            Foreground="{DynamicResource InnerForegroundColor}"
                            Theme="{StaticResource InnerPathIcon}" />
                    </Template>
                </Setter>
            </Style>
        </Style>
        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource PaginationButtonSelectedBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PaginationButtonSelectedForeground}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextBlockTitleFontWeight}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>