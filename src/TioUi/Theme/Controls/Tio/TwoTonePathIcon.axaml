<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight3}" x:Key="TwoTonePathIconForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark1}" x:Key="TwoTonePathIconStrokeBrush" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="TwoTonePathIconActiveForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="TwoTonePathIconActiveStrokeBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight3}" x:Key="TwoTonePathIconForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark1}" x:Key="TwoTonePathIconStrokeBrush" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="TwoTonePathIconActiveForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="TwoTonePathIconActiveStrokeBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    <ControlTheme TargetType="tio:TwoTonePathIcon" x:Key="{x:Type tio:TwoTonePathIcon}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="{DynamicResource IconElementThemeHeight}" />
        <Setter Property="Width" Value="{DynamicResource IconElementThemeWidth}" />
        <Setter Property="StrokeThickness" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource TwoTonePathIconForeground}" />
        <Setter Property="StrokeBrush" Value="{DynamicResource TwoTonePathIconStrokeBrush}" />
        <Setter Property="ActiveForeground" Value="{DynamicResource TwoTonePathIconActiveForeground}" />
        <Setter Property="ActiveStrokeBrush" Value="{DynamicResource TwoTonePathIconActiveStrokeBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:TwoTonePathIcon">
                <Border Background="{TemplateBinding Background}">
                    <Panel>
                        <Viewbox Height="{TemplateBinding Height}" Width="{TemplateBinding Width}">
                            <Path
                                Data="{TemplateBinding Data}"
                                Fill="{TemplateBinding Foreground}"
                                Margin="5"
                                Name="PART_Fill"
                                Stretch="Uniform"
                                Stroke="{TemplateBinding StrokeBrush}"
                                StrokeJoin="Round"
                                StrokeThickness="{TemplateBinding StrokeThickness}" />
                        </Viewbox>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:active /template/ Path#PART_Fill">
            <Setter Property="Fill" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ActiveForeground}" />
            <Setter Property="Stroke" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ActiveStrokeBrush}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>