<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ControlTheme TargetType="tio:OverlayDialogHost" x:Key="{x:Type tio:OverlayDialogHost}">
        <Setter Property="OverlayMaskBrush" Value="{DynamicResource OverlayDialogMaskBrush}" />
    </ControlTheme>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="White" x:Key="SemiColorBackground2" />
            <SolidColorBrush
                Color="#16161A"
                Opacity="0.6"
                x:Key="SemiColorOverlayBackground" />
            <SolidColorBrush Color="#0062D6" x:Key="SemiBlue6" />
            <SolidColorBrush Color="#D52515" x:Key="SemiRed6" />
            <SolidColorBrush Color="#D26700" x:Key="SemiOrange6" />
            <SolidColorBrush Color="#30953B" x:Key="SemiGreen6" />
            <SolidColorBrush Color="#F2F3F5" x:Key="WindowDefaultBackground" />
            <SolidColorBrush Color="#16161A" x:Key="WindowDefaultForeground" />
            <SolidColorBrush Color="#FFFFFF" x:Key="BorderCardBackground" />
            <StaticResource ResourceKey="SemiColorOverlayBackground" x:Key="OverlayDialogMaskBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="#35363C" x:Key="SemiColorBackground2" />
            <SolidColorBrush
                Color="#16161A"
                Opacity="0.6"
                x:Key="SemiColorOverlayBackground" />
            <SolidColorBrush Color="#7FC1FF" x:Key="SemiBlue6" />
            <SolidColorBrush Color="#FD9983" x:Key="SemiRed6" />
            <SolidColorBrush Color="#FFC772" x:Key="SemiOrange6" />
            <SolidColorBrush Color="#7FD184" x:Key="SemiGreen6" />
            <SolidColorBrush Color="#16161A" x:Key="WindowDefaultBackground" />
            <SolidColorBrush Color="#F2F3F5" x:Key="WindowDefaultForeground" />
            <SolidColorBrush Color="#242529" x:Key="BorderCardBackground" />
            <StaticResource ResourceKey="SemiColorOverlayBackground" x:Key="OverlayDialogMaskBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="DialogMinWidth">48</x:Double>
    <x:Double x:Key="DialogMinHeight">48</x:Double>
    <CornerRadius x:Key="DialogCornerRadius">12</CornerRadius>
    <x:Double x:Key="DefaultFontSize">14</x:Double>
    <FontWeight x:Key="TextBlockTitleFontWeight">600</FontWeight>
    <StreamGeometry x:Key="DialogArrangeBringForwardGlyph">M2,2H16V16H2V2M22,8V22H8V18H10V20H20V10H18V8H22Z</StreamGeometry>
    <StreamGeometry x:Key="DialogArrangeBringToFrontGlyph">M2,2H11V6H9V4H4V9H6V11H2V2M22,13V22H13V18H15V20H20V15H18V13H22M8,8H16V16H8V8Z</StreamGeometry>
    <StreamGeometry x:Key="DialogArrangeSendBackwardGlyph">M2,2H16V16H2V2M22,8V22H8V18H18V8H22M4,4V14H14V4H4Z</StreamGeometry>
    <StreamGeometry x:Key="DialogArrangeSendToBackGlyph">M2,2H11V11H2V2M9,4H4V9H9V4M22,13V22H13V13H22M15,20H20V15H15V20M16,8V11H13V8H16M11,16H8V13H11V16Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconClose">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</StreamGeometry>
    <StaticResource ResourceKey="SemiIconInfoCircle" x:Key="DialogInformationIconGlyph" />
    <StaticResource ResourceKey="SemiIconAlertCircle" x:Key="DialogErrorIconGlyph" />
    <StaticResource ResourceKey="SemiIconAlertTriangle" x:Key="DialogWarningIconGlyph" />
    <StaticResource ResourceKey="SemiIconHelpCircle" x:Key="DialogQuestionIconGlyph" />
    <StaticResource ResourceKey="SemiIconTickCircle" x:Key="DialogSuccessIconGlyph" />

    <ControlTheme TargetType="tio:CustomDialogControl" x:Key="{x:Type tio:CustomDialogControl}">
        <Setter Property="MinWidth" Value="{DynamicResource DialogMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource DialogMinHeight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource DialogCornerRadius}" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Duration="0.2" Property="RenderTransform" />
            </Transitions>
        </Setter>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="RenderTransform" Value="scale(1.0)" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:CustomDialogControl">
                <Panel>
                    <Border
                        Background="{DynamicResource PopupBackgroundColor}"
                        BorderBrush="{DynamicResource PopupBorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="False"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Focusable="True"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        IsHitTestVisible="True"
                        Name="PART_Border"
                        Padding="0"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                        <Border ClipToBounds="True" CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid RowDefinitions="Auto, *">
                                <ScrollViewer
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    HorizontalScrollBarVisibility="{Binding (ScrollViewer.HorizontalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}"
                                    VerticalScrollBarVisibility="{Binding (ScrollViewer.VerticalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}">
                                    <ContentPresenter Content="{TemplateBinding Content}" Name="PART_ContentPresenter" />
                                </ScrollViewer>
                                <Grid ColumnDefinitions="*, Auto" Grid.Row="0">
                                    <Panel
                                        Background="Transparent"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Name="{x:Static tio:DialogControlBase.PART_TitleArea}" />
                                    <Button
                                        DockPanel.Dock="Right"
                                        Grid.Column="1"
                                        Margin="0,24,24,0"
                                        Name="{x:Static tio:MessageBoxWindow.PART_CloseButton}"
                                        Theme="{DynamicResource OverlayCloseButton}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Border>
                    <tio:DialogResizer IsVisible="{TemplateBinding CanResize}" Margin="{Binding #PART_Border.Margin}" />
                </Panel>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:full-screen">
            <Setter Property="CornerRadius" Value="0" />
            <Style Selector="^ /template/ Border#PART_Border">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Theme" Value="{x:Null}" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Background" Value="{DynamicResource BorderCardBackground}" />
            </Style>
        </Style>
        <Style Selector="^ /template/ Panel#PART_TitleArea">
            <Setter Property="ContextFlyout">
                <MenuFlyout>
                    <MenuItem Command="{Binding $parent[tio:DialogControlBase].Close}" Header="{DynamicResource Lang.Close}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource SemiIconClose}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuFlyout>
            </Setter>
        </Style>
        <Style Selector="^:not(:modal) /template/ Panel#PART_TitleArea">
            <Setter Property="ContextFlyout">
                <MenuFlyout>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.BringForward}"
                        Header="{DynamicResource Lang.BringForward}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeBringForwardGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.BringToFront}"
                        Header="{DynamicResource Lang.BringToFront}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeBringToFrontGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.SendBackward}"
                        Header="{DynamicResource Lang.SendBackward}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeSendBackwardGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.SendToBack}"
                        Header="{DynamicResource Lang.SendToBack}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeSendToBackGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Command="{Binding $parent[tio:DialogControlBase].Close}" Header="{DynamicResource Lang.Close}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource SemiIconClose}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuFlyout>
            </Setter>
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="tio:DefaultDialogControl" x:Key="{x:Type tio:DefaultDialogControl}">
        <Setter Property="MinWidth" Value="{DynamicResource DialogMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource DialogMinHeight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource DialogCornerRadius}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Duration="0.2" Property="RenderTransform" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:DefaultDialogControl">
                <Panel>
                    <Border
                        Background="{DynamicResource PopupBackgroundColor}"
                        BorderBrush="{DynamicResource PopupBorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="False"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Focusable="True"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        IsHitTestVisible="True"
                        Name="PART_Border"
                        Padding="0"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                        <Border ClipToBounds="True" CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <ScrollViewer
                                    Grid.Row="1"
                                    HorizontalScrollBarVisibility="{Binding (ScrollViewer.HorizontalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}"
                                    VerticalScrollBarVisibility="{Binding (ScrollViewer.VerticalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}">
                                    <ContentPresenter
                                        Content="{TemplateBinding Content}"
                                        Margin="24,8"
                                        Name="PART_ContentPresenter" />
                                </ScrollViewer>
                                <Grid
                                    ColumnDefinitions="Auto, *, Auto"
                                    Grid.Row="0"
                                    Name="PART_Header">
                                    <Panel
                                        Background="Transparent"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Name="{x:Static tio:DialogControlBase.PART_TitleArea}" />
                                    <PathIcon
                                        Classes="ExtraLarge"
                                        Grid.Column="0"
                                        Margin="24,24,8,0"
                                        Name="PART_Icon"
                                        Theme="{StaticResource InnerPathIcon}"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="{DynamicResource TextBlockTitleFontWeight}"
                                        Grid.Column="1"
                                        IsHitTestVisible="False"
                                        IsVisible="{TemplateBinding Title,
                                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Margin="0,24,0,0"
                                        Name="PART_Title"
                                        Text="{TemplateBinding Title}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center" />
                                    <Button
                                        DockPanel.Dock="Right"
                                        Grid.Column="2"
                                        Margin="0,24,24,0"
                                        Name="{x:Static tio:MessageBoxWindow.PART_CloseButton}"
                                        Theme="{DynamicResource OverlayCloseButton}" />
                                </Grid>
                                <Grid
                                    ColumnDefinitions="Auto, Auto, Auto, Auto"
                                    Grid.Row="2"
                                    HorizontalAlignment="Right"
                                    Margin="24,0,24,24"
                                    Name="PART_Footer">
                                    <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_CancelButton}" />
                                    <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_NoButton}" />
                                    <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_YesButton}" />
                                    <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_OKButton}" />
                                </Grid>

                            </Grid>
                        </Border>
                    </Border>
                    <tio:DialogResizer IsVisible="{TemplateBinding CanResize}" Margin="{Binding #PART_Border.Margin}" />
                </Panel>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:full-screen">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="^:full-screen /template/ Border#PART_Border">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BorderCardBackground}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_CancelButton">
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Cancel}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_NoButton">
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            <Setter Property="Content" Value="{DynamicResource Lang.No}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_YesButton">
            <Setter Property="Grid.Column" Value="2" />
            <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Yes}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_OKButton">
            <Setter Property="Grid.Column" Value="3" />
            <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Ok}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^[Mode=None]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ /template/ TextBlock#PART_Title">
                <Setter Property="Margin" Value="24 24 0 0" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Info]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogInformationIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiBlue6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Warning]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogWarningIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiOrange6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Warning" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Warning" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Error]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogErrorIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiRed6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Question]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogQuestionIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiBlue6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Success]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogSuccessIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiGreen6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Success" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Success" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^ /template/ Panel#PART_TitleArea">
            <Setter Property="ContextFlyout">
                <MenuFlyout>
                    <MenuItem Command="{Binding $parent[tio:DialogControlBase].Close}" Header="{DynamicResource Lang.Close}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource SemiIconClose}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuFlyout>
            </Setter>
        </Style>
        <Style Selector="^:not(:modal) /template/ Panel#PART_TitleArea">
            <Setter Property="ContextFlyout">
                <MenuFlyout>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.BringForward}"
                        Header="{DynamicResource Lang.BringForward}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeBringForwardGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.BringToFront}"
                        Header="{DynamicResource Lang.BringToFront}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeBringToFrontGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.SendBackward}"
                        Header="{DynamicResource Lang.SendBackward}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeSendBackwardGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].UpdateLayer}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.SendToBack}"
                        Header="{DynamicResource Lang.SendToBack}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource DialogArrangeSendToBackGlyph}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding $parent[tio:DialogControlBase].Close}"
                        CommandParameter="{x:Static tio:DialogLayerChangeType.BringForward}"
                        Header="{DynamicResource Lang.Close}">
                        <MenuItem.Icon>
                            <PathIcon Data="{DynamicResource SemiIconClose}" Theme="{StaticResource InnerPathIcon}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuFlyout>
            </Setter>
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="tio:DialogWindow" x:Key="{x:Type tio:DialogWindow}">
        <Setter Property="Title" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource PopupBackgroundColor}" />
        <Setter Property="TransparencyBackgroundFallback" Value="{DynamicResource PopupBackgroundColor}" />
        <Setter Property="Foreground" Value="{DynamicResource WindowDefaultForeground}" />
        <Setter Property="FontSize" Value="{DynamicResource DefaultFontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource TioFontFamily}" />
        <Setter Property="Padding" Value="48 24" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="WindowStartupLocation" Value="CenterOwner" />
        <Setter Property="ExtendClientAreaTitleBarHeightHint" Value="1" />
        <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />

        <Setter Property="MinWidth" Value="{DynamicResource DialogMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource DialogMinHeight}" />
        <Setter Property="WindowDecorations">
            <OnPlatform>
                <OnPlatform.Windows>
                    <WindowDecorations>Full</WindowDecorations>
                </OnPlatform.Windows>
                <OnPlatform.Default>
                    <WindowDecorations>BorderOnly</WindowDecorations>
                </OnPlatform.Default>
            </OnPlatform>
        </Setter>
        <Setter Property="CanResize" Value="False" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:DialogWindow">
                <Panel>
                    <Border IsHitTestVisible="False" Name="PART_TransparencyFallback" />
                    <Border
                        Background="{TemplateBinding Background}"
                        BackgroundSizing="InnerBorderEdge"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        IsHitTestVisible="False" />
                    <Panel Background="Transparent" Margin="{TemplateBinding WindowDecorationMargin}" />
                    <VisualLayerManager>
                        <Grid RowDefinitions="Auto, *">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Grid.Row="0"
                                Grid.RowSpan="2" />
                            <Grid ColumnDefinitions="*, Auto" Grid.Row="0">
                                <Panel
                                    Background="Transparent"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Name="{x:Static tio:DialogWindow.PART_TitleArea}" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="{DynamicResource TextBlockTitleFontWeight}"
                                    Grid.Column="0"
                                    Margin="24,24,0,0"
                                    Text="{TemplateBinding Title}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <Button
                                    Grid.Column="1"
                                    Margin="0,24,24,0"
                                    Name="{x:Static tio:MessageBoxWindow.PART_CloseButton}"
                                    Theme="{DynamicResource CloseButton}" />
                            </Grid>

                        </Grid>
                    </VisualLayerManager>
                    <tio:WindowResizer IsVisible="{TemplateBinding IsManagedResizerVisible}" />
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="tio:DefaultDialogWindow" x:Key="{x:Type tio:DefaultDialogWindow}">
        <Setter Property="Title" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource PopupBackgroundColor}" />
        <Setter Property="TransparencyBackgroundFallback" Value="{DynamicResource PopupBackgroundColor}" />
        <Setter Property="Foreground" Value="{DynamicResource WindowDefaultForeground}" />
        <Setter Property="FontSize" Value="{DynamicResource DefaultFontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource TioFontFamily}" />
        <Setter Property="Padding" Value="48 24" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="WindowStartupLocation" Value="CenterOwner" />
        <Setter Property="ExtendClientAreaTitleBarHeightHint" Value="1" />
        <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />

        <Setter Property="MinWidth" Value="{DynamicResource DialogMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource DialogMinHeight}" />
        <Setter Property="WindowDecorations">
            <OnPlatform>
                <OnPlatform.Windows>
                    <WindowDecorations>Full</WindowDecorations>
                </OnPlatform.Windows>
                <OnPlatform.Default>
                    <WindowDecorations>BorderOnly</WindowDecorations>
                </OnPlatform.Default>
            </OnPlatform>
        </Setter>
        <Setter Property="CanResize" Value="False" />
        <Setter Property="Template">
            <ControlTemplate TargetType="tio:DefaultDialogWindow">
                <Panel>
                    <Border IsHitTestVisible="False" Name="PART_TransparencyFallback" />
                    <Border
                        Background="{TemplateBinding Background}"
                        BackgroundSizing="InnerBorderEdge"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        IsHitTestVisible="False" />
                    <Panel Background="Transparent" Margin="{TemplateBinding WindowDecorationMargin}" />
                    <VisualLayerManager>
                        <Grid RowDefinitions="Auto, *, Auto">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Grid.Row="1"
                                Margin="24,8"
                                Name="PART_ContentPresenter" />
                            <Grid
                                ColumnDefinitions="Auto, *, Auto"
                                Grid.Row="0"
                                Name="PART_Header">
                                <Panel
                                    Background="Transparent"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Name="{x:Static tio:DialogWindow.PART_TitleArea}" />
                                <PathIcon
                                    Classes="ExtraLarge"
                                    Grid.Column="0"
                                    Margin="24,24,8,0"
                                    Name="PART_Icon"
                                    Theme="{StaticResource InnerPathIcon}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="{DynamicResource TextBlockTitleFontWeight}"
                                    Grid.Column="1"
                                    IsHitTestVisible="False"
                                    IsVisible="{TemplateBinding Title,
                                                                Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Margin="0,24,0,0"
                                    Name="PART_Title"
                                    Text="{TemplateBinding Title}"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />
                                <Button
                                    DockPanel.Dock="Right"
                                    Grid.Column="2"
                                    Margin="0,24,24,0"
                                    Name="{x:Static tio:MessageBoxWindow.PART_CloseButton}"
                                    Theme="{DynamicResource CloseButton}" />
                            </Grid>
                            <StackPanel
                                Grid.Row="2"
                                HorizontalAlignment="Right"
                                Margin="24,0,24,24"
                                Name="PART_Footer"
                                Orientation="Horizontal">
                                <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_CancelButton}" />
                                <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_NoButton}" />
                                <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_YesButton}" />
                                <Button Margin="8,0,0,0" Name="{x:Static tio:DefaultDialogControl.PART_OKButton}" />
                            </StackPanel>

                        </Grid>
                    </VisualLayerManager>
                    <tio:WindowResizer IsVisible="{TemplateBinding IsManagedResizerVisible}" />
                </Panel>
            </ControlTemplate>
        </Setter>
        <Style Selector="^ /template/ Button#PART_CancelButton">
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Cancel}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_NoButton">
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            <Setter Property="Content" Value="{DynamicResource Lang.No}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_YesButton">
            <Setter Property="Grid.Column" Value="2" />
            <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Yes}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^ /template/ Button#PART_OKButton">
            <Setter Property="Grid.Column" Value="3" />
            <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            <Setter Property="Content" Value="{DynamicResource Lang.Ok}" />
            <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
        </Style>
        <Style Selector="^[Mode=None]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ /template/ TextBlock#PART_Title">
                <Setter Property="Margin" Value="24 24 0 0" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Info]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogInformationIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiBlue6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Warning]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogWarningIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiOrange6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Warning" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Warning" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
                <Setter Property="Theme" Value="{DynamicResource SolidButton}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Error]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogErrorIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiRed6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Question]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogQuestionIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiBlue6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Primary" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
        <Style Selector="^[Mode=Success]">
            <Style Selector="^ /template/ PathIcon#PART_Icon">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Data" Value="{DynamicResource DialogSuccessIconGlyph}" />
                <Setter Property="Foreground" Value="{DynamicResource SemiGreen6}" />
            </Style>
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Success" />
            </Style>
            <Style Selector="^ /template/ Button#PART_YesButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Success" />
            </Style>
            <Style Selector="^ /template/ Button#PART_NoButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Danger" />
            </Style>
            <Style Selector="^ /template/ Button#PART_CancelButton">
                <Setter Property="tio:ClassHelper.Classes" Value="Tertiary" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>