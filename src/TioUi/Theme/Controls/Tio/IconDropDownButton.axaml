<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <tio:BooleansToOpacityConverter x:Key="OpacityConverter" />

    <ControlTemplate TargetType="ContentControl" x:Key="IconDropDownButtonTemplate">
        <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}"
            Name="PART_Background"
            Padding="{TemplateBinding Padding}">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <ReversibleStackPanel
                    Grid.Column="0"
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    Name="{x:Static tio:IconButton.PART_RootPanel}"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                    <Panel Name="PART_IconRoot">
                        <Panel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="(tio:IconButton.IsLoading)" RelativeSource="{RelativeSource TemplatedParent}" />
                                <Binding
                                    Converter="{x:Static ObjectConverters.IsNotNull}"
                                    Path="(tio:IconButton.Icon)"
                                    RelativeSource="{RelativeSource TemplatedParent}" />
                            </MultiBinding>
                        </Panel.IsVisible>
                        <ContentPresenter
                            Content="{TemplateBinding (tio:IconButton.Icon)}"
                            ContentTemplate="{TemplateBinding (tio:IconButton.IconTemplate)}"
                            Foreground="{Binding #PART_ContentPresenter.Foreground}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Opacity="{Binding !(tio:IconButton.IsLoading), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource OpacityConverter}}"
                            RecognizesAccessKey="True">
                            <ContentPresenter.Styles>
                                <Style Selector="PathIcon">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
                                </Style>
                                <Style Selector="tio|IconDropDownButton.Danger PathIcon">
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </ContentPresenter.Styles>
                            <ContentPresenter.DataTemplates>
                                <DataTemplate DataType="Geometry">
                                    <PathIcon
                                        Data="{Binding}"
                                        Height="16"
                                        Width="16" />
                                </DataTemplate>
                            </ContentPresenter.DataTemplates>
                        </ContentPresenter>
                        <tio:LoadingIcon
                            Classes="Small"
                            Foreground="{Binding #PART_ContentPresenter.Foreground}"
                            IsLoading="{TemplateBinding (tio:IconButton.IsLoading)}"
                            IsVisible="{TemplateBinding (tio:IconButton.IsLoading)}" />
                    </Panel>
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        IsVisible="{TemplateBinding Content,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Name="PART_ContentPresenter"
                        RecognizesAccessKey="True"
                        TextElement.FontSize="{TemplateBinding FontSize}"
                        TextElement.FontWeight="{TemplateBinding FontWeight}"
                        UseLayoutRounding="False"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ReversibleStackPanel>
                <PathIcon
                    Data="{DynamicResource DropDownButtonIconGlyph}"
                    Foreground="{Binding #PART_ContentPresenter.Foreground}"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    IsHitTestVisible="False"
                    Name="DropDownGlyph"
                    UseLayoutRounding="False"
                    Width="12" />
            </Grid>
        </Border>
    </ControlTemplate>

    <ControlTheme
        BasedOn="{StaticResource BaseIconButton}"
        TargetType="tio:IconDropDownButton"
        x:Key="{x:Type tio:IconDropDownButton}">
        <Setter Property="Template" Value="{StaticResource IconDropDownButtonTemplate}" />
        <Style Selector="^:empty-content">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="{DynamicResource ButtonDefaultPadding}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>