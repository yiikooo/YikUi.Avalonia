<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="using:Avalonia.Controls.Converters"
    xmlns:converters1="clr-namespace:Avalonia.Controls.Primitives.Converters;assembly=Avalonia.Controls.ColorPicker"
    xmlns:globalization="clr-namespace:System.Globalization;assembly=System.Runtime"
    xmlns:tio="https://github.com/yiikooo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <converters:CornerRadiusFilterConverter Filter="TopLeft, BottomLeft" x:Key="LeftCornerRadiusFilterConverter" />
    <converters:ToBrushConverter x:Key="ToBrushConverter" />

    <Thickness x:Key="ColorViewRadioButtonPadding">16 4</Thickness>
    <x:Double x:Key="ColorViewNumericUpDownWidth">70</x:Double>
    <x:Double x:Key="ColorPreviewerAccentSectionWidth">80</x:Double>
    <x:Double x:Key="ColorPreviewerAccentSectionHeight">20</x:Double>
    <x:Double x:Key="ColorPreviewerHeight">48</x:Double>
    <PlacementMode x:Key="ColorPickerFlyoutPlacement">AnchorAndGravity</PlacementMode>
    <PlacementMode x:Key="SimpleColorPickerFlyoutPlacement">BottomEdgeAlignedLeft</PlacementMode>
    <FontWeight x:Key="ColorViewRadioButtonFontWeight">600</FontWeight>
    <CornerRadius x:Key="ColorPickerCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="ColorPreviewerCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="ColorSpectrumCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="ColorSliderCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="ColorSliderThumbCornerRadius">9999</CornerRadius>
    <x:Double x:Key="ColorPickerMinHeight">32</x:Double>
    <x:Double x:Key="SemiWidthIconMedium">16</x:Double>

    <converters1:ContrastBrushConverter x:Key="ContrastBrushConverter" />
    <converters:ColorToDisplayNameConverter x:Key="ColorToDisplayNameConverter" />
    <converters:ColorToHexConverter x:Key="ColorToHexConverter" />
    <converters:DoNothingForNullConverter x:Key="DoNothingForNullConverter" />
    <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    <tio:HsvColorToTextConverter x:Key="HsvColorToTextConverter" />
    <tio:ColorToTextConverter x:Key="ColorToTextConverter" />
    <tio:ToColorModel x:Key="ToColorModel" />
    <globalization:NumberFormatInfo NumberDecimalDigits="0" x:Key="ColorViewComponentNumberFormat" />

    <!--  Icon Glyphs  -->
    <StreamGeometry x:Key="ColorViewSpectrumIconGlyph">M1.22 20.77a4.24 4.24 0 0 1 .02-5.98l9.33-9.28-.94-.95a1.41 1.41 0 0 1 0-1.99 1.39 1.39 0 0 1 1.97 0l.95.97L14.9 1.2a4.16 4.16 0 0 1 5.89.02 4.24 4.24 0 0 1-.02 5.98l-2.3 2.28 1.02 1.02c.54.55.54 1.44 0 1.99-.55.55-1.43.55-1.97 0l-1.03-1.03-9.37 9.32a4.16 4.16 0 0 1-5.89-.02ZM12.54 7.49l1.97 1.99-9.35 9.3c-.55.55-1.42.55-1.97 0a1.41 1.41 0 0 1 .01-2l9.34-9.29Z</StreamGeometry>
    <StreamGeometry x:Key="ColorViewPaletteIconGlyph">M2 4c0-1.1.9-2 2-2h5a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4Zm6 13.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm11.59-8.91L16.4 5.4a2 2 0 0 0-2.82 0L13 6v12l6.59-6.59a2 2 0 0 0 0-2.82ZM22 16a2 2 0 0 0-2-2l-8 8h8a2 2 0 0 0 2-2v-4Z</StreamGeometry>
    <StreamGeometry x:Key="ColorViewComponentsIconGlyph">M4 6.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM9.5 3a1.5 1.5 0 1 0 0 3h11a1.5 1.5 0 0 0 0-3h-11ZM8 11.5c0-.83.67-1.5 1.5-1.5h11a1.5 1.5 0 0 1 0 3h-11A1.5 1.5 0 0 1 8 11.5Zm0 7c0-.83.67-1.5 1.5-1.5h11a1.5 1.5 0 0 1 0 3h-11A1.5 1.5 0 0 1 8 18.5Zm-2-7a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm-2 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z</StreamGeometry>

    <!--  Checkered Background Brush  -->
    <VisualBrush
        DestinationRect="0,0,8,8"
        Stretch="Uniform"
        TileMode="Tile"
        x:Key="ColorControlCheckeredBackgroundBrush">
        <VisualBrush.Visual>
            <Image Height="8" Width="8">
                <Image.Source>
                    <DrawingImage>
                        <DrawingImage.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="Transparent" Geometry="M0,0 L2,0 2,2, 0,2Z" />
                                <GeometryDrawing Brush="#19808080" Geometry="M0,1 L2,1 2,2, 1,2 1,0 0,0Z" />
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                </Image.Source>
            </Image>
        </VisualBrush.Visual>
    </VisualBrush>

    <!--  Theme-specific resources  -->
    <ResourceDictionary.ThemeDictionaries>
        <!--  Light Theme  -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonForeground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="ColorViewRadioButtonPointeroverBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.13"
                x:Key="ColorViewRadioButtonPressedBackground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonCheckedForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonCheckedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark1}" x:Key="ColorViewRadioButtonCheckedPointeroverBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark1}" x:Key="ColorViewRadioButtonCheckedPressedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewTabItemSelectedForeground" />
            <SolidColorBrush Color="Black" x:Key="ColorSliderDefaultBorderBrush" />
            <SolidColorBrush Color="White" x:Key="ColorSliderLightBorderBrush" />
            <SolidColorBrush Color="Black" x:Key="ColorSliderDarkBorderBrush" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.08"
                x:Key="ColorSpectrumBorderBrush" />
            <BoxShadows x:Key="ColorPreviewerMainBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows>
            <BoxShadows x:Key="ColorSliderBoxShadow">0 0 2 1 #FFFFFF</BoxShadows>
        </ResourceDictionary>

        <!--  Dark Theme  -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonForeground" />
            <SolidColorBrush Color="#16161A" x:Key="ColorViewRadioButtonBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.16"
                x:Key="ColorViewRadioButtonPointeroverBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.20"
                x:Key="ColorViewRadioButtonPressedBackground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonCheckedForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonCheckedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight1}" x:Key="ColorViewRadioButtonCheckedPointeroverBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight1}" x:Key="ColorViewRadioButtonCheckedPressedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewTabItemSelectedForeground" />
            <SolidColorBrush Color="Black" x:Key="ColorSliderDefaultBorderBrush" />
            <SolidColorBrush Color="White" x:Key="ColorSliderLightBorderBrush" />
            <SolidColorBrush Color="Black" x:Key="ColorSliderDarkBorderBrush" />
            <SolidColorBrush
                Color="White"
                Opacity="0.08"
                x:Key="ColorSpectrumBorderBrush" />
            <BoxShadows x:Key="ColorPreviewerMainBoxShadow">inset 0 0 0 1 #1AFFFFFF, 0 4 14 #40000000</BoxShadows>
            <BoxShadows x:Key="ColorSliderBoxShadow">0 0 2 1 #FFFFFF</BoxShadows>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="ColorPicker" x:Key="{x:Type ColorPicker}">
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="{DynamicResource ColorPickerMinHeight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource ColorPickerCornerRadius}" />
        <Setter Property="Content">
            <Template>
                <Panel>
                    <Border
                        Background="{DynamicResource ColorControlCheckeredBackgroundBrush}"
                        CornerRadius="8,6,6,8"
                        Margin="2,2,0,2" />
                    <Border
                        Background="{TemplateBinding HsvColor,
                                                     Converter={StaticResource ToBrushConverter}}"
                        CornerRadius="8,6,6,8"
                        Margin="2,2,0,2" />
                </Panel>
            </Template>
        </Setter>
        <Setter Property="Palette">
            <FluentColorPalette />
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ColorPicker}">
                <DropDownButton
                    ClipToBounds="True"
                    Content="{TemplateBinding Content}"
                    ContentTemplate="{TemplateBinding ContentTemplate}"
                    CornerRadius="{DynamicResource TioCornerRadius}"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Height="{TemplateBinding Height}"
                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                    MinHeight="{TemplateBinding MinHeight}"
                    MinWidth="{TemplateBinding MinWidth}"
                    UseLayoutRounding="False"
                    VerticalAlignment="{TemplateBinding VerticalAlignment}"
                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                    Width="{TemplateBinding Width}">
                    <DropDownButton.Styles>
                        <Style Selector="FlyoutPresenter.nopadding">
                            <Setter Property="Padding" Value="0" />
                        </Style>
                        <Style Selector="PathIcon#DropDownGlyph">
                            <Setter Property="Margin" Value="3,0,0,0" />
                        </Style>
                    </DropDownButton.Styles>
                    <DropDownButton.Flyout>
                        <Flyout FlyoutPresenterClasses="nopadding" Placement="{DynamicResource ColorPickerFlyoutPlacement}">
                            <Grid
                                Height="300"
                                Name="RootGrid"
                                RowDefinitions="*,Auto"
                                Width="300">
                                <Border
                                    Background="Transparent"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Height="{TemplateBinding Height}"
                                    HorizontalAlignment="Stretch"
                                    Name="ContentBackgroundBorder"
                                    VerticalAlignment="Stretch" />

                                <TabControl
                                    Grid.Row="0"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,2,0,0"
                                    Name="PART_TabControl"
                                    Padding="0"
                                    SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    VerticalAlignment="Stretch">
                                    <TabControl.Styles>
                                        <Style Selector="TabItem">
                                            <Setter Property="MinHeight" Value="32" />
                                        </Style>
                                        <Style Selector="TabItem:selected">
                                            <Setter Property="Foreground" Value="{DynamicResource ColorViewTabItemSelectedForeground}" />
                                        </Style>
                                    </TabControl.Styles>
                                    <TabControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="0" Rows="1" />
                                        </ItemsPanelTemplate>
                                    </TabControl.ItemsPanel>
                                    <!--  Spectrum Tab  -->
                                    <TabItem IsVisible="{TemplateBinding IsColorSpectrumVisible}">
                                        <TabItem.Header>
                                            <PathIcon
                                                Data="{DynamicResource ColorViewSpectrumIconGlyph}"
                                                Foreground="{Binding $parent[TabItem].Foreground}"
                                                Theme="{StaticResource InnerPathIcon}"
                                                Width="18" />
                                        </TabItem.Header>
                                        <Grid Margin="12" RowDefinitions="*">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition MinWidth="32" Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition MinWidth="32" Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ColorSlider
                                                AutomationProperties.Name="Third Component"
                                                ColorComponent="{Binding ThirdComponent, ElementName=ColorSpectrum}"
                                                ColorModel="Hsva"
                                                Grid.Column="0"
                                                HorizontalAlignment="Center"
                                                HsvColor="{Binding HsvColor, ElementName=ColorSpectrum}"
                                                IsAlphaVisible="True"
                                                IsPerceptive="False"
                                                IsVisible="{TemplateBinding IsColorSpectrumSliderVisible}"
                                                Margin="0,0,12,0"
                                                Name="ColorSpectrumThirdComponentSlider"
                                                Orientation="Vertical"
                                                VerticalAlignment="Stretch" />
                                            <ColorSpectrum
                                                Components="{TemplateBinding ColorSpectrumComponents}"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                MaxHue="{TemplateBinding MaxHue}"
                                                MaxSaturation="{TemplateBinding MaxSaturation}"
                                                MaxValue="{TemplateBinding MaxValue}"
                                                MinHue="{TemplateBinding MinHue}"
                                                MinSaturation="{TemplateBinding MinSaturation}"
                                                MinValue="{TemplateBinding MinValue}"
                                                Name="ColorSpectrum"
                                                Shape="{TemplateBinding ColorSpectrumShape}"
                                                VerticalAlignment="Stretch" />
                                            <ColorSlider
                                                AutomationProperties.Name="Alpha Component"
                                                ColorComponent="Alpha"
                                                ColorModel="Hsva"
                                                Grid.Column="2"
                                                HorizontalAlignment="Center"
                                                HsvColor="{Binding HsvColor, ElementName=ColorSpectrum}"
                                                IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                                Margin="12,0,0,0"
                                                Name="ColorSpectrumAlphaSlider"
                                                Orientation="Vertical"
                                                VerticalAlignment="Stretch">
                                                <ColorSlider.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="IsAlphaVisible" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    </MultiBinding>
                                                </ColorSlider.IsVisible>
                                            </ColorSlider>
                                        </Grid>
                                    </TabItem>
                                    <!--  Palette Tab  -->
                                    <TabItem IsVisible="{TemplateBinding IsColorPaletteVisible}">
                                        <TabItem.Header>
                                            <PathIcon
                                                Data="{DynamicResource ColorViewPaletteIconGlyph}"
                                                Foreground="{Binding $parent[TabItem].Foreground}"
                                                Theme="{StaticResource InnerPathIcon}"
                                                Width="18" />
                                        </TabItem.Header>
                                        <ListBox
                                            ItemContainerTheme="{DynamicResource ColorViewPaletteListBoxItemTheme}"
                                            ItemsSource="{TemplateBinding PaletteColors}"
                                            Margin="12"
                                            SelectedItem="{Binding Color, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DoNothingForNullConverter}, Mode=TwoWay}"
                                            Theme="{DynamicResource ColorViewPaletteListBoxTheme}"
                                            UseLayoutRounding="False"
                                            VerticalAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type Color}">
                                                    <Border
                                                        AutomationProperties.Name="{Binding Converter={StaticResource ColorToDisplayNameConverter}}"
                                                        HorizontalAlignment="Stretch"
                                                        ToolTip.Tip="{Binding Converter={StaticResource ColorToDisplayNameConverter}}"
                                                        VerticalAlignment="Stretch">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding}" />
                                                        </Border.Background>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="{Binding $parent[ColorView].PaletteColumnCount}" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                    </TabItem>
                                    <!--  Components Tab  -->
                                    <TabItem IsVisible="{TemplateBinding IsColorComponentsVisible}">
                                        <TabItem.Header>
                                            <PathIcon
                                                Data="{DynamicResource ColorViewComponentsIconGlyph}"
                                                Foreground="{Binding $parent[TabItem].Foreground}"
                                                Theme="{StaticResource InnerPathIcon}"
                                                Width="18" />
                                        </TabItem.Header>
                                        <Grid
                                            ColumnDefinitions="Auto,*"
                                            Margin="12"
                                            RowDefinitions="Auto,24,*,*,*,*,12"
                                            Tag="{TemplateBinding ColorModel}">
                                            <Grid.Styles>
                                                <Style Selector="NumericUpDown">
                                                    <Setter Property="InnerLeftContent">
                                                        <Template>
                                                            <TextBlock Text="{Binding $parent[NumericUpDown].Tag}" Width="12" />
                                                        </Template>
                                                    </Setter>
                                                </Style>
                                                <Style Selector="Grid[Tag=Rgba]">
                                                    <Style Selector="^ NumericUpDown#Component1NumericUpDown">
                                                        <Setter Property="Tag" Value="R" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#Component2NumericUpDown">
                                                        <Setter Property="Tag" Value="G" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#Component3NumericUpDown">
                                                        <Setter Property="Tag" Value="B" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#AlphaComponentNumericUpDown">
                                                        <Setter Property="Tag" Value="A" />
                                                    </Style>
                                                </Style>
                                                <Style Selector="Grid[Tag=Hsva]">
                                                    <Style Selector="^ NumericUpDown#Component1NumericUpDown">
                                                        <Setter Property="Tag" Value="H" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#Component2NumericUpDown">
                                                        <Setter Property="Tag" Value="S" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#Component3NumericUpDown">
                                                        <Setter Property="Tag" Value="V" />
                                                    </Style>
                                                    <Style Selector="^ NumericUpDown#AlphaComponentNumericUpDown">
                                                        <Setter Property="Tag" Value="A" />
                                                    </Style>
                                                </Style>
                                            </Grid.Styles>
                                            <!--  Top color model & Hex input  -->
                                            <Grid
                                                ColumnDefinitions="*,12,*"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Grid.Row="0">
                                                <!--  RadioButtonGroup  -->
                                                <Border CornerRadius="3" Padding="2">
                                                    <Border IsVisible="{TemplateBinding IsColorModelVisible}" Theme="{StaticResource RadioButtonGroupBorder}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <RadioButton
                                                                Content="RGB"
                                                                IsChecked="{TemplateBinding ColorModel,
                                                                                            Converter={StaticResource EnumToBoolConverter},
                                                                                            ConverterParameter={x:Static ColorModel.Rgba},
                                                                                            Mode=TwoWay}"
                                                                Name="RgbRadioButton"
                                                                Theme="{DynamicResource ButtonRadioButton}" />
                                                            <RadioButton
                                                                Content="HSV"
                                                                IsChecked="{TemplateBinding ColorModel,
                                                                                            Converter={StaticResource EnumToBoolConverter},
                                                                                            ConverterParameter={x:Static ColorModel.Hsva},
                                                                                            Mode=TwoWay}"
                                                                Name="HsvRadioButton"
                                                                Theme="{DynamicResource ButtonRadioButton}" />
                                                        </StackPanel>
                                                    </Border>
                                                </Border>
                                                <TextBox
                                                    AutomationProperties.Name="Hexadecimal Color"
                                                    FontSize="12"
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Stretch"
                                                    InnerLeftContent="#"
                                                    IsVisible="{TemplateBinding IsHexInputVisible}"
                                                    MaxLength="8"
                                                    Name="PART_HexTextBox" />
                                            </Grid>
                                            <!--  Color component editing controls  -->
                                            <!--  Component 1 RGB:Red HSV:Hue  -->
                                            <NumericUpDown
                                                AllowSpin="True"
                                                Classes="Small"
                                                Grid.Column="0"
                                                Grid.Row="2"
                                                IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                                Margin="0,0,12,0"
                                                Maximum="{Binding Maximum, ElementName=Component1Slider}"
                                                Minimum="{Binding Minimum, ElementName=Component1Slider}"
                                                Name="Component1NumericUpDown"
                                                NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                                ShowButtonSpinner="False"
                                                Value="{Binding Value, ElementName=Component1Slider}"
                                                VerticalAlignment="Center"
                                                Width="{DynamicResource ColorViewNumericUpDownWidth}" />
                                            <ColorSlider
                                                ColorComponent="Component1"
                                                ColorModel="{TemplateBinding ColorModel,
                                                                             Mode=OneWay}"
                                                Grid.Column="1"
                                                Grid.Row="2"
                                                HorizontalAlignment="Stretch"
                                                HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                IsRoundingEnabled="True"
                                                IsSnapToTickEnabled="True"
                                                IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                                Name="Component1Slider"
                                                Orientation="Horizontal"
                                                TickFrequency="1"
                                                VerticalAlignment="Center" />
                                            <!--  Component 2 RGB:Green HSV:Saturation  -->
                                            <NumericUpDown
                                                AllowSpin="True"
                                                Classes="Small"
                                                Grid.Column="0"
                                                Grid.Row="3"
                                                IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                                Margin="0,0,12,0"
                                                Maximum="{Binding Maximum, ElementName=Component2Slider}"
                                                Minimum="{Binding Minimum, ElementName=Component2Slider}"
                                                Name="Component2NumericUpDown"
                                                NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                                ShowButtonSpinner="False"
                                                Value="{Binding Value, ElementName=Component2Slider}"
                                                VerticalAlignment="Center"
                                                Width="{DynamicResource ColorViewNumericUpDownWidth}" />
                                            <ColorSlider
                                                ColorComponent="Component2"
                                                ColorModel="{TemplateBinding ColorModel,
                                                                             Mode=OneWay}"
                                                Grid.Column="1"
                                                Grid.Row="3"
                                                HorizontalAlignment="Stretch"
                                                HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                IsRoundingEnabled="True"
                                                IsSnapToTickEnabled="True"
                                                IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                                Name="Component2Slider"
                                                Orientation="Horizontal"
                                                TickFrequency="1"
                                                VerticalAlignment="Center" />
                                            <!--  Component 3 RGB:Blue HSV:Value  -->
                                            <NumericUpDown
                                                AllowSpin="True"
                                                Classes="Small"
                                                Grid.Column="0"
                                                Grid.Row="4"
                                                IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                                Margin="0,0,12,0"
                                                Maximum="{Binding Maximum, ElementName=Component3Slider}"
                                                Minimum="{Binding Minimum, ElementName=Component3Slider}"
                                                Name="Component3NumericUpDown"
                                                NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                                ShowButtonSpinner="False"
                                                Value="{Binding Value, ElementName=Component3Slider}"
                                                VerticalAlignment="Center"
                                                Width="{DynamicResource ColorViewNumericUpDownWidth}" />
                                            <ColorSlider
                                                ColorComponent="Component3"
                                                ColorModel="{TemplateBinding ColorModel,
                                                                             Mode=OneWay}"
                                                Grid.Column="1"
                                                Grid.Row="4"
                                                HorizontalAlignment="Stretch"
                                                HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                IsRoundingEnabled="True"
                                                IsSnapToTickEnabled="True"
                                                IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                                Name="Component3Slider"
                                                Orientation="Horizontal"
                                                TickFrequency="1"
                                                VerticalAlignment="Center" />
                                            <!--  Alpha Component  -->
                                            <NumericUpDown
                                                AllowSpin="True"
                                                Classes="Small"
                                                Grid.Column="0"
                                                Grid.Row="5"
                                                IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                                Margin="0,0,12,0"
                                                Maximum="{Binding Maximum, ElementName=AlphaComponentSlider}"
                                                Minimum="{Binding Minimum, ElementName=AlphaComponentSlider}"
                                                Name="AlphaComponentNumericUpDown"
                                                NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                                ShowButtonSpinner="False"
                                                Value="{Binding Value, ElementName=AlphaComponentSlider}"
                                                VerticalAlignment="Center"
                                                Width="{DynamicResource ColorViewNumericUpDownWidth}">
                                                <NumericUpDown.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="IsAlphaVisible" RelativeSource="{RelativeSource TemplatedParent}" />
                                                        <Binding Path="IsComponentTextInputVisible" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    </MultiBinding>
                                                </NumericUpDown.IsVisible>
                                            </NumericUpDown>
                                            <ColorSlider
                                                ColorComponent="Alpha"
                                                ColorModel="{TemplateBinding ColorModel,
                                                                             Mode=OneWay}"
                                                Grid.Column="1"
                                                Grid.Row="5"
                                                HorizontalAlignment="Stretch"
                                                HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                                IsRoundingEnabled="True"
                                                IsSnapToTickEnabled="True"
                                                Name="AlphaComponentSlider"
                                                Orientation="Horizontal"
                                                TickFrequency="1"
                                                VerticalAlignment="Center">
                                                <ColorSlider.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="IsAlphaVisible" RelativeSource="{RelativeSource TemplatedParent}" />
                                                        <Binding Path="IsComponentSliderVisible" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    </MultiBinding>
                                                </ColorSlider.IsVisible>
                                            </ColorSlider>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                                <!--  Previewer  -->
                                <!--  Note that top/bottom margins have -5 to remove for drop shadow padding  -->
                                <ColorPreviewer
                                    Grid.Row="1"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    IsAccentColorsVisible="{TemplateBinding IsAccentColorsVisible}"
                                    IsVisible="{TemplateBinding IsColorPreviewVisible}"
                                    Margin="12,-5,12,7" />
                            </Grid>
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ DropDownButton">
            <Setter Property="Padding" Value="0 0 10 0" />
        </Style>
    </ControlTheme>

    <ControlTheme
        BasedOn="{StaticResource {x:Type ColorPicker}}"
        TargetType="ColorPicker"
        x:Key="HexColorPicker">
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Content">
            <Template>
                <Grid ColumnDefinitions="Auto, *">
                    <Border
                        Background="{DynamicResource ColorControlCheckeredBackgroundBrush}"
                        CornerRadius="8,6,6,8"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Margin="2,2,0,2"
                        VerticalAlignment="Stretch"
                        Width="{Binding $self.Bounds.Height}" />
                    <Border
                        Background="{TemplateBinding HsvColor,
                                                     Converter={StaticResource ToBrushConverter}}"
                        CornerRadius="8,6,6,8"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Margin="2,2,0,2"
                        VerticalAlignment="Stretch"
                        Width="{Binding $self.Bounds.Height}" />
                    <TextBlock
                        FontWeight="Regular"
                        Foreground="{DynamicResource ForegroundColor}"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Margin="8,0,0,0"
                        Text="{Binding $parent[ColorPicker].Color}"
                        VerticalAlignment="Center" />
                </Grid>
            </Template>
        </Setter>
    </ControlTheme>

    <ControlTheme
        BasedOn="{StaticResource {x:Type ColorPicker}}"
        TargetType="ColorPicker"
        x:Key="SimpleColorPicker">
        <Setter Property="ColorSpectrumComponents" Value="SaturationValue" />
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ColorPicker}">
                <DropDownButton
                    Content="{TemplateBinding Content}"
                    ContentTemplate="{TemplateBinding ContentTemplate}"
                    CornerRadius="{DynamicResource TioCornerRadius}"
                    Foreground="{DynamicResource InnerForegroundColor}"
                    Height="{TemplateBinding Height}"
                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                    MinHeight="{TemplateBinding MinHeight}"
                    MinWidth="{TemplateBinding MinWidth}"
                    UseLayoutRounding="False"
                    VerticalAlignment="{TemplateBinding VerticalAlignment}"
                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                    Width="{TemplateBinding Width}">
                    <DropDownButton.Styles>
                        <Style Selector="FlyoutPresenter.padding">
                            <Setter Property="Padding" Value="15" />
                        </Style>
                    </DropDownButton.Styles>
                    <DropDownButton.Flyout>
                        <Flyout FlyoutPresenterClasses="padding" Placement="{DynamicResource SimpleColorPickerFlyoutPlacement}">

                            <!--
                                The following is copy-pasted from the ColorView's control template.
                                It MUST always be kept in sync with the ColorView (which is master).
                                Note the only changes are resources specific to the ColorPicker.
                            -->
                            <Grid Width="280">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" MinHeight="280" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!--  Spectrum Tab  -->
                                <Border
                                    ClipToBounds="True"
                                    CornerRadius="8 8 0 0"
                                    Grid.Row="0">
                                    <ColorSpectrum
                                        Components="{TemplateBinding ColorSpectrumComponents}"
                                        HorizontalAlignment="Stretch"
                                        HsvColor="{TemplateBinding HsvColor,
                                                                   Mode=TwoWay}"
                                        MaxHue="{TemplateBinding MaxHue}"
                                        MaxSaturation="{TemplateBinding MaxSaturation}"
                                        MaxValue="{TemplateBinding MaxValue}"
                                        MinHue="{TemplateBinding MinHue}"
                                        MinSaturation="{TemplateBinding MinSaturation}"
                                        MinValue="{TemplateBinding MinValue}"
                                        Name="ColorSpectrum"
                                        Shape="{TemplateBinding ColorSpectrumShape}"
                                        VerticalAlignment="Stretch" />
                                </Border>
                                <ColorSlider
                                    AutomationProperties.Name="Third Component"
                                    ColorComponent="{Binding #ColorSpectrum.ThirdComponent}"
                                    ColorModel="Hsva"
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{TemplateBinding HsvColor,
                                                               Mode=TwoWay}"
                                    IsVisible="{TemplateBinding IsColorSpectrumSliderVisible}"
                                    Name="ColorSpectrumThirdComponentSlider"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center" />

                                <ColorSlider
                                    AutomationProperties.Name="Alpha Component"
                                    ColorComponent="Alpha"
                                    ColorModel="Hsva"
                                    Grid.Row="2"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{TemplateBinding HsvColor,
                                                               Mode=TwoWay}"
                                    IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                    IsRoundingEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    IsVisible="{TemplateBinding IsAlphaVisible}"
                                    Name="ColorSpectrumAlphaSlider"
                                    Orientation="Horizontal"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                                <StackPanel
                                    Grid.Row="3"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    Spacing="3"
                                    VerticalAlignment="Center">
                                    <Border
                                        Background="{TemplateBinding Color,
                                                                     Converter={StaticResource ToBrushConverter}}"
                                        CornerRadius="4"
                                        Height="20"
                                        Width="20" />
                                    <Panel
                                        HorizontalAlignment="Stretch"
                                        Name="PART_TextBoxPanel"
                                        VerticalAlignment="Center"
                                        Width="106">
                                        <TextBox
                                            Classes="Small"
                                            FontSize="12"
                                            InnerLeftContent="#"
                                            IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Hex}"
                                            MaxLength="8"
                                            Name="PART_HexTextBox"
                                            Text="{TemplateBinding Color,
                                                                   Converter={StaticResource ColorToHexConverter},
                                                                   Mode=TwoWay}" />
                                        <TextBox
                                            Classes="Small"
                                            FontSize="12"
                                            IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Rgba}"
                                            Name="PART_RgbaTextBox"
                                            Text="{TemplateBinding Color,
                                                                   Converter={StaticResource ColorToTextConverter},
                                                                   Mode=TwoWay}" />
                                        <TextBox
                                            Classes="Small"
                                            FontSize="12"
                                            IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Hsva}"
                                            Name="PART_HsvaTextBox"
                                            Text="{TemplateBinding HsvColor,
                                                                   Converter={StaticResource HsvColorToTextConverter},
                                                                   Mode=TwoWay}" />
                                    </Panel>

                                    <NumericUpDown
                                        AllowSpin="True"
                                        Classes="Small"
                                        HorizontalAlignment="Right"
                                        InnerRightContent="%"
                                        IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                        IsVisible="{TemplateBinding IsAlphaVisible}"
                                        Maximum="{Binding #ColorSpectrumAlphaSlider.Maximum}"
                                        Minimum="{Binding #ColorSpectrumAlphaSlider.Minimum}"
                                        Name="AlphaComponentNumericUpDown"
                                        NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                        ShowButtonSpinner="False"
                                        Value="{Binding #ColorSpectrumAlphaSlider.Value}"
                                        VerticalAlignment="Center"
                                        Width="65" />
                                    <ComboBox
                                        Classes="Small"
                                        Name="ColorModelComboBox"
                                        SelectedIndex="0"
                                        VerticalAlignment="Center"
                                        Width="80">
                                        Hex
                                        <ColorModel>Rgba</ColorModel>
                                        <ColorModel>Hsva</ColorModel>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[IsAlphaVisible=False] /template/ Panel#PART_TextBoxPanel">
            <Setter Property="Width" Value="176" />
        </Style>
    </ControlTheme>

    <ControlTheme
        BasedOn="{StaticResource SimpleColorPicker}"
        TargetType="ColorPicker"
        x:Key="HexSimpleColorPicker">
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Content">
            <Template>
                <Grid ColumnDefinitions="Auto, *">
                    <Border
                        Background="{DynamicResource ColorControlCheckeredBackgroundBrush}"
                        CornerRadius="8,6,6,8"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Margin="2,2,0,2"
                        VerticalAlignment="Stretch"
                        Width="{Binding $self.Bounds.Height}" />
                    <Border
                        Background="{TemplateBinding HsvColor,
                                                     Converter={StaticResource ToBrushConverter}}"
                        CornerRadius="8,6,6,8"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Margin="2,2,0,2"
                        VerticalAlignment="Stretch"
                        Width="{Binding $self.Bounds.Height}" />
                    <TextBlock
                        FontWeight="Regular"
                        Foreground="{DynamicResource ForegroundColor}"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Margin="8,0,0,0"
                        Text="{Binding $parent[ColorPicker].Color}"
                        VerticalAlignment="Center" />
                </Grid>
            </Template>
        </Setter>
    </ControlTheme>

</ResourceDictionary>