<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <MenuFlyout Placement="Bottom" x:Key="SelectableTextBlockContextFlyout">
        <MenuItem
            Command="{Binding $parent[TextBox].Copy}"
            Cursor="Hand"
            Header="复制"
            InputGesture="{x:Static TextBox.CopyGesture}"
            IsEnabled="{Binding $parent[TextBox].CanCopy}">
            <MenuItem.Icon>
                <PathIcon
                    Data="M192 0c-41.8 0-77.4 26.7-90.5 64L64 64C28.7 64 0 92.7 0 128L0 448c0 35.3 28.7 64 64 64l256 0c35.3 0 64-28.7 64-64l0-320c0-35.3-28.7-64-64-64l-37.5 0C269.4 26.7 233.8 0 192 0zm0 64a32 32 0 1 1 0 64 32 32 0 1 1 0-64zM112 192l160 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-160 0c-8.8 0-16-7.2-16-16s7.2-16 16-16z"
                    Height="17"
                    Margin="1,0,0,0" />
            </MenuItem.Icon>
        </MenuItem>
    </MenuFlyout>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush
                Color="#0041C5"
                Opacity="0.8"
                x:Key="TextBoxSelectionBackground" />
            <SolidColorBrush Color="White" x:Key="TextBoxSelectionForeground" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush
                Color="#0041C5"
                Opacity="0.8"
                x:Key="TextBoxSelectionBackground" />
            <SolidColorBrush Color="White" x:Key="TextBoxSelectionForeground" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="SelectableTextBlock" x:Key="{x:Type SelectableTextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource YikFontSize}" />
        <Setter Property="Cursor" Value="Ibeam" />
        <Setter Property="SelectionBrush" Value="{DynamicResource TextBoxSelectionBackground}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextBoxSelectionForeground}" />

        <Setter Property="FontFamily" Value="{DynamicResource YikFontFamily}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition
                    Duration="0:0:0.3"
                    Easing="CircularEaseOut"
                    Property="Foreground" />
            </Transitions>
        </Setter>
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        <Style Selector="^.Underline">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="^.Delete">
            <Setter Property="TextDecorations" Value="StrikeThrough" />
        </Style>
        <Style Selector="^.Underline.Delete">
            <Setter Property="TextDecorations">
                <TextDecorationCollection>
                    <TextDecoration Location="Underline" />
                    <TextDecoration Location="Strikethrough" />
                </TextDecorationCollection>
            </Setter>
        </Style>
        <Style Selector="^.H1">
            <Setter Property="FontSize" Value="32" />
        </Style>
        <Style Selector="^.H2">
            <Setter Property="FontSize" Value="28" />
        </Style>
        <Style Selector="^.H3">
            <Setter Property="FontSize" Value="24" />
        </Style>
        <Style Selector="^.H4">
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style Selector="^.H5">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style Selector="^.H6">
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="^.Success">
            <Setter Property="Foreground" Value="#3bb346" />
        </Style>
        <Style Selector="^.Warning">
            <Setter Property="Foreground" Value="#fc8800" />
        </Style>
        <Style Selector="^.Danger">
            <Setter Property="Foreground" Value="#f93920" />
        </Style>
        <Style Selector="^.Accent">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        </Style>
        <Style Selector="^[IsEnabled=True]">
            <Setter Property="ContextFlyout" Value="{StaticResource SelectableTextBlockContextFlyout}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>