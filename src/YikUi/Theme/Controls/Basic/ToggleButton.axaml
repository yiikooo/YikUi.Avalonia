<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:converter="using:YikUi.Common.Converter"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <StackPanel HorizontalAlignment="Left" Spacing="16">
            <WrapPanel ItemSpacing="16" LineSpacing="16">
                <ToggleButton Content="Default" />
                <ToggleButton Content="Disabled" IsEnabled="False" />
                <ToggleButton
                    Content="Disabled"
                    IsChecked="True"
                    IsEnabled="False" />
                <ToggleButton Classes="Basic" Content="Basic Style" />
                <ToggleButton
                    Classes="Basic"
                    Content="Basic Checked"
                    IsChecked="True" />
            </WrapPanel>
        </StackPanel>
    </Design.PreviewWith>

    <converter:ColorDarkenConverter Percentage="0.15" x:Key="ColorDarken15" />
    <converter:ColorDarkenConverter Percentage="0.30" x:Key="ColorDarken30" />
    <converter:ColorDarkenConverter Percentage="0.45" x:Key="ColorDarken45" />
    <converter:ColorLightenConverter Percentage="0.15" x:Key="ColorLighten15" />
    <converter:ColorLightenConverter Percentage="0.30" x:Key="ColorLighten30" />
    <converter:ColorLightenConverter Percentage="0.45" x:Key="ColorLighten45" />

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="#FFFFFF" x:Key="ForegroundColor" />
            <SolidColorBrush Color="Transparent" x:Key="ButtonOutlineBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.05"
                x:Key="ButtonOutlinePointeroverBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="ButtonOutlinePressedBackground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.35"
                x:Key="TButtonDefaultDisabledForeground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.08"
                x:Key="ButtonOutlineBorderBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="#FFFFFF" x:Key="ForegroundColor" />
            <SolidColorBrush Color="Transparent" x:Key="ButtonOutlineBackground" />
            <SolidColorBrush
                Color="#FFFFFF"
                Opacity="0.12"
                x:Key="ButtonOutlinePointeroverBackground" />
            <SolidColorBrush
                Color="#FFFFFF"
                Opacity="0.16"
                x:Key="ButtonOutlinePressedBackground" />
            <SolidColorBrush
                Color="#F9F9F9"
                Opacity="0.75"
                x:Key="TButtonDefaultDisabledForeground" />
            <SolidColorBrush
                Color="#FFFFFF"
                Opacity="0.08"
                x:Key="ButtonOutlineBorderBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Thickness x:Key="AdornerLayerBorderThickness">2</Thickness>
    <CornerRadius x:Key="AdornerLayerCornerRadius">3</CornerRadius>

    <ControlTheme
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="ToggleButton"
        x:Key="{x:Type ToggleButton}">

        <Style Selector="^:checked">
            <Setter Property="FocusAdorner">
                <FocusAdornerTemplate>
                    <Border Classes="Solid" Theme="{DynamicResource AdornerLayerBorder}" />
                </FocusAdornerTemplate>
            </Setter>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight1}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorLight1}" />
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1}" />
            </Style>
            <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="{DynamicResource TButtonDefaultDisabledForeground}" />
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="ToggleButton"
        x:Key="TransparentToggleButton">

        <Style Selector="^">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonDefaultDisabledForeground}" />
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="ToggleButton" x:Key="InputToggleButton">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource ButtonInputInnerForeground}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ToggleButton">
                <Panel
                    Background="{TemplateBinding Background}"
                    Height="{TemplateBinding Height}"
                    Width="{TemplateBinding Width}">
                    <PathIcon
                        Data="M2.03 4.68a1.5 1.5 0 0 1 2.03.61c2.15 4 4.77 6.21 7.94 6.21 3.17 0 5.79-2.2 7.94-6.21a1.5 1.5 0 0 1 2.64 1.42 21.25 21.25 0 0 1-2.3 3.49l2.92 3.9a1.5 1.5 0 0 1-2.4 1.8l-2.68-3.58c-.67.53-1.39.98-2.15 1.32l1.43 3.83a1.5 1.5 0 1 1-2.8 1.06l-1.5-4a1.57 1.57 0 0 1-.03-.09 9.86 9.86 0 0 1-2.14 0l-.03.09-1.5 4a1.5 1.5 0 1 1-2.8-1.06l1.43-3.83c-.76-.34-1.48-.79-2.15-1.32L3.2 15.9a1.5 1.5 0 0 1-2.4-1.8l2.93-3.9A21.25 21.25 0 0 1 1.42 6.7a1.5 1.5 0 0 1 .6-2.03Z"
                        IsVisible="{TemplateBinding IsChecked,
                                                    Converter={x:Static BoolConverters.Not}}"
                        Theme="{DynamicResource InnerPathIcon}" />
                    <PathIcon
                        Data="M12 4C5 4 1 10 1 12s4 8 11 8 11-6 11-8-4-8-11-8Zm5 8a5 5 0 1 1-10 0 5 5 0 0 1 10 0Zm-5 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
                        IsVisible="{TemplateBinding IsChecked}"
                        Theme="{DynamicResource InnerPathIcon}" />
                </Panel>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource ButtonInputInnerPointeroverForeground}" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="Foreground" Value="{DynamicResource ButtonInputInnerPressedForeground}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>