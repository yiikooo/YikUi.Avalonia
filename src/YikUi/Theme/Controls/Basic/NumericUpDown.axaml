<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="#FEF2ED" x:Key="DataValidationErrorsBackground" />
            <SolidColorBrush Color="#FEDDD2" x:Key="DataValidationErrorsPointeroverBackground" />
            <SolidColorBrush Color="#FDB7A5" x:Key="DataValidationErrorsPressedBackground" />
            <SolidColorBrush Color="#FEF2ED" x:Key="DataValidationErrorsSelectedBackground" />
            <SolidColorBrush Color="#F93920" x:Key="DataValidationErrorsSelectedBorderBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush
                Color="#FC725A"
                Opacity="0.2"
                x:Key="DataValidationErrorsBackground" />
            <SolidColorBrush
                Color="#FC725A"
                Opacity="0.3"
                x:Key="DataValidationErrorsPointeroverBackground" />
            <SolidColorBrush
                Color="#FC725A"
                Opacity="0.4"
                x:Key="DataValidationErrorsPressedBackground" />
            <SolidColorBrush
                Color="#FC725A"
                Opacity="0.2"
                x:Key="DataValidationErrorsSelectedBackground" />
            <SolidColorBrush Color="#FC725A" x:Key="DataValidationErrorsSelectedBorderBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="NumericUpDown" x:Key="{x:Type NumericUpDown}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource YikCornerRadius}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <ControlTemplate TargetType="NumericUpDown">
                <DataValidationErrors>
                    <ButtonSpinner
                        AllowSpin="{TemplateBinding AllowSpin}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}"
                        HorizontalContentAlignment="Stretch"
                        MinWidth="0"
                        Name="PART_Spinner"
                        ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
                        VerticalContentAlignment="Stretch">
                        <TextBox
                            AcceptsReturn="False"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            DataValidationErrors.Errors="{Binding $parent[NumericUpDown].(DataValidationErrors.Errors)}"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{TemplateBinding Foreground}"
                            Height="{TemplateBinding Height}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            InnerLeftContent="{TemplateBinding InnerLeftContent}"
                            InnerRightContent="{TemplateBinding InnerRightContent}"
                            IsReadOnly="{TemplateBinding IsReadOnly}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Name="PART_TextBox"
                            PlaceholderText="{TemplateBinding Watermark}"
                            Text="{TemplateBinding Text}"
                            TextWrapping="NoWrap"
                            Theme="{DynamicResource NonErrorTextBox}"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ButtonSpinner>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:error">
            <Style Selector="^ /template/ TextBox#PART_TextBox">
                <Setter Property="Background" Value="{DynamicResource DataValidationErrorsBackground}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="^:pointerover /template/ TextBox#PART_TextBox">
                <Setter Property="Background" Value="{DynamicResource DataValidationErrorsPointeroverBackground}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="^:pressed /template/ TextBox#PART_TextBox">
                <Setter Property="Background" Value="{DynamicResource DataValidationErrorsPressedBackground}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="^:focus /template/ TextBox#PART_TextBox">
                <Setter Property="Background" Value="{DynamicResource DataValidationErrorsSelectedBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DataValidationErrorsSelectedBorderBrush}" />
            </Style>
        </Style>
    </ControlTheme>

</ResourceDictionary>