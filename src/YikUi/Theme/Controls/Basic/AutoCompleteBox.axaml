<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <StackPanel Margin="20" Spacing="20">
            <TextBox Text="Hello" />
            <AutoCompleteBox Width="100" />
        </StackPanel>
    </Design.PreviewWith>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="White" x:Key="AutoCompleteBoxPopupBackground" />
            <SolidColorBrush
                Color="#000000"
                Opacity="0.08"
                x:Key="AutoCompleteBoxPopupBorderBrush" />
            <BoxShadows x:Key="AutoCompleteBoxPopupBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="#43444A" x:Key="AutoCompleteBoxPopupBackground" />
            <SolidColorBrush
                Color="#FFFFFF"
                Opacity="0.08"
                x:Key="AutoCompleteBoxPopupBorderBrush" />
            <BoxShadows x:Key="AutoCompleteBoxPopupBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Thickness x:Key="AutoCompleteBoxPopupBorderThickness">1</Thickness>
    <CornerRadius x:Key="AutoCompleteBoxPopupCornerRadius">6</CornerRadius>
    <Thickness x:Key="AutoCompleteBoxPopupMargin">4</Thickness>

    <ControlTheme TargetType="AutoCompleteBox" x:Key="{x:Type AutoCompleteBox}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <ControlTemplate TargetType="AutoCompleteBox">
                <DataValidationErrors>
                    <Panel>
                        <TextBox
                            DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                            InnerLeftContent="{TemplateBinding InnerLeftContent}"
                            InnerRightContent="{TemplateBinding InnerRightContent}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Name="PART_TextBox"
                            PlaceholderText="{TemplateBinding Watermark}"
                            Theme="{DynamicResource NonErrorTextBox}"
                            VerticalAlignment="Stretch" />
                        <Popup
                            InheritsTransform="True"
                            IsLightDismissEnabled="True"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                            Name="PART_Popup"
                            PlacementTarget="{TemplateBinding}">
                            <Border
                                Background="{DynamicResource PopupBackgroundColor}"
                                BorderBrush="{DynamicResource PopupBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource YikCornerRadius}"
                                HorizontalAlignment="Stretch"
                                Margin="4"
                                MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                                <ListBox
                                    Foreground="{TemplateBinding Foreground}"
                                    ItemTemplate="{TemplateBinding ItemTemplate}"
                                    Margin="0,-2"
                                    Name="PART_SelectingItemsControl"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </Popup>
                    </Panel>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Bordered">
            <Setter Property="Template">
                <ControlTemplate TargetType="AutoCompleteBox">
                    <Panel>
                        <TextBox
                            Classes="Bordered"
                            DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                            MinHeight="0"
                            Name="PART_TextBox"
                            PlaceholderText="{TemplateBinding Watermark}"
                            VerticalAlignment="Stretch" />
                        <Popup
                            InheritsTransform="True"
                            IsLightDismissEnabled="True"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                            Name="PART_Popup"
                            PlacementTarget="{TemplateBinding}">
                            <Border
                                Background="{DynamicResource AutoCompleteBoxPopupBackground}"
                                BorderBrush="{DynamicResource AutoCompleteBoxPopupBorderBrush}"
                                BorderThickness="{DynamicResource AutoCompleteBoxPopupBorderThickness}"
                                BoxShadow="{DynamicResource AutoCompleteBoxPopupBoxShadow}"
                                CornerRadius="{DynamicResource AutoCompleteBoxPopupCornerRadius}"
                                HorizontalAlignment="Stretch"
                                Margin="{DynamicResource AutoCompleteBoxPopupMargin}"
                                MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                                <ListBox
                                    Foreground="{TemplateBinding Foreground}"
                                    ItemTemplate="{TemplateBinding ItemTemplate}"
                                    Margin="0,-2"
                                    Name="PART_SelectingItemsControl"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.IsScrollChainingEnabled="False"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </Popup>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="^.BorderedOnFocus">
            <Setter Property="Template">
                <ControlTemplate TargetType="AutoCompleteBox">
                    <Panel>
                        <TextBox
                            Classes="BorderedOnFocus"
                            DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                            MinHeight="0"
                            Name="PART_TextBox"
                            PlaceholderText="{TemplateBinding Watermark}"
                            VerticalAlignment="Stretch" />
                        <Popup
                            InheritsTransform="True"
                            IsLightDismissEnabled="True"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                            Name="PART_Popup"
                            PlacementTarget="{TemplateBinding}">
                            <Border
                                Background="{DynamicResource AutoCompleteBoxPopupBackground}"
                                BorderBrush="{DynamicResource AutoCompleteBoxPopupBorderBrush}"
                                BorderThickness="{DynamicResource AutoCompleteBoxPopupBorderThickness}"
                                BoxShadow="{DynamicResource AutoCompleteBoxPopupBoxShadow}"
                                CornerRadius="{DynamicResource AutoCompleteBoxPopupCornerRadius}"
                                HorizontalAlignment="Stretch"
                                Margin="{DynamicResource AutoCompleteBoxPopupMargin}"
                                MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                                <ListBox
                                    Foreground="{TemplateBinding Foreground}"
                                    ItemTemplate="{TemplateBinding ItemTemplate}"
                                    Margin="0,-2"
                                    Name="PART_SelectingItemsControl"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.IsScrollChainingEnabled="False"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </Popup>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
    </ControlTheme>
</ResourceDictionary>