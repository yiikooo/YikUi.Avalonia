<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- <DatePickerPresenter YearVisible="False" /> -->
            <DatePickerPresenter Classes="BorderedOnFocus" />
        </Border>
    </Design.PreviewWith>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!--  DateTimePicker Colors  -->
            <SolidColorBrush Color="White" x:Key="DateTimePickerPopupBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerPopupBorderBrush" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.08"
                x:Key="DateTimePickerSeparatorBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonBorderBrush" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.05"
                x:Key="DateTimePickerButtonBackground" />
            <SolidColorBrush Color="#1C1F23" x:Key="DateTimePickerButtonForeground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.62"
                x:Key="DateTimePickerIconForeground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.62"
                x:Key="DateTimePickerEmptyForeground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="DateTimePickerButtonPointeroverBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonPointeroverBorderBrush" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonDisabledBorderBrush" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.02"
                x:Key="DateTimePickerButtonDisabledBackground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.35"
                x:Key="DateTimePickerButtonDisabledIconForeground" />
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.62"
                x:Key="DateTimePickerFlyoutButtonForeground" />
            <SolidColorBrush Color="#1C1F23" x:Key="DateTimePickerFlyoutButtonPointeroverForeground" />
            <SolidColorBrush Color="#1C1F23" x:Key="DateTimePickerFlyoutButtonPressedForeground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerFlyoutButtonBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="DateTimePickerFlyoutButtonPointeroverBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.13"
                x:Key="DateTimePickerFlyoutButtonPressedBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerListItemBackground" />
            <!-- <BoxShadows x:Key="DateTimePickerFlyoutBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows> -->
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <!--  DateTimePicker Colors  -->
            <SolidColorBrush Color="#43444A" x:Key="DateTimePickerPopupBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerPopupBorderBrush" />
            <SolidColorBrush
                Color="White"
                Opacity="0.08"
                x:Key="DateTimePickerSeparatorBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonBorderBrush" />
            <SolidColorBrush
                Color="White"
                Opacity="0.12"
                x:Key="DateTimePickerButtonBackground" />
            <SolidColorBrush Color="#F9F9F9" x:Key="DateTimePickerButtonForeground" />
            <SolidColorBrush
                Color="#F9F9F9"
                Opacity="0.6"
                x:Key="DateTimePickerIconForeground" />
            <SolidColorBrush
                Color="#F9F9F9"
                Opacity="0.6"
                x:Key="DateTimePickerEmptyForeground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.16"
                x:Key="DateTimePickerButtonPointeroverBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonPointeroverBorderBrush" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerButtonDisabledBorderBrush" />
            <SolidColorBrush
                Color="#E6E8EA"
                Opacity="0.04"
                x:Key="DateTimePickerButtonDisabledBackground" />
            <SolidColorBrush
                Color="#F9F9F9"
                Opacity="0.35"
                x:Key="DateTimePickerButtonDisabledIconForeground" />
            <SolidColorBrush
                Color="#F9F9F9"
                Opacity="0.6"
                x:Key="DateTimePickerFlyoutButtonForeground" />
            <SolidColorBrush Color="#F9F9F9" x:Key="DateTimePickerFlyoutButtonPointeroverForeground" />
            <SolidColorBrush Color="#F9F9F9" x:Key="DateTimePickerFlyoutButtonPressedForeground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerFlyoutButtonBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.16"
                x:Key="DateTimePickerFlyoutButtonPointeroverBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.20"
                x:Key="DateTimePickerFlyoutButtonPressedBackground" />
            <SolidColorBrush Color="Transparent" x:Key="DateTimePickerListItemBackground" />
            <!-- <BoxShadows x:Key="DateTimePickerFlyoutBoxShadow">inset 0 0 0 1 #1AFFFFFF, 0 4 14 #40000000</BoxShadows> -->
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!--  Non-theme specific resources  -->
    <CornerRadius x:Key="DateTimePickerPopupCornerRadius">10</CornerRadius>
    <x:Double x:Key="DateTimePickerListBoxItemHeight">36</x:Double>
    <Thickness x:Key="DateTimePickerFlyoutPadding">0</Thickness>
    <Thickness x:Key="DateTimePickerFlyoutBorderMargin">8</Thickness>
    <x:Double x:Key="DateTimePickerButtonSmallHeight">24</x:Double>
    <x:Double x:Key="DateTimePickerButtonDefaultHeight">32</x:Double>
    <x:Double x:Key="DateTimePickerButtonLargeHeight">40</x:Double>
    <Thickness x:Key="DateTimePickerButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="DateTimePickerButtonCornerRadius">3</CornerRadius>

    <!--  Icon Glyphs  -->
    <StreamGeometry x:Key="DateTimePickerButtonUpGlyph">m2.17 17.4 9.02-12.3a1 1 0 0 1 1.62 0l9.02 12.3a1 1 0 0 1-.8 1.6H2.97a1 1 0 0 1-.8-1.6Z</StreamGeometry>
    <StreamGeometry x:Key="DateTimePickerButtonDownGlyph">m21.83 6.6-9.02 12.3a1 1 0 0 1-1.62 0L2.17 6.6a1 1 0 0 1 .8-1.6h18.06a1 1 0 0 1 .8 1.6Z</StreamGeometry>
    <StreamGeometry x:Key="DateTimePickerAcceptGlyph">M21.35 4.27c.68.47.86 1.4.38 2.08l-10 14.5a1.5 1.5 0 0 1-2.33.17l-6.5-7a1.5 1.5 0 0 1 2.2-2.04l5.23 5.63 8.94-12.96a1.5 1.5 0 0 1 2.08-.38Z</StreamGeometry>
    <StreamGeometry x:Key="DateTimePickerDismissGlyph">M17.66 19.78a1.5 1.5 0 0 0 2.12-2.12L14.12 12l5.66-5.66a1.5 1.5 0 0 0-2.12-2.12L12 9.88 6.34 4.22a1.5 1.5 0 1 0-2.12 2.12L9.88 12l-5.66 5.66a1.5 1.5 0 0 0 2.12 2.12L12 14.12l5.66 5.66Z</StreamGeometry>
    <StreamGeometry x:Key="DatePickerIconGlyph">F1 M448,512z M0,0z M128,0C110.3,0,96,14.3,96,32L96,64 64,64C28.7,64,0,92.7,0,128L0,176 448,176 448,128C448,92.7,419.3,64,384,64L352,64 352,32C352,14.3 337.7,0 320,0 302.3,0 288,14.3 288,32L288,64 160,64 160,32C160,14.3,145.7,0,128,0z M0,224L0,416C0,451.3,28.7,480,64,480L384,480C419.3,480,448,451.3,448,416L448,224 0,224z</StreamGeometry>

    <ControlTheme TargetType="DatePickerPresenter" x:Key="{x:Type DatePickerPresenter}">
        <Setter Property="Width" Value="296" />
        <Setter Property="MinWidth" Value="296" />
        <Setter Property="MaxHeight" Value="300" />
        <Setter Property="Background" Value="{DynamicResource PopupBackgroundColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PopupBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource DateTimePickerPopupCornerRadius}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="DatePickerPresenter">
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    BoxShadow="{DynamicResource DateTimePickerFlyoutBoxShadow}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    HorizontalAlignment="Stretch"
                    Margin="{DynamicResource DateTimePickerFlyoutBorderMargin}"
                    Name="Background"
                    Padding="{DynamicResource DateTimePickerFlyoutPadding}">
                    <Border ClipToBounds="True" CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid Name="ContentPanel" RowDefinitions="*,Auto">
                            <Grid ColumnDefinitions="*,1,*,1,*" Name="PART_PickerContainer">

                                <Grid.Styles>
                                    <Style Selector="DateTimePickerPanel &gt; ListBoxItem">
                                        <Setter Property="Theme" Value="{StaticResource DateTimePickerItem}" />
                                    </Style>
                                </Grid.Styles>

                                <Panel Name="PART_MonthHost">
                                    <Border
                                        BorderBrush="{DynamicResource DateTimePickerSeparatorBackground}"
                                        BorderThickness="0"
                                        Name="PART_MonthBorder">
                                        <Panel>
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Hidden">
                                                <DateTimePickerPanel
                                                    ItemHeight="{DynamicResource DateTimePickerListBoxItemHeight}"
                                                    Name="PART_MonthSelector"
                                                    PanelType="Month"
                                                    ShouldLoop="True" />
                                            </ScrollViewer>
                                            <RepeatButton Name="PART_MonthUpButton"
                                                          Theme="{StaticResource DateTimePickerUpButton}" />
                                            <RepeatButton Name="PART_MonthDownButton"
                                                          Theme="{StaticResource DateTimePickerDownButton}" />
                                        </Panel>
                                    </Border>
                                </Panel>


                                <Panel Grid.Column="2" Name="PART_DayHost">
                                    <Border BorderBrush="{DynamicResource DateTimePickerSeparatorBackground}">
                                        <Panel>
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Hidden">
                                                <DateTimePickerPanel
                                                    ItemHeight="{DynamicResource DateTimePickerListBoxItemHeight}"
                                                    Name="PART_DaySelector"
                                                    PanelType="Day"
                                                    ShouldLoop="True" />
                                            </ScrollViewer>
                                            <RepeatButton Name="PART_DayUpButton"
                                                          Theme="{StaticResource DateTimePickerUpButton}" />
                                            <RepeatButton Name="PART_DayDownButton"
                                                          Theme="{StaticResource DateTimePickerDownButton}" />
                                        </Panel>
                                    </Border>
                                </Panel>

                                <Panel Grid.Column="4" Name="PART_YearHost">
                                    <Border
                                        BorderBrush="{DynamicResource DateTimePickerSeparatorBackground}"
                                        BorderThickness="0"
                                        Name="PART_YearBorder">
                                        <Panel>
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Hidden">
                                                <DateTimePickerPanel
                                                    ItemHeight="{DynamicResource DateTimePickerListBoxItemHeight}"
                                                    Name="PART_YearSelector"
                                                    PanelType="Year"
                                                    ShouldLoop="False" />
                                            </ScrollViewer>
                                            <RepeatButton Name="PART_YearUpButton"
                                                          Theme="{StaticResource DateTimePickerUpButton}" />
                                            <RepeatButton Name="PART_YearDownButton"
                                                          Theme="{StaticResource DateTimePickerDownButton}" />
                                        </Panel>
                                    </Border>
                                </Panel>
                            </Grid>

                            <Grid
                                ColumnDefinitions="*,Auto,*"
                                Grid.Row="1"
                                Name="AcceptDismissGrid">
                                <Button
                                    CornerRadius="{DynamicResource YikCornerRadius}"
                                    Grid.Column="0"
                                    Height="30"
                                    HorizontalAlignment="Stretch"
                                    Margin="3,4,3,3"
                                    Name="PART_AcceptButton"
                                    Padding="0,6"
                                    Theme="{StaticResource DateTimePickerButton}"
                                    VerticalAlignment="Stretch">
                                    <PathIcon
                                        Data="{DynamicResource DateTimePickerAcceptGlyph}"
                                        Foreground="{DynamicResource InnerForegroundColor}"
                                        Height="15"
                                        Width="12" />
                                </Button>
                                <Rectangle
                                    Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                                    Grid.Column="1"
                                    Margin="-2,0,0,0"
                                    Width="1" />
                                <Button
                                    CornerRadius="{DynamicResource YikCornerRadius}"
                                    Grid.Column="2"
                                    Height="30"
                                    HorizontalAlignment="Stretch"
                                    Margin="3,4,3,3"
                                    Name="PART_DismissButton"
                                    Padding="0,6"
                                    Theme="{StaticResource DateTimePickerButton}"
                                    VerticalAlignment="Stretch">
                                    <PathIcon
                                        Data="{DynamicResource DateTimePickerDismissGlyph}"
                                        Foreground="{DynamicResource InnerForegroundColor}"
                                        Height="15"
                                        Theme="{StaticResource InnerPathIcon}"
                                        Width="15" />
                                </Button>
                                <Rectangle
                                    Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Height="1"
                                    VerticalAlignment="Top" />
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Panel">
            <Style Selector="^:pointerover RepeatButton">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[DayVisible=True] /template/ Border#PART_MonthBorder">
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="^[DayVisible=True] /template/ Border#PART_YearBorder">
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="^[MonthVisible=True] /template/ Border#PART_YearBorder">
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="DatePicker" x:Key="{x:Type DatePicker}">
        <Setter Property="Foreground" Value="{DynamicResource DateTimePickerButtonForeground}" />
        <Setter Property="Background" Value="{DynamicResource DateTimePickerButtonBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DateTimePickerButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource YikCornerRadius}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="{DynamicResource DateTimePickerButtonDefaultHeight}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="DatePicker">
                <DataValidationErrors>
                    <Grid
                        ColumnDefinitions="*, Auto"
                        Margin="{TemplateBinding Padding}"
                        Name="LayoutRoot">
                        <Button
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Cursor="Hand"
                            DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                            Foreground="{TemplateBinding Foreground}"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{TemplateBinding IsEnabled}"
                            MinHeight="{TemplateBinding MinHeight}"
                            MinWidth="298"
                            Name="PART_FlyoutButton"
                            Theme="{StaticResource DateTimePickerFlyoutButton}"
                            VerticalAlignment="Stretch"
                            Width="298">
                            <Grid ColumnDefinitions="*, Auto">
                                <Grid
                                    ColumnDefinitions="78*,Auto,132*,Auto,78*"
                                    Grid.Column="0"
                                    Name="PART_ButtonContentGrid">
                                    <TextBlock
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        HorizontalAlignment="Center"
                                        Name="PART_DayTextBlock"
                                        Padding="12,0"
                                        Text="{DynamicResource Lang.Day}"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        HorizontalAlignment="Center"
                                        Name="PART_MonthTextBlock"
                                        Padding="12,0"
                                        Text="{DynamicResource Lang.Month}"
                                        TextAlignment="Left"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        HorizontalAlignment="Center"
                                        Name="PART_YearTextBlock"
                                        Padding="12,0"
                                        Text="{DynamicResource Lang.Year}"
                                        VerticalAlignment="Center" />
                                    <Rectangle
                                        Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Name="PART_FirstSpacer"
                                        Width="1" />
                                    <Rectangle
                                        Fill="{DynamicResource DateTimePickerSeparatorBackground}"
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        Name="PART_SecondSpacer"
                                        Width="1" />
                                </Grid>
                                <PathIcon
                                    Data="F1 M448,512z M0,0z M128,0C110.3,0,96,14.3,96,32L96,64 64,64C28.7,64,0,92.7,0,128L0,176 448,176 448,128C448,92.7,419.3,64,384,64L352,64 352,32C352,14.3 337.7,0 320,0 302.3,0 288,14.3 288,32L288,64 160,64 160,32C160,14.3,145.7,0,128,0z M0,224L0,416C0,451.3,28.7,480,64,480L384,480C419.3,480,448,451.3,448,416L448,224 0,224z"
                                    Foreground="{DynamicResource DateTimePickerIconForeground}"
                                    Grid.Column="1"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    Name="PART_Icon"
                                    Width="20" />
                            </Grid>
                        </Button>
                        <Popup
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            InheritsTransform="True"
                            IsLightDismissEnabled="True"
                            Name="PART_Popup"
                            Placement="Bottom"
                            PlacementTarget="{TemplateBinding}"
                            WindowManagerAddShadowHint="False">
                            <DatePickerPresenter Name="PART_PickerPresenter" />
                        </Popup>
                        <Button
                            Command="{Binding $parent[DatePicker].Clear}"
                            Focusable="False"
                            Grid.Column="1"
                            IsVisible="False"
                            Margin="0,0,9,0"
                            Name="ClearButton"
                            Theme="{DynamicResource TransparentButton}">
                            <PathIcon
                                Data="{DynamicResource Close}"
                                Foreground="{DynamicResource InnerForegroundColor}"
                                Height="11"
                                Width="16" />
                        </Button>
                    </Grid>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.clearButton:pointerover, ^.ClearButton:pointerover">
            <Style Selector="^:not(:hasnodate) /template/ Button#ClearButton">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="^:not(:hasnodate) /template/ PathIcon#PART_Icon">
                <Setter Property="Opacity" Value="0" />
            </Style>
        </Style>

        <Style Selector="^:disabled /template/ PathIcon#PART_Icon">
            <Setter Property="Foreground" Value="{DynamicResource DateTimePickerButtonDisabledIconForeground}" />
        </Style>

        <Style Selector="^:hasnodate /template/ Button#PART_FlyoutButton TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DateTimePickerEmptyForeground}" />
        </Style>

        <Style Selector="^.Bordered">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style Selector="^:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style Selector="^:focus">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </Style>
        <Style Selector="^.BorderedOnFocus:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="^.BorderedOnFocus:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </ControlTheme>
</ResourceDictionary>