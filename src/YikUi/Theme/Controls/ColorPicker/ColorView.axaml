<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="using:Avalonia.Controls.Converters"
    xmlns:globalization="using:System.Globalization"
    xmlns:pc="using:Avalonia.Controls.Primitives.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <pc:ContrastBrushConverter x:Key="ContrastBrushConverter" />
    <converters:ColorToDisplayNameConverter x:Key="ColorToDisplayNameConverter" />
    <converters:ColorToHexConverter x:Key="ColorToHexConverter" />
    <converters:DoNothingForNullConverter x:Key="DoNothingForNullConverter" />
    <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    <converters:ToBrushConverter x:Key="ToBrushConverter" />
    <yik:HsvColorToTextConverter x:Key="HsvColorToTextConverter" />
    <yik:ColorToTextConverter x:Key="ColorToTextConverter" />
    <yik:ToColorModel x:Key="ToColorModel" />
    <globalization:NumberFormatInfo NumberDecimalDigits="0" x:Key="ColorViewComponentNumberFormat" />

    <Design.PreviewWith>
        <ColorView
            ColorModel="Hsva"
            HsvColor="hsv(120,7%,90%)"
            IsAlphaEnabled="True"
            IsAlphaVisible="True"
            Theme="{StaticResource SimpleColorView}" />
    </Design.PreviewWith>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!--  ColorView Radio Button Resources  -->
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonForeground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="ColorViewRadioButtonPointeroverBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.13"
                x:Key="ColorViewRadioButtonPressedBackground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonCheckedForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewRadioButtonCheckedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark1}"
                             x:Key="ColorViewRadioButtonCheckedPointeroverBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorDark2}"
                             x:Key="ColorViewRadioButtonCheckedPressedBackground" />
            <!--  ColorView Tab Resources  -->
            <SolidColorBrush Color="{DynamicResource SystemAccentColor}" x:Key="ColorViewTabItemSelectedForeground" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <!--  ColorView Radio Button Resources  -->
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight1}" x:Key="ColorViewRadioButtonForeground" />
            <SolidColorBrush Color="#16161A" x:Key="ColorViewRadioButtonBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.16"
                x:Key="ColorViewRadioButtonPointeroverBackground" />
            <SolidColorBrush
                Color="White"
                Opacity="0.20"
                x:Key="ColorViewRadioButtonPressedBackground" />
            <SolidColorBrush Color="White" x:Key="ColorViewRadioButtonCheckedForeground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight1}"
                             x:Key="ColorViewRadioButtonCheckedBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight2}"
                             x:Key="ColorViewRadioButtonCheckedPointeroverBackground" />
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight3}"
                             x:Key="ColorViewRadioButtonCheckedPressedBackground" />
            <!--  ColorView Tab Resources  -->
            <SolidColorBrush Color="{DynamicResource SystemAccentColorLight1}"
                             x:Key="ColorViewTabItemSelectedForeground" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!--  Non-theme resources  -->
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>

    <VisualBrush
        DestinationRect="0,0,8,8"
        Stretch="Uniform"
        TileMode="Tile"
        x:Key="ColorControlCheckeredBackgroundBrush">
        <VisualBrush.Visual>
            <Image Height="8" Width="8">
                <Image.Source>
                    <DrawingImage>
                        <DrawingImage.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="Transparent" Geometry="M0,0 L2,0 2,2, 0,2Z" />
                                <GeometryDrawing Brush="#19808080" Geometry="M0,1 L2,1 2,2, 1,2 1,0 0,0Z" />
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                </Image.Source>
            </Image>
        </VisualBrush.Visual>
    </VisualBrush>

    <ControlTheme TargetType="ListBox" x:Key="ColorViewPaletteListBoxTheme">
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.IsScrollChainingEnabled" Value="True" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBox">
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    ClipToBounds="{TemplateBinding ClipToBounds}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Name="border">
                    <ScrollViewer
                        AllowAutoHide="{TemplateBinding (ScrollViewer.AllowAutoHide)}"
                        HorizontalScrollBarVisibility="{TemplateBinding (ScrollViewer.HorizontalScrollBarVisibility)}"
                        IsDeferredScrollingEnabled="{TemplateBinding (ScrollViewer.IsDeferredScrollingEnabled)}"
                        IsScrollChainingEnabled="{TemplateBinding (ScrollViewer.IsScrollChainingEnabled)}"
                        Name="PART_ScrollViewer"
                        VerticalScrollBarVisibility="{TemplateBinding (ScrollViewer.VerticalScrollBarVisibility)}">
                        <ItemsPresenter
                            ItemsPanel="{TemplateBinding ItemsPanel}"
                            Margin="{TemplateBinding Padding}"
                            Name="PART_ItemsPresenter" />
                    </ScrollViewer>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="ListBoxItem" x:Key="ColorViewPaletteListBoxItemTheme">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                <Grid UseLayoutRounding="False">
                    <ContentPresenter
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    <Rectangle
                        HorizontalAlignment="Stretch"
                        IsHitTestVisible="False"
                        Name="BorderRectangle"
                        StrokeThickness="1"
                        VerticalAlignment="Stretch" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Rectangle#BorderRectangle">
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="^:pointerover /template/ Rectangle#BorderRectangle" x:DataType="Color">
            <Setter Property="Stroke" Value="{Binding Converter={StaticResource ContrastBrushConverter}}" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>

        <Style Selector="^:selected /template/ Rectangle#BorderRectangle" x:DataType="Color">
            <Setter Property="Stroke" Value="{Binding Converter={StaticResource ContrastBrushConverter}}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="RadioButton" x:Key="ColorViewRadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="600" />
        <Setter Property="Padding" Value="16,4" />
        <Setter Property="Foreground" Value="{DynamicResource ColorViewRadioButtonForeground}" />
        <Setter Property="Background" Value="{DynamicResource ColorViewRadioButtonBackground}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="RadioButton">
                <ContentPresenter
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Content="{TemplateBinding Content}"
                    ContentTemplate="{TemplateBinding ContentTemplate}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                    Margin="{TemplateBinding Margin}"
                    Name="PART_ContentPresenter"
                    Padding="{TemplateBinding Padding}"
                    RecognizesAccessKey="True"
                    TextElement.FontSize="{TemplateBinding FontSize}"
                    TextElement.FontWeight="{TemplateBinding FontWeight}"
                    UseLayoutRounding="False"
                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
            </ControlTemplate>
        </Setter>
        <Style Selector="^:checked">
            <Setter Property="Background" Value="{DynamicResource ColorViewRadioButtonCheckedBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ColorViewRadioButtonCheckedForeground}" />
            <Style Selector="^:pointerover">
                <Setter Property="Background"
                        Value="{DynamicResource ColorViewRadioButtonCheckedPointeroverBackground}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource ColorViewRadioButtonCheckedPressedBackground}" />
            </Style>
        </Style>
        <Style Selector="^:unchecked">
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ColorViewRadioButtonPointeroverBackground}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource ColorViewRadioButtonPressedBackground}" />
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="ColorView" x:Key="{x:Type ColorView}">
        <Setter Property="CornerRadius" Value="{DynamicResource YikCornerRadius}" />
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="300" />
        <Setter Property="Palette">
            <FluentColorPalette />
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ColorView}">
                <Grid RowDefinitions="*,Auto">
                    <!--  Backgrounds  -->
                    <!--  TODO: Background="{DynamicResource ColorViewTabBackgroundBrush}"  -->
                    <Border
                        Background="{DynamicResource ColorViewContentBackgroundBrush}"
                        BorderBrush="{DynamicResource ColorViewContentBorderBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Height="{TemplateBinding Height}"
                        HorizontalAlignment="Stretch"
                        Name="ContentBackgroundBorder"
                        VerticalAlignment="Stretch" />

                    <TabControl
                        Grid.Row="0"
                        HorizontalContentAlignment="Stretch"
                        Name="PART_TabControl"
                        Padding="0"
                        SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                        VerticalAlignment="Stretch">
                        <TabControl.Styles>
                            <Style Selector="TabItem">
                                <Setter Property="MinHeight" Value="32" />
                            </Style>
                            <Style Selector="TabItem:selected">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ColorViewTabItemSelectedForeground}" />
                            </Style>
                        </TabControl.Styles>
                        <TabControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="0" Rows="1" />
                            </ItemsPanelTemplate>
                        </TabControl.ItemsPanel>
                        <!--  Spectrum Tab  -->
                        <TabItem IsVisible="{TemplateBinding IsColorSpectrumVisible}">
                            <TabItem.Header>
                                <PathIcon
                                    Data="M1.22 20.77a4.24 4.24 0 0 1 .02-5.98l9.33-9.28-.94-.95a1.41 1.41 0 0 1 0-1.99 1.39 1.39 0 0 1 1.97 0l.95.97L14.9 1.2a4.16 4.16 0 0 1 5.89.02 4.24 4.24 0 0 1-.02 5.98l-2.3 2.28 1.02 1.02c.54.55.54 1.44 0 1.99-.55.55-1.43.55-1.97 0l-1.03-1.03-9.37 9.32a4.16 4.16 0 0 1-5.89-.02ZM12.54 7.49l1.97 1.99-9.35 9.3c-.55.55-1.42.55-1.97 0a1.41 1.41 0 0 1 .01-2l9.34-9.29Z"
                                    Foreground="{Binding $parent[TabItem].Foreground}"
                                    Theme="{StaticResource InnerPathIcon}" />
                            </TabItem.Header>
                            <Grid Margin="12" RowDefinitions="*">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="32" Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition MinWidth="32" Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ColorSlider
                                    AutomationProperties.Name="Third Component"
                                    ColorComponent="{Binding ThirdComponent, ElementName=ColorSpectrum}"
                                    ColorModel="Hsva"
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    HsvColor="{Binding HsvColor, ElementName=ColorSpectrum}"
                                    IsAlphaVisible="True"
                                    IsPerceptive="False"
                                    IsVisible="{TemplateBinding IsColorSpectrumSliderVisible}"
                                    Margin="0,0,12,0"
                                    Name="ColorSpectrumThirdComponentSlider"
                                    Orientation="Vertical"
                                    VerticalAlignment="Stretch" />
                                <ColorSpectrum
                                    Components="{TemplateBinding ColorSpectrumComponents}"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    MaxHue="{TemplateBinding MaxHue}"
                                    MaxSaturation="{TemplateBinding MaxSaturation}"
                                    MaxValue="{TemplateBinding MaxValue}"
                                    MinHue="{TemplateBinding MinHue}"
                                    MinSaturation="{TemplateBinding MinSaturation}"
                                    MinValue="{TemplateBinding MinValue}"
                                    Name="ColorSpectrum"
                                    Shape="{TemplateBinding ColorSpectrumShape}"
                                    VerticalAlignment="Stretch" />
                                <ColorSlider
                                    AutomationProperties.Name="Alpha Component"
                                    ColorComponent="Alpha"
                                    ColorModel="Hsva"
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    HsvColor="{Binding HsvColor, ElementName=ColorSpectrum}"
                                    IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                    Margin="12,0,0,0"
                                    Name="ColorSpectrumAlphaSlider"
                                    Orientation="Vertical"
                                    VerticalAlignment="Stretch">
                                    <ColorSlider.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="IsAlphaVisible"
                                                     RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </ColorSlider.IsVisible>
                                </ColorSlider>
                            </Grid>
                        </TabItem>
                        <!--  Palette Tab  -->
                        <TabItem IsVisible="{TemplateBinding IsColorPaletteVisible}">
                            <TabItem.Header>
                                <PathIcon
                                    Data="M2 4c0-1.1.9-2 2-2h5a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4Zm6 13.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm11.59-8.91L16.4 5.4a2 2 0 0 0-2.82 0L13 6v12l6.59-6.59a2 2 0 0 0 0-2.82ZM22 16a2 2 0 0 0-2-2l-8 8h8a2 2 0 0 0 2-2v-4Z"
                                    Foreground="{Binding $parent[TabItem].Foreground}"
                                    Theme="{StaticResource InnerPathIcon}" />
                            </TabItem.Header>
                            <ListBox
                                ItemContainerTheme="{StaticResource ColorViewPaletteListBoxItemTheme}"
                                ItemsSource="{TemplateBinding PaletteColors}"
                                Margin="12"
                                SelectedItem="{Binding Color, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DoNothingForNullConverter}, Mode=TwoWay}"
                                Theme="{StaticResource ColorViewPaletteListBoxTheme}"
                                UseLayoutRounding="False"
                                VerticalAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type Color}">
                                        <Border
                                            AutomationProperties.Name="{Binding Converter={StaticResource ColorToDisplayNameConverter}}"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="{Binding Converter={StaticResource ColorToDisplayNameConverter}}"
                                            VerticalAlignment="Stretch">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding}" />
                                            </Border.Background>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding $parent[ColorView].PaletteColumnCount}" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </TabItem>
                        <!--  Components Tab  -->
                        <TabItem IsVisible="{TemplateBinding IsColorComponentsVisible}">
                            <TabItem.Header>
                                <PathIcon
                                    Data="M4 6.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM9.5 3a1.5 1.5 0 1 0 0 3h11a1.5 1.5 0 0 0 0-3h-11ZM8 11.5c0-.83.67-1.5 1.5-1.5h11a1.5 1.5 0 0 1 0 3h-11A1.5 1.5 0 0 1 8 11.5Zm0 7c0-.83.67-1.5 1.5-1.5h11a1.5 1.5 0 0 1 0 3h-11A1.5 1.5 0 0 1 8 18.5Zm-2-7a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm-2 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"
                                    Foreground="{Binding $parent[TabItem].Foreground}"
                                    Theme="{StaticResource InnerPathIcon}" />
                            </TabItem.Header>
                            <Grid
                                ColumnDefinitions="Auto,*"
                                Margin="12"
                                RowDefinitions="Auto,24,*,*,*,*,12"
                                UseLayoutRounding="False">
                                <Grid.Styles>
                                    <Style Selector="NumericUpDown">
                                        <Setter Property="InnerLeftContent">
                                            <Template>
                                                <TextBlock Text="{Binding $parent[NumericUpDown].Tag}" Width="12" />
                                            </Template>
                                        </Setter>
                                    </Style>
                                </Grid.Styles>
                                <!--  Top color model & Hex input  -->
                                <Grid
                                    ColumnDefinitions="*,12,*"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Grid.Row="0">
                                    <!--  RadioButtonGroup  -->
                                    <Border
                                        Background="{DynamicResource ColorViewRadioButtonPointeroverBackground}"
                                        CornerRadius="3"
                                        Padding="2">
                                        <Grid ColumnDefinitions="*,*" IsVisible="{TemplateBinding IsColorModelVisible}">
                                            <RadioButton
                                                Content="RGB"
                                                CornerRadius="3,0,0,3"
                                                Grid.Column="0"
                                                HorizontalContentAlignment="Center"
                                                IsChecked="{TemplateBinding ColorModel,
                                                                            Converter={StaticResource EnumToBoolConverter},
                                                                            ConverterParameter={x:Static ColorModel.Rgba},
                                                                            Mode=TwoWay}"
                                                Name="RgbRadioButton"
                                                Theme="{DynamicResource ColorViewRadioButton}"
                                                VerticalContentAlignment="Center" />
                                            <RadioButton
                                                Content="HSV"
                                                CornerRadius="0,3,3,0"
                                                Grid.Column="1"
                                                HorizontalContentAlignment="Center"
                                                IsChecked="{TemplateBinding ColorModel,
                                                                            Converter={StaticResource EnumToBoolConverter},
                                                                            ConverterParameter={x:Static ColorModel.Hsva},
                                                                            Mode=TwoWay}"
                                                Name="HsvRadioButton"
                                                Theme="{DynamicResource ColorViewRadioButton}"
                                                VerticalContentAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <TextBox
                                        AutomationProperties.Name="Hexadecimal Color"
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        InnerLeftContent="#"
                                        IsVisible="{TemplateBinding IsHexInputVisible}"
                                        MaxLength="8"
                                        Name="PART_HexTextBox" />
                                </Grid>
                                <!--  Color component editing controls  -->
                                <!--  Component 1 RGB:Red HSV:Hue  -->
                                <NumericUpDown
                                    AllowSpin="True"
                                    Classes="Small"
                                    Grid.Column="0"
                                    Grid.Row="2"
                                    IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                    Margin="0,0,12,0"
                                    Maximum="{Binding Maximum, ElementName=Component1Slider}"
                                    Minimum="{Binding Minimum, ElementName=Component1Slider}"
                                    Name="Component1NumericUpDown"
                                    NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                    ShowButtonSpinner="False"
                                    Value="{Binding Value, ElementName=Component1Slider}"
                                    VerticalAlignment="Center"
                                    Width="70" />
                                <ColorSlider
                                    ColorComponent="Component1"
                                    ColorModel="{TemplateBinding ColorModel,
                                                                 Mode=OneWay}"
                                    Grid.Column="1"
                                    Grid.Row="2"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    IsRoundingEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                    Name="Component1Slider"
                                    Orientation="Horizontal"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                                <!--  Component 2 RGB:Green HSV:Saturation  -->
                                <NumericUpDown
                                    AllowSpin="True"
                                    Classes="Small"
                                    Grid.Column="0"
                                    Grid.Row="3"
                                    IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                    Margin="0,0,12,0"
                                    Maximum="{Binding Maximum, ElementName=Component2Slider}"
                                    Minimum="{Binding Minimum, ElementName=Component2Slider}"
                                    Name="Component2NumericUpDown"
                                    NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                    ShowButtonSpinner="False"
                                    Value="{Binding Value, ElementName=Component2Slider}"
                                    VerticalAlignment="Center"
                                    Width="70" />
                                <ColorSlider
                                    ColorComponent="Component2"
                                    ColorModel="{TemplateBinding ColorModel,
                                                                 Mode=OneWay}"
                                    Grid.Column="1"
                                    Grid.Row="3"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    IsRoundingEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                    Name="Component2Slider"
                                    Orientation="Horizontal"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                                <!--  Component 3 RGB:Blue HSV:Value  -->
                                <NumericUpDown
                                    AllowSpin="True"
                                    Classes="Small"
                                    Grid.Column="0"
                                    Grid.Row="4"
                                    IsVisible="{TemplateBinding IsComponentTextInputVisible}"
                                    Margin="0,0,12,0"
                                    Maximum="{Binding Maximum, ElementName=Component3Slider}"
                                    Minimum="{Binding Minimum, ElementName=Component3Slider}"
                                    Name="Component3NumericUpDown"
                                    NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                    ShowButtonSpinner="False"
                                    Value="{Binding Value, ElementName=Component3Slider}"
                                    VerticalAlignment="Center"
                                    Width="70" />
                                <ColorSlider
                                    ColorComponent="Component3"
                                    ColorModel="{TemplateBinding ColorModel,
                                                                 Mode=OneWay}"
                                    Grid.Column="1"
                                    Grid.Row="4"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    IsRoundingEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    IsVisible="{TemplateBinding IsComponentSliderVisible}"
                                    Name="Component3Slider"
                                    Orientation="Horizontal"
                                    TickFrequency="1"
                                    VerticalAlignment="Center" />
                                <!--  Alpha Component  -->
                                <NumericUpDown
                                    AllowSpin="True"
                                    Classes="Small"
                                    Grid.Column="0"
                                    Grid.Row="5"
                                    IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                    Margin="0,0,12,0"
                                    Maximum="{Binding Maximum, ElementName=AlphaComponentSlider}"
                                    Minimum="{Binding Minimum, ElementName=AlphaComponentSlider}"
                                    Name="AlphaComponentNumericUpDown"
                                    NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                                    ShowButtonSpinner="False"
                                    Value="{Binding Value, ElementName=AlphaComponentSlider}"
                                    VerticalAlignment="Center"
                                    Width="70">
                                    <NumericUpDown.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="IsAlphaVisible"
                                                     RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="IsComponentTextInputVisible"
                                                     RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </NumericUpDown.IsVisible>
                                </NumericUpDown>
                                <ColorSlider
                                    ColorComponent="Alpha"
                                    ColorModel="{TemplateBinding ColorModel,
                                                                 Mode=OneWay}"
                                    Grid.Column="1"
                                    Grid.Row="5"
                                    HorizontalAlignment="Stretch"
                                    HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    IsEnabled="{TemplateBinding IsAlphaEnabled}"
                                    IsRoundingEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    Name="AlphaComponentSlider"
                                    Orientation="Horizontal"
                                    TickFrequency="1"
                                    VerticalAlignment="Center">
                                    <ColorSlider.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="IsAlphaVisible"
                                                     RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="IsComponentSliderVisible"
                                                     RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </ColorSlider.IsVisible>
                                </ColorSlider>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <!--  Previewer  -->
                    <!--  Note that top/bottom margins have -5 to remove for drop shadow padding  -->
                    <ColorPreviewer
                        Grid.Row="1"
                        HsvColor="{Binding HsvColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                        IsAccentColorsVisible="{TemplateBinding IsAccentColorsVisible}"
                        IsVisible="{TemplateBinding IsColorPreviewVisible}"
                        Margin="12,-5,12,7" />
                </Grid>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[ColorModel=Rgba]">
            <Style Selector="^ /template/ NumericUpDown#Component1NumericUpDown">
                <Setter Property="Tag" Value="R" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#Component2NumericUpDown">
                <Setter Property="Tag" Value="G" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#Component3NumericUpDown">
                <Setter Property="Tag" Value="B" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#AlphaComponentNumericUpDown">
                <Setter Property="Tag" Value="A" />
            </Style>
        </Style>
        <Style Selector="^[ColorModel=Hsva]">
            <Style Selector="^ /template/ NumericUpDown#Component1NumericUpDown">
                <Setter Property="Tag" Value="H" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#Component2NumericUpDown">
                <Setter Property="Tag" Value="S" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#Component3NumericUpDown">
                <Setter Property="Tag" Value="V" />
            </Style>
            <Style Selector="^ /template/ NumericUpDown#AlphaComponentNumericUpDown">
                <Setter Property="Tag" Value="A" />
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme TargetType="ColorView" x:Key="SimpleColorView">
        <Setter Property="Width" Value="280" />
        <Setter Property="CornerRadius" Value="{DynamicResource YikCornerRadius}" />
        <Setter Property="ColorSpectrumComponents" Value="SaturationValue" />
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ColorView}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="280" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--  Spectrum Tab  -->
                    <Border
                        ClipToBounds="True"
                        CornerRadius="8 8 0 0"
                        Grid.Row="0">
                        <ColorSpectrum
                            Components="{TemplateBinding ColorSpectrumComponents}"
                            HorizontalAlignment="Stretch"
                            HsvColor="{TemplateBinding HsvColor,
                                                       Mode=TwoWay}"
                            MaxHue="{TemplateBinding MaxHue}"
                            MaxSaturation="{TemplateBinding MaxSaturation}"
                            MaxValue="{TemplateBinding MaxValue}"
                            MinHue="{TemplateBinding MinHue}"
                            MinSaturation="{TemplateBinding MinSaturation}"
                            MinValue="{TemplateBinding MinValue}"
                            Name="ColorSpectrum"
                            Shape="{TemplateBinding ColorSpectrumShape}"
                            VerticalAlignment="Stretch" />
                    </Border>
                    <ColorSlider
                        AutomationProperties.Name="Third Component"
                        ColorComponent="{Binding #ColorSpectrum.ThirdComponent}"
                        ColorModel="Hsva"
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        HsvColor="{TemplateBinding HsvColor,
                                                   Mode=TwoWay}"
                        IsVisible="{TemplateBinding IsColorSpectrumSliderVisible}"
                        Name="ColorSpectrumThirdComponentSlider"
                        Orientation="Horizontal"
                        VerticalAlignment="Center" />

                    <ColorSlider
                        AutomationProperties.Name="Alpha Component"
                        ColorComponent="Alpha"
                        ColorModel="Hsva"
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        HsvColor="{TemplateBinding HsvColor,
                                                   Mode=TwoWay}"
                        IsEnabled="{TemplateBinding IsAlphaEnabled}"
                        IsRoundingEnabled="True"
                        IsSnapToTickEnabled="True"
                        IsVisible="{TemplateBinding IsAlphaVisible}"
                        Orientation="Horizontal"
                        TickFrequency="1"
                        VerticalAlignment="Center"
                        x:Name="ColorSpectrumAlphaSlider" />
                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Stretch"
                        Margin="0,8,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Border
                            Background="{TemplateBinding Color,
                                                         Converter={StaticResource ToBrushConverter}}"
                            CornerRadius="4"
                            Height="20"
                            Width="20" />
                        <Panel
                            HorizontalAlignment="Stretch"
                            Margin="4,0,0,0"
                            Name="PART_TextBoxPanel"
                            VerticalAlignment="Center"
                            Width="106">
                            <TextBox
                                Classes="Small"
                                InnerLeftContent="#"
                                IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Hex}"
                                MaxLength="8"
                                Name="PART_HexTextBox"
                                Text="{TemplateBinding Color,
                                                       Converter={StaticResource ColorToHexConverter},
                                                       Mode=TwoWay}" />
                            <TextBox
                                Classes="Small"
                                IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Rgba}"
                                Name="PART_RgbaTextBox"
                                Text="{TemplateBinding Color,
                                                       Converter={StaticResource ColorToTextConverter},
                                                       Mode=TwoWay}" />
                            <TextBox
                                Classes="Small"
                                IsVisible="{Binding #ColorModelComboBox.SelectedValue, Converter={StaticResource ToColorModel}, ConverterParameter=Hsva}"
                                Name="PART_HsvaTextBox"
                                Text="{TemplateBinding HsvColor,
                                                       Converter={StaticResource HsvColorToTextConverter},
                                                       Mode=TwoWay}" />
                        </Panel>

                        <NumericUpDown
                            AllowSpin="True"
                            Classes="Small"
                            HorizontalAlignment="Right"
                            InnerRightContent="%"
                            IsEnabled="{TemplateBinding IsAlphaEnabled}"
                            IsVisible="{TemplateBinding IsAlphaVisible}"
                            Maximum="{Binding #ColorSpectrumAlphaSlider.Maximum}"
                            Minimum="{Binding #ColorSpectrumAlphaSlider.Minimum}"
                            Name="AlphaComponentNumericUpDown"
                            NumberFormat="{StaticResource ColorViewComponentNumberFormat}"
                            ShowButtonSpinner="False"
                            Value="{Binding #ColorSpectrumAlphaSlider.Value}"
                            VerticalAlignment="Center"
                            Width="70" />
                        <ComboBox
                            Classes="Small"
                            Name="ColorModelComboBox"
                            SelectedValue="Hex"
                            VerticalAlignment="Center"
                            Width="80">
                            Hex
                            <ColorModel>Rgba</ColorModel>
                            <ColorModel>Hsva</ColorModel>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[IsAlphaVisible=False] /template/ Panel#PART_TextBoxPanel">
            <Setter Property="Width" Value="176" />
        </Style>
    </ControlTheme>
</ResourceDictionary>