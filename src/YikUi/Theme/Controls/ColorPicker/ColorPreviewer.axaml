<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="using:Avalonia.Controls.Converters"
    xmlns:pc="using:Avalonia.Controls.Primitives.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <pc:AccentColorConverter x:Key="AccentColorConverter" />
    <converters:CornerRadiusFilterConverter Filter="TopLeft, BottomLeft" x:Key="LeftCornerRadiusFilterConverter" />
    <converters:CornerRadiusFilterConverter Filter="TopRight, BottomRight" x:Key="RightCornerRadiusFilterConverter" />
    <converters:ToBrushConverter x:Key="ToBrushConverter" />

    <x:Double x:Key="ColorPreviewerAccentSectionWidth">80</x:Double>
    <x:Double x:Key="ColorPreviewerAccentSectionHeight">20</x:Double>
    <x:Double x:Key="ColorPreviewerHeight">48</x:Double>
    <CornerRadius x:Key="ColorPreviewerCornerRadius">3</CornerRadius>

    <VisualBrush
        DestinationRect="0,0,8,8"
        Stretch="Uniform"
        TileMode="Tile"
        x:Key="ColorControlCheckeredBackgroundBrush">
        <VisualBrush.Visual>
            <Image Height="8" Width="8">
                <Image.Source>
                    <DrawingImage>
                        <DrawingImage.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="Transparent" Geometry="M0,0 L2,0 2,2, 0,2Z" />
                                <GeometryDrawing Brush="#19808080" Geometry="M0,1 L2,1 2,2, 1,2 1,0 0,0Z" />
                            </DrawingGroup>
                        </DrawingImage.Drawing>
                    </DrawingImage>
                </Image.Source>
            </Image>
        </VisualBrush.Visual>
    </VisualBrush>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <BoxShadows x:Key="ColorPreviewerMainBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <BoxShadows x:Key="ColorPreviewerMainBoxShadow">inset 0 0 0 1 #1AFFFFFF, 0 4 14 #40000000</BoxShadows>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="ColorPreviewer" x:Key="{x:Type ColorPreviewer}">
        <Setter Property="Height" Value="{DynamicResource ColorPreviewerHeight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource ColorPreviewerCornerRadius}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="{x:Type ColorPreviewer}">
                <Panel>
                    <!--  Preview color with accents to the left and right  -->
                    <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{TemplateBinding IsAccentColorsVisible}">
                        <!--  Left accent colors  -->
                        <Grid
                            ColumnDefinitions="*,*"
                            Grid.Column="0"
                            Height="{DynamicResource ColorPreviewerAccentSectionHeight}"
                            VerticalAlignment="Center"
                            Width="{DynamicResource ColorPreviewerAccentSectionWidth}">
                            <Border
                                Background="{DynamicResource ColorControlCheckeredBackgroundBrush}"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                            <Border
                                Background="{TemplateBinding HsvColor,
                                                             Converter={StaticResource AccentColorConverter},
                                                             ConverterParameter='-2'}"
                                CornerRadius="{TemplateBinding CornerRadius,
                                                               Converter={StaticResource LeftCornerRadiusFilterConverter}}"
                                Grid.Column="0"
                                Name="PART_AccentDecrement2Border"
                                Tag="-2" />
                            <Border
                                Background="{TemplateBinding HsvColor,
                                                             Converter={StaticResource AccentColorConverter},
                                                             ConverterParameter='-1'}"
                                Grid.Column="1"
                                Name="PART_AccentDecrement1Border"
                                Tag="-1" />
                        </Grid>
                        <!--  Right accent colors  -->
                        <Grid
                            ColumnDefinitions="*,*"
                            Grid.Column="2"
                            Height="{DynamicResource ColorPreviewerAccentSectionHeight}"
                            VerticalAlignment="Center"
                            Width="{DynamicResource ColorPreviewerAccentSectionWidth}">
                            <Border
                                Background="{DynamicResource ColorControlCheckeredBackgroundBrush}"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                            <Border
                                Background="{TemplateBinding HsvColor,
                                                             Converter={StaticResource AccentColorConverter},
                                                             ConverterParameter='1'}"
                                Grid.Column="0"
                                Name="PART_AccentIncrement1Border"
                                Tag="1" />
                            <Border
                                Background="{TemplateBinding HsvColor,
                                                             Converter={StaticResource AccentColorConverter},
                                                             ConverterParameter='2'}"
                                CornerRadius="{TemplateBinding CornerRadius,
                                                               Converter={StaticResource RightCornerRadiusFilterConverter}}"
                                Grid.Column="1"
                                Name="PART_AccentIncrement2Border"
                                Tag="2" />
                        </Grid>
                        <!--  Preview color: Must be last for drop shadow Z-index  -->
                        <Border
                            BoxShadow="{DynamicResource ColorPreviewerMainBoxShadow}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,8"
                            VerticalAlignment="Stretch">
                            <Panel>
                                <Border Background="{DynamicResource ColorControlCheckeredBackgroundBrush}" CornerRadius="{TemplateBinding CornerRadius}" />
                                <Border
                                    Background="{TemplateBinding HsvColor,
                                                                 Converter={StaticResource ToBrushConverter}}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />
                            </Panel>
                        </Border>
                    </Grid>
                    <!--  Only preview color  -->
                    <Border
                        CornerRadius="{TemplateBinding CornerRadius}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{TemplateBinding IsAccentColorsVisible,
                                                    Converter={x:Static BoolConverters.Not}}"
                        VerticalAlignment="Stretch">
                        <Panel>
                            <Border Background="{DynamicResource ColorControlCheckeredBackgroundBrush}" CornerRadius="{TemplateBinding CornerRadius}" />
                            <Border
                                Background="{TemplateBinding HsvColor,
                                                             Converter={StaticResource ToBrushConverter}}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Panel>
                    </Border>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>