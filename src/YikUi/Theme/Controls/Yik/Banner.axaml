<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Design.PreviewWith>
        <HeaderedContentControl Theme="{StaticResource GroupBox}" Width="500">
            <yik:Banner
                CanClose="True"
                Classes="Bordered"
                Content="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat"
                Header="Title"
                Type="Warning" />
        </HeaderedContentControl>
    </Design.PreviewWith>
    <Thickness x:Key="BannerBorderPadding">12</Thickness>
    <Thickness x:Key="BannerBorderThickness">1</Thickness>
    <Thickness x:Key="BannerIconMargin">0 0 12 0</Thickness>
    <Thickness x:Key="BannerCloseButtonMargin">12 0 0 0</Thickness>
    <x:Double x:Key="BannerTitleFontSize">18</x:Double>
    <CornerRadius x:Key="BannerCornerRadius">3</CornerRadius>
    <FontWeight x:Key="TextBlockTitleFontWeight">600</FontWeight>

    <StreamGeometry x:Key="IconInfoCircle">
        M12 23a11 11 0 1 0 0-22 11 11 0 0 0 0 22Zm2-16a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm-5 3.75c0-.41.34-.75.75-.75h2.75a1 1 0 0 1 1 1v5.5h.75a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1 0-1.5h.75v-5h-.75a.75.75 0 0 1-.75-.75Z
    </StreamGeometry>
    <StreamGeometry x:Key="IconTickCircle">
        M12 23a11 11 0 1 0 0-22 11 11 0 0 0 0 22Zm5.88-13.18-6.2 7.6a1.5 1.5 0 0 1-2.37 0l-3.5-4a1.5 1.5 0 1 1 2.37-1.84l2.3 2.46L15.5 8a1.5 1.5 0 1 1 2.38 1.82Z
    </StreamGeometry>
    <StreamGeometry x:Key="IconAlertTriangle">
        m10.23 2.4-8.7 16.67A2 2 0 0 0 3.3 22h17.4a2 2 0 0 0 1.77-2.93L13.77 2.4a2 2 0 0 0-3.54 0ZM13.14 14a1.15 1.15 0 0 1-2.28 0l-.58-4.03a1.73 1.73 0 1 1 3.44 0l-.58 4.03Zm.36 4.49a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z
    </StreamGeometry>
    <StreamGeometry x:Key="IconAlertCircle">
        M23 12a11 11 0 1 1-22 0 11 11 0 0 1 22 0Zm-9.5 5.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0ZM12 5a1.9 1.9 0 0 0-1.89 2l.3 5.5a1.59 1.59 0 0 0 3.17 0l.3-5.5c.07-1.09-.8-2-1.88-2Z
    </StreamGeometry>
    <!--  Icon geometries  -->
    <StaticResource ResourceKey="IconInfoCircle" x:Key="BannerInformationIconGeometry" />
    <StaticResource ResourceKey="IconTickCircle" x:Key="BannerSuccessIconGeometry" />
    <StaticResource ResourceKey="IconAlertTriangle" x:Key="BannerWarningIconGeometry" />
    <StaticResource ResourceKey="IconAlertCircle" x:Key="BannerErrorIconGeometry" />

    <!--  Theme dictionaries （颜色已全部改为直接使用十六进制值）  -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush Color="Transparent" x:Key="BannerBorderBrush" />

            <!--  信息提示  -->
            <SolidColorBrush Color="#EAF5FF" x:Key="BannerInformationBackground" />
            <SolidColorBrush Color="#0064FA" x:Key="BannerInformationBorderBrush" />

            <!--  成功  -->
            <SolidColorBrush Color="#ECF7EC" x:Key="BannerSuccessBackground" />
            <SolidColorBrush Color="#3BB346" x:Key="BannerSuccessBorderBrush" />

            <!--  警告  -->
            <SolidColorBrush Color="#FFF8EA" x:Key="BannerWarningBackground" />
            <SolidColorBrush Color="#FC8800" x:Key="BannerWarningBorderBrush" />

            <!--  错误/危险  -->
            <SolidColorBrush Color="#FEF2ED" x:Key="BannerErrorBackground" />
            <SolidColorBrush Color="#F93920" x:Key="BannerErrorBorderBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="Transparent" x:Key="BannerBorderBrush" />

            <!--  信息提示  -->
            <SolidColorBrush
                Color="#54A9FF"
                Opacity="0.2"
                x:Key="BannerInformationBackground" />
            <SolidColorBrush Color="#54A9FF" x:Key="BannerInformationBorderBrush" />

            <!--  成功  -->
            <SolidColorBrush
                Color="#5DC264"
                Opacity="0.2"
                x:Key="BannerSuccessBackground" />
            <SolidColorBrush Color="#5DC264" x:Key="BannerSuccessBorderBrush" />

            <!--  警告  -->
            <SolidColorBrush
                Color="#FFAE43"
                Opacity="0.2"
                x:Key="BannerWarningBackground" />
            <SolidColorBrush Color="#FFAE43" x:Key="BannerWarningBorderBrush" />

            <!--  错误/危险  -->
            <SolidColorBrush
                Color="#FC725A"
                Opacity="0.2"
                x:Key="BannerErrorBackground" />
            <SolidColorBrush Color="#FC725A" x:Key="BannerErrorBorderBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="yik:Banner" x:Key="{x:Type yik:Banner}">
        <Setter Property="Padding" Value="{DynamicResource BannerBorderPadding}" />
        <Setter Property="BorderThickness" Value="{DynamicResource BannerBorderThickness}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BannerBorderBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:Banner">
                <Border
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Name="PART_Container"
                    Padding="{TemplateBinding Padding}">
                    <Grid ColumnDefinitions="*, Auto">
                        <Grid
                            ColumnDefinitions="Auto, *"
                            Grid.Column="0"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
                            <!--  Icon Area  -->
                            <Panel
                                Grid.Column="0"
                                IsVisible="{TemplateBinding ShowIcon}"
                                Margin="{DynamicResource BannerIconMargin}"
                                VerticalAlignment="Top">
                                <ContentPresenter Content="{TemplateBinding Icon}" />
                                <PathIcon
                                    Classes="Large"
                                    IsVisible="{TemplateBinding Icon,
                                                                Converter={x:Static ObjectConverters.IsNull}}"
                                    Name="PART_BuildInIcon"
                                    Theme="{DynamicResource InnerPathIcon}" />
                            </Panel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <ContentPresenter
                                    Content="{TemplateBinding Header}"
                                    ContentTemplate="{TemplateBinding HeaderTemplate}"
                                    TextElement.FontSize="{DynamicResource BannerTitleFontSize}"
                                    TextElement.FontWeight="{DynamicResource TextBlockTitleFontWeight}"
                                    TextTrimming="CharacterEllipsis" />
                                <ContentPresenter
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            IsVisible="{TemplateBinding CanClose}"
                            Margin="{DynamicResource BannerCloseButtonMargin}"
                            Name="{x:Static yik:Banner.PART_CloseButton}"
                            Theme="{DynamicResource OverlayCloseButton}"
                            VerticalAlignment="Top" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^.Bordered">
            <Setter Property="CornerRadius" Value="{DynamicResource YikCornerRadius}" />
        </Style>
        <Style Selector="^[Type=Information]">
            <Style Selector="^.Bordered /template/ Border#PART_Container">
                <Setter Property="BorderBrush" Value="{DynamicResource BannerInformationBorderBrush}" />
            </Style>
            <Style Selector="^ /template/ Border#PART_Container">
                <Setter Property="Background" Value="{DynamicResource BannerInformationBackground}" />
            </Style>
            <Style Selector="^ /template/ PathIcon#PART_BuildInIcon">
                <Setter Property="Data" Value="{DynamicResource BannerInformationIconGeometry}" />
                <Setter Property="Foreground" Value="{DynamicResource BannerInformationBorderBrush}" />
            </Style>
        </Style>
        <Style Selector="^[Type=Success]">
            <Style Selector="^.Bordered /template/ Border#PART_Container">
                <Setter Property="BorderBrush" Value="{DynamicResource BannerSuccessBorderBrush}" />
            </Style>
            <Style Selector="^ /template/ Border#PART_Container">
                <Setter Property="Background" Value="{DynamicResource BannerSuccessBackground}" />
            </Style>
            <Style Selector="^ /template/ PathIcon#PART_BuildInIcon">
                <Setter Property="Data" Value="{DynamicResource BannerSuccessIconGeometry}" />
                <Setter Property="Foreground" Value="{DynamicResource BannerSuccessBorderBrush}" />
            </Style>
        </Style>
        <Style Selector="^[Type=Warning]">
            <Style Selector="^.Bordered /template/ Border#PART_Container">
                <Setter Property="BorderBrush" Value="{DynamicResource BannerWarningBorderBrush}" />
            </Style>
            <Style Selector="^ /template/ Border#PART_Container">
                <Setter Property="Background" Value="{DynamicResource BannerWarningBackground}" />
            </Style>
            <Style Selector="^ /template/ PathIcon#PART_BuildInIcon">
                <Setter Property="Data" Value="{DynamicResource BannerWarningIconGeometry}" />
                <Setter Property="Foreground" Value="{DynamicResource BannerWarningBorderBrush}" />
            </Style>
        </Style>
        <Style Selector="^[Type=Error]">
            <Style Selector="^.Bordered /template/ Border#PART_Container">
                <Setter Property="BorderBrush" Value="{DynamicResource BannerErrorBorderBrush}" />
            </Style>
            <Style Selector="^ /template/ Border#PART_Container">
                <Setter Property="Background" Value="{DynamicResource BannerErrorBackground}" />
            </Style>
            <Style Selector="^ /template/ PathIcon#PART_BuildInIcon">
                <Setter Property="Data" Value="{DynamicResource BannerErrorIconGeometry}" />
                <Setter Property="Foreground" Value="{DynamicResource BannerErrorBorderBrush}" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>