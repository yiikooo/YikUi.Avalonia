<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">

    <x:Double x:Key="ResizerThumbWidth">6</x:Double>
    <x:Double x:Key="ResizerThumbHeight">6</x:Double>

    <ControlTheme TargetType="yik:WindowResizerThumb" x:Key="{x:Type yik:WindowResizerThumb}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:WindowResizerThumb">
                <yik:PureRectangle
                    Background="{TemplateBinding Background}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="yik:DialogResizerThumb" x:Key="{x:Type yik:DialogResizerThumb}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:DialogResizerThumb">
                <Panel>
                    <yik:PureRectangle
                        Background="{TemplateBinding Background}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="yik:DialogResizer" x:Key="{x:Type yik:DialogResizer}">
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:WindowResizer">
                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto">
                    <yik:DialogResizerThumb
                        Cursor="TopLeftCorner"
                        Grid.Column="0"
                        Grid.Row="0"
                        Name="{x:Static yik:DialogResizer.PART_TopLeft}"
                        ResizeDirection="TopLeft" />
                    <yik:DialogResizerThumb
                        Cursor="TopSide"
                        Grid.Column="1"
                        Grid.Row="0"
                        Height="{DynamicResource ResizerThumbHeight}"
                        Name="{x:Static yik:DialogResizer.PART_Top}"
                        ResizeDirection="Top" />
                    <yik:DialogResizerThumb
                        Cursor="TopRightCorner"
                        Grid.Column="2"
                        Grid.Row="0"
                        Name="{x:Static yik:DialogResizer.PART_TopRight}"
                        ResizeDirection="TopRight" />
                    <yik:DialogResizerThumb
                        Cursor="LeftSide"
                        Grid.Column="0"
                        Grid.Row="1"
                        Name="{x:Static yik:DialogResizer.PART_Left}"
                        ResizeDirection="Left"
                        Width="{DynamicResource ResizerThumbWidth}" />
                    <yik:DialogResizerThumb
                        Cursor="RightSide"
                        Grid.Column="2"
                        Grid.Row="1"
                        Name="{x:Static yik:DialogResizer.PART_Right}"
                        ResizeDirection="Right"
                        Width="{DynamicResource ResizerThumbWidth}" />
                    <yik:DialogResizerThumb
                        Cursor="BottomLeftCorner"
                        Grid.Column="0"
                        Grid.Row="2"
                        Name="{x:Static yik:DialogResizer.PART_BottomLeft}"
                        ResizeDirection="BottomLeft" />
                    <yik:DialogResizerThumb
                        Cursor="BottomSide"
                        Grid.Column="1"
                        Grid.Row="2"
                        Height="{DynamicResource ResizerThumbHeight}"
                        Name="{x:Static yik:DialogResizer.PART_Bottom}"
                        ResizeDirection="Bottom" />
                    <yik:DialogResizerThumb
                        Cursor="BottomRightCorner"
                        Grid.Column="2"
                        Grid.Row="2"
                        Name="{x:Static yik:DialogResizer.PART_BottomRight}"
                        ResizeDirection="BottomRight" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="yik:WindowResizer" x:Key="{x:Type yik:WindowResizer}">
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:WindowResizer">
                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto">
                    <yik:WindowResizerThumb
                        Cursor="TopLeftCorner"
                        Grid.Column="0"
                        Grid.Row="0"
                        ResizeDirection="TopLeft" />
                    <yik:WindowResizerThumb
                        Cursor="TopSide"
                        Grid.Column="1"
                        Grid.Row="0"
                        Height="{DynamicResource ResizerThumbHeight}"
                        ResizeDirection="Top" />
                    <yik:WindowResizerThumb
                        Cursor="TopRightCorner"
                        Grid.Column="2"
                        Grid.Row="0"
                        ResizeDirection="TopRight" />
                    <yik:WindowResizerThumb
                        Cursor="LeftSide"
                        Grid.Column="0"
                        Grid.Row="1"
                        ResizeDirection="Left"
                        Width="{DynamicResource ResizerThumbWidth}" />
                    <yik:WindowResizerThumb
                        Cursor="RightSide"
                        Grid.Column="2"
                        Grid.Row="1"
                        ResizeDirection="Right"
                        Width="{DynamicResource ResizerThumbWidth}" />
                    <yik:WindowResizerThumb
                        Cursor="BottomLeftCorner"
                        Grid.Column="0"
                        Grid.Row="2"
                        ResizeDirection="BottomLeft" />
                    <yik:WindowResizerThumb
                        Cursor="BottomSide"
                        Grid.Column="1"
                        Grid.Row="2"
                        Height="{DynamicResource ResizerThumbHeight}"
                        ResizeDirection="Bottom" />
                    <yik:WindowResizerThumb
                        Cursor="BottomRightCorner"
                        Grid.Column="2"
                        Grid.Row="2"
                        ResizeDirection="BottomRight" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>