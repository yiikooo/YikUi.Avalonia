<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <ControlTheme TargetType="yik:DisableContainer" x:Key="{x:Type yik:DisableContainer}">
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:DisableContainer">
                <Panel>
                    <ContentPresenter Content="{TemplateBinding Content}" />
                    <yik:PureRectangle
                        Background="Transparent"
                        Cursor="No"
                        IsVisible="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content.IsEnabled, Converter={x:Static BoolConverters.Not}}"
                        ToolTip.Tip="{TemplateBinding DisabledTip}" />
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>