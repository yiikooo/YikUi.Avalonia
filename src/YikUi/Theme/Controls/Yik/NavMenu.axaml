<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="NavigationMenuItemExpandIconForeground">#1C1F23</Color>
            <SolidColorBrush
                Color="#1C1F23"
                Opacity="0.08"
                x:Key="NavigationMenuItemSeparatorBorderForeground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.05"
                x:Key="ListBoxItemPointeroverBackground" />
            <SolidColorBrush
                Color="#2E3238"
                Opacity="0.09"
                x:Key="ListBoxItemSelectedBackground" />
            <Color x:Key="TextBlockQuaternaryForeground">#636363</Color>
            <Color x:Key="ListBoxItemPointeroverForeground">#1C1F23</Color>
            <!-- <Color x:Key="ListBoxItemPointeroverBackground">#F9F9F9</Color> -->
            <Color x:Key="ListBoxItemSelectedForeground">#1C1F23</Color>
            <!-- <Color x:Key="ListBoxItemSelectedBackground">#EAF5FF</Color> -->
            <Color x:Key="ListBoxItemSelectedPointeroverBackground">#CBE7FE</Color>
            <Color x:Key="MenuFlyoutBackground">#FFFFFF</Color>
            <Color x:Key="MenuFlyoutBorderBrush">#E6E8EA</Color>
            <BoxShadows x:Key="MenuFlyoutBorderBoxShadow">0 0 1 #4A000000, 0 4 14 #1A000000</BoxShadows>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="NavigationMenuItemExpandIconForeground">#F9F9F9</Color>
            <SolidColorBrush
                Color="White"
                Opacity="0.08"
                x:Key="NavigationMenuItemSeparatorBorderForeground" />
            <Color x:Key="TextBlockQuaternaryForeground">#F9F9F9</Color>
            <Color x:Key="ListBoxItemPointeroverForeground">#F9F9F9</Color>
            <Color x:Key="ListBoxItemPointeroverBackground">#232429</Color>
            <Color x:Key="ListBoxItemSelectedForeground">#F9F9F9</Color>
            <Color x:Key="ListBoxItemSelectedBackground">#35363C</Color>
            <Color x:Key="ListBoxItemSelectedPointeroverBackground">#3E3F45</Color>
            <Color x:Key="MenuFlyoutBackground">#43444A</Color>
            <Color x:Key="MenuFlyoutBorderBrush">#F9F9F9</Color>
            <BoxShadows x:Key="MenuFlyoutBorderBoxShadow">inset 0 0 0 1 #1AFFFFFF, 0 4 14 #40000000</BoxShadows>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <ControlTheme TargetType="yik:NavMenu" x:Key="{x:Type yik:NavMenu}">
        <Setter Property="Grid.IsSharedSizeScope" Value="True" />
        <Setter Property="SubMenuIndent" Value="24" />
        <Setter Property="Template">
            <ControlTemplate TargetType="yik:NavMenu">
                <Grid RowDefinitions="Auto, Auto, *, Auto">
                    <ContentPresenter Content="{TemplateBinding Header}" />

                    <!--  Search Box at Top  -->
                    <Border
                        Grid.Row="1"
                        IsVisible="{TemplateBinding EnableSearch}"
                        Margin="0,0,6,4"
                        Name="PART_SearchBoxTop">
                        <TextBox
                            Name="PART_SearchBox"
                            PlaceholderText="{TemplateBinding SearchPlaceholderText}"
                            Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <TextBox.InnerRightContent>
                                <PathIcon
                                    Data="F1 M512,512z M0,0z M416,208C416,253.9,401.1,296.3,376,330.7L502.6,457.4C515.1,469.9 515.1,490.2 502.6,502.7 490.1,515.2 469.8,515.2 457.3,502.7L330.7,376C296.3,401.1 253.9,416 208,416 93.1,416 0,322.9 0,208 0,93.1 93.1,0 208,0 322.9,0 416,93.1 416,208z M208,352A144,144,0,1,0,208,64A144,144,0,1,0,208,352z" />
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </Border>

                    <ScrollViewer
                        AllowAutoHide="True"
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" Name="PART_ItemsPresenter" />
                    </ScrollViewer>

                    <!--  Search Box at Bottom  -->
                    <Border
                        Grid.Row="3"
                        IsVisible="False"
                        Margin="0,4,6,0"
                        Name="PART_SearchBoxBottom">
                        <TextBox PlaceholderText="{TemplateBinding SearchPlaceholderText}"
                                 Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <TextBox.InnerRightContent>
                                <PathIcon
                                    Data="F1 M512,512z M0,0z M416,208C416,253.9,401.1,296.3,376,330.7L502.6,457.4C515.1,469.9 515.1,490.2 502.6,502.7 490.1,515.2 469.8,515.2 457.3,502.7L330.7,376C296.3,401.1 253.9,416 208,416 93.1,416 0,322.9 0,208 0,93.1 93.1,0 208,0 322.9,0 416,93.1 416,208z M208,352A144,144,0,1,0,208,64A144,144,0,1,0,208,352z" />
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </Border>

                    <ContentPresenter
                        Content="{TemplateBinding Footer}"
                        Grid.Row="3"
                        Name="PART_Footer" />
                </Grid>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[SearchPlacement=Top] /template/ Border#PART_SearchBoxTop">
            <Setter Property="IsVisible"
                    Value="{Binding EnableSearch, RelativeSource={RelativeSource TemplatedParent}}" />
        </Style>
        <Style Selector="^[SearchPlacement=Bottom] /template/ Border#PART_SearchBoxTop">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^[SearchPlacement=Bottom] /template/ Border#PART_SearchBoxBottom">
            <Setter Property="IsVisible"
                    Value="{Binding EnableSearch, RelativeSource={RelativeSource TemplatedParent}}" />
        </Style>
        <Style Selector="^[SearchPlacement=Bottom] /template/ ContentPresenter#PART_Footer">
            <Setter Property="Grid.Row" Value="4" />
        </Style>
        <Style Selector="^:not(:horizontal-collapsed)">
            <Setter Property="Width" Value="{Binding $self.ExpandWidth}" />
        </Style>
        <Style Selector="^:horizontal-collapsed">
            <Setter Property="Width" Value="{Binding $self.CollapseWidth}" />
            <Setter Property="Grid.IsSharedSizeScope" Value="False" />
        </Style>
        <Style Selector="^.enable_animation">
            <Setter Property="yik:SizeAnimationHelper.TriggerAvaloniaProperty"
                    Value="{x:Static yik:NavMenu.IsHorizontalCollapsedProperty}" />
            <Setter Property="yik:SizeAnimationHelper.CreateAnimation"
                    Value="{DynamicResource NavMenuWidthAnimationGenerator}" />
            <Setter Property="yik:SizeAnimationHelper.EnableWHAnimation" Value="True" />
        </Style>
        <Style Selector="^.FlatScrollBar">
            <Setter Property="Template">
                <ControlTemplate TargetType="yik:NavMenu">
                    <Grid RowDefinitions="Auto, Auto, *, Auto">
                        <ContentPresenter Content="{TemplateBinding Header}" />
                        <!--  Search Box at Top  -->
                        <Border
                            Grid.Row="1"
                            IsVisible="{TemplateBinding EnableSearch}"
                            Margin="0,0,6,4"
                            Name="PART_SearchBoxTop">
                            <TextBox
                                Name="PART_SearchBox"
                                PlaceholderText="{TemplateBinding SearchPlaceholderText}"
                                Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <TextBox.InnerRightContent>
                                    <PathIcon
                                        Data="F1 M512,512z M0,0z M416,208C416,253.9,401.1,296.3,376,330.7L502.6,457.4C515.1,469.9 515.1,490.2 502.6,502.7 490.1,515.2 469.8,515.2 457.3,502.7L330.7,376C296.3,401.1 253.9,416 208,416 93.1,416 0,322.9 0,208 0,93.1 93.1,0 208,0 322.9,0 416,93.1 416,208z M208,352A144,144,0,1,0,208,64A144,144,0,1,0,208,352z"
                                        Height="14"
                                        Width="14" />
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </Border>
                        <ScrollViewer
                            AllowAutoHide="True"
                            Classes="Flat"
                            Grid.Row="2"
                            HorizontalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" Name="PART_ItemsPresenter" />
                        </ScrollViewer>
                        <!--  Search Box at Bottom  -->
                        <Border
                            Grid.Row="3"
                            IsVisible="False"
                            Margin="0,4,6,0"
                            Name="PART_SearchBoxBottom">
                            <TextBox PlaceholderText="{TemplateBinding SearchPlaceholderText}"
                                     Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <TextBox.InnerRightContent>
                                    <PathIcon
                                        Data="F1 M512,512z M0,0z M416,208C416,253.9,401.1,296.3,376,330.7L502.6,457.4C515.1,469.9 515.1,490.2 502.6,502.7 490.1,515.2 469.8,515.2 457.3,502.7L330.7,376C296.3,401.1 253.9,416 208,416 93.1,416 0,322.9 0,208 0,93.1 93.1,0 208,0 322.9,0 416,93.1 416,208z M208,352A144,144,0,1,0,208,64A144,144,0,1,0,208,352z" />
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </Border>
                        <ContentPresenter
                            Content="{TemplateBinding Footer}"
                            Grid.Row="3"
                            Name="PART_Footer" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
    </ControlTheme>

    <ControlTemplate TargetType="yik:NavMenuItem" x:Key="DefaultNavMenuItemTemplate">
        <Grid Background="Transparent" RowDefinitions="Auto, *">
            <Border
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                CornerRadius="{DynamicResource YikCornerRadius}"
                Cursor="Hand"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                MinHeight="32"
                Name="PART_Border">
                <Border.Margin>
                    <MultiBinding Converter="{yik:NavMenuMarginConverter}">
                        <Binding Path="SubMenuIndent" RelativeSource="{RelativeSource TemplatedParent}" />
                        <Binding Path="Level" RelativeSource="{RelativeSource TemplatedParent}" />
                        <Binding Path="IsHorizontalCollapsed" RelativeSource="{RelativeSource TemplatedParent}" />
                    </MultiBinding>
                </Border.Margin>
                <Grid
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    Name="PART_RootGrid"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition SharedSizeGroup="Icon" Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition SharedSizeGroup="Expander" Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Rectangle
                        Fill="{DynamicResource SystemAccentColor}"
                        Height="16"
                        HorizontalAlignment="Left"
                        IsVisible="True"
                        Margin="0,4,-2,4"
                        Name="SelectionIndicator"
                        Opacity="0"
                        RadiusX="2"
                        RadiusY="2"
                        RenderTransform="scaleY(0)"
                        UseLayoutRounding="False"
                        VerticalAlignment="Center"
                        Width="3">
                        <Rectangle.Transitions>
                            <Transitions>
                                <TransformOperationsTransition
                                    Duration="00:00:00.167"
                                    Easing="0,0 0,1"
                                    Property="RenderTransform" />
                                <DoubleTransition
                                    Duration="00:00:00.167"
                                    Easing="0,0 0,1"
                                    Property="Opacity" />
                            </Transitions>
                        </Rectangle.Transitions>
                    </Rectangle>

                    <ContentPresenter
                        Background="Transparent"
                        Content="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}"
                        ContentTemplate="{Binding IconTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Name="PART_IconPresenter"
                        Padding="8" />
                    <ContentPresenter
                        Background="Transparent"
                        Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                        ContentTemplate="{Binding HeaderTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                        Grid.Column="2"
                        Name="PART_HeaderPresenter"
                        Padding="0,8,8,8" />

                    <PathIcon
                        Data="F1 M640,640z M0,0z M297.4,438.6C309.9,451.1,330.2,451.1,342.7,438.6L502.7,278.6C515.2,266.1 515.2,245.8 502.7,233.3 490.2,220.8 469.9,220.8 457.4,233.3L320,370.7 182.6,233.4C170.1,220.9 149.8,220.9 137.3,233.4 124.8,245.9 124.8,266.2 137.3,278.7L297.3,438.7z"
                        Foreground="{DynamicResource ForegroundColor}"
                        Grid.Column="3"
                        Margin="4,0,10,0"
                        Name="PART_ExpanderIcon"
                        Width="16">
                        <PathIcon.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Duration="0.1" Property="RenderTransform" />
                            </Transitions>
                        </PathIcon.Transitions>
                    </PathIcon>

                    <Popup
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        IsLightDismissEnabled="True"
                        Name="PART_Popup"
                        Placement="RightEdgeAlignedTop"
                        PlacementTarget="{Binding #PART_Border}">
                        <Border
                            Background="{DynamicResource MenuFlyoutBackground}"
                            BorderBrush="{DynamicResource MenuFlyoutBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource YikCornerRadius}"
                            HorizontalAlignment="Stretch"
                            Margin="8"
                            Padding="4,4,5,4">
                            <StackPanel Name="PART_OverflowPanel" />
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <yik:ContentExpander
                Grid.Row="1"
                Name="PART_ContentExpand"
                Orientation="Vertical"
                VerticalAlignment="Top">
                <ItemsPresenter
                    Grid.IsSharedSizeScope="True"
                    ItemsPanel="{Binding ItemsPanel, RelativeSource={RelativeSource TemplatedParent}}"
                    Margin="0,4,0,0"
                    Name="PART_ItemsPresenter" />
            </yik:ContentExpander>
        </Grid>
    </ControlTemplate>

    <ControlTheme TargetType="yik:NavMenuItem" x:Key="{x:Type yik:NavMenuItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <yik:OverflowStackPanel />
            </ItemsPanelTemplate>
        </Setter>
        <Setter Property="Template" Value="{StaticResource DefaultNavMenuItemTemplate}" />

        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}" />
        </Style>
        <Style Selector="^:empty:pointerover">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}" />
        </Style>

        <Style Selector="^ /template/ yik|ContentExpander#PART_ContentExpand">
            <Setter Property="Multiplier" Value="1" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition
                        Duration="0:0:0.3"
                        Easing="ExponentialEaseOut"
                        Property="Multiplier" />
                    <DoubleTransition
                        Duration="0:0:0.3"
                        Easing="ExponentialEaseOut"
                        Property="Opacity" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^:vertical-collapsed /template/ yik|ContentExpander#PART_ContentExpand">
            <Setter Property="Multiplier" Value="0" />
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="^:vertical-collapsed /template/ PathIcon#PART_ExpanderIcon">
            <Setter Property="RenderTransform" Value="rotate(-90deg)" />
        </Style>
        <Style Selector="^:empty /template/ PathIcon#PART_ExpanderIcon">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ Border#PART_Border:pointerover">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}" />
        </Style>
        <Style Selector="^:selected /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}" />
        </Style>
        <Style Selector="^:selected /template/ Rectangle#SelectionIndicator">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scaleY(1)" />
        </Style>

        <Style Selector="^:horizontal-collapsed">
            <Setter Property="MinWidth" Value="35" />
            <Style Selector="^ /template/ ContentPresenter#PART_IconPresenter">
                <Setter Property="Padding" Value="0" />
            </Style>
        </Style>

        <Style Selector="^">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="^:empty /template/ yik|ContentExpander#PART_ContentExpand">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^:horizontal-collapsed:first-level">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Grid.IsSharedSizeScope" Value="True" />
            <Style Selector="^ /template/ Border#PART_Border">
                <Setter Property="ToolTip.Tip">
                    <Template>
                        <ContentPresenter Content="{TemplateBinding yik:NavMenuItem.Header}"
                                          ContentTemplate="{TemplateBinding yik:NavMenuItem.HeaderTemplate}" />
                    </Template>
                </Setter>
                <Setter Property="ToolTip.ShowDelay" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
            <Style Selector="^ /template/ Border#PART_Border:pointerover">
                <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}" />
            </Style>
            <Style Selector="^ /template/ ContentPresenter#PART_IconPresenter">
                <Setter Property="Grid.ColumnSpan" Value="3" />
                <Setter Property="Margin" Value="0 8" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
            <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ /template/ PathIcon#PART_ExpanderIcon">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ /template/ yik|ContentExpander#PART_ContentExpand">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </Style>

        <Style Selector="^:horizontal-collapsed:not(:first-level)">
            <Style Selector="^ /template/ PathIcon#PART_ExpanderIcon">
                <Setter Property="RenderTransform" Value="rotate(90deg)" />
            </Style>
        </Style>

        <Style Selector="^[IsSeparator=True]">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel
                        Cursor="No"
                        Margin="4,0"
                        Name="PART_RootPanel">
                        <ContentPresenter
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            Foreground="{DynamicResource TextBlockQuaternaryForeground}"
                            HorizontalAlignment="Left"
                            IsVisible="{TemplateBinding Header,
                                                        Converter={x:Static ObjectConverters.IsNotNull}}"
                            Margin="4,0"
                            Name="PART_HeaderPresenter">
                            <ContentPresenter.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                </Style>
                            </ContentPresenter.Styles>
                        </ContentPresenter>
                        <Rectangle
                            Fill="{DynamicResource NavigationMenuItemSeparatorBorderForeground}"
                            Height="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,2"
                            Name="PART_SeparatorBorder" />
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:horizontal-collapsed:first-level">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
                <Style Selector="^ /template/ Rectangle#PART_SeparatorBorder">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="Width" Value="12" />
                </Style>
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>