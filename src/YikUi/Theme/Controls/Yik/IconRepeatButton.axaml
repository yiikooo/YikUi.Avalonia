<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">

    <ControlTheme
        BasedOn="{StaticResource BaseIconButton}"
        TargetType="yik:IconRepeatButton"
        x:Key="{x:Type yik:IconRepeatButton}">
        <Setter Property="Template" Value="{StaticResource IconButtonTemplate}" />
    </ControlTheme>

</ResourceDictionary>