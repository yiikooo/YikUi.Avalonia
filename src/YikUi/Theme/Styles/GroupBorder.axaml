<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yik="https://github.com/yiikooo/YikUi.Avalonia">
    <Style Selector="yik|GroupBorder[IsHeaderSelectable=True]">
        <Style Selector="^ TextBlock#Text">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^ SelectableTextBlock#SelectableText">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </Style>
    <Style Selector="yik|GroupBorder[IsHeaderSelectable=False]">
        <Style Selector="^ TextBlock#Text">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^ SelectableTextBlock#SelectableText">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Style>
</Styles>